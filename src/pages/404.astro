---
import BaseLayout from "../layouts/BaseLayout.astro";
import Footer from "../components/Footer.astro";
---

<BaseLayout
  title="Page Not Found | Argmin"
  description="The page you're looking for doesn't exist."
  canonicalUrl="https://argmin.co/404"
  robots="noindex, nofollow"
  showMobileThemeToggle={false}
>
  <main id="main-content">
    <section class="px-6">
      <div class="site-shell">
        <div class="relative mx-auto max-w-2xl rise-in">
          <div aria-hidden="true" class="pointer-events-none absolute inset-x-0 -top-8 flex justify-center text-[clamp(7rem,22vw,14rem)] font-bold leading-none tracking-[-0.06em] text-argmin-accent/10 select-none">
            404
          </div>
          <div class="relative rounded-[1.75rem] border border-argmin-border bg-argmin-surface/90 px-8 py-12 text-center shadow-[var(--page-shadow-soft)] backdrop-blur md:px-12 md:py-16">
            <p class="section-kicker">Argmin · Error 404</p>
            <h1 class="section-title-lg mt-4">This route doesn't resolve.</h1>
            <p class="mx-auto mt-5 max-w-lg text-base leading-8 text-argmin-mid md:text-lg">
              The page you were trying to reach has moved or was never here. No attribution lost — let's get you back on a known path.
            </p>
            <div class="mt-8 flex flex-wrap justify-center gap-3">
              <a href="/" class="button-primary">Back to home</a>
              <a href="/platform" class="button-secondary">See the platform</a>
              <a href="/contact" class="button-secondary">Contact us</a>
            </div>
          </div>
        </div>
      </div>
    </section>

    <Footer />
  </main>
</BaseLayout>
