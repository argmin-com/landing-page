---
import BaseLayout from "../layouts/BaseLayout.astro";
import Footer from "../components/Footer.astro";
---

<BaseLayout
  title="Page Not Found | Argmin"
  description="The page you're looking for doesn't exist."
  canonicalUrl="https://argmin.co/404"
  robots="noindex, nofollow"
  showMobileThemeToggle={false}
>
  <main id="main-content">
    <section class="px-6 py-20 md:py-32">
      <div class="site-shell text-center">
        <p class="section-kicker">404</p>
        <h1 class="section-title-lg mt-5">Page not found.</h1>
        <p class="mx-auto mt-6 max-w-lg text-lg leading-8 text-argmin-mid">
          The page you're looking for doesn't exist or has been moved.
        </p>
        <div class="mt-8 flex flex-wrap justify-center gap-3">
          <a href="/" class="button-primary">Back to home</a>
          <a href="/contact" class="button-secondary">Contact us</a>
        </div>
      </div>
    </section>

    <Footer />
  </main>
</BaseLayout>
