---
import BaseLayout from "../layouts/BaseLayout.astro";
import Footer from "../components/Footer.astro";
import PageHero from "../components/PageHero.astro";

---

<BaseLayout
  title="Security | Argmin"
  description="Argmin runs inside your environment with read-only connectors, advisory-first workflows, and a narrow trust boundary."
  canonicalUrl="https://argmin.co/security"
>
  <main id="main-content">
    <PageHero
      eyebrow="Security"
      title="Your data never leaves your environment."
      lede="Argmin runs inside your cloud with read-only access. The product does not depend on broad telemetry exfiltration, write paths, or agents to resolve AI cost ownership."
      notes={[
        { label: "Trust boundary", value: "Signals stay inside the customer environment." },
        { label: "Operating mode", value: "Advisory first, enforcement only by explicit opt-in." },
        { label: "Availability", value: "Fail-open architecture with a 50ms latency budget." },
      ]}
      actions={[
        { href: "/platform#deployment-path", label: "See deployment path" },
        { href: "/contact", label: "Talk through your environment", variant: "secondary" },
      ]}
    />

    <section class="px-6 pb-10 pt-8 md:pb-14">
      <div class="site-shell section-divider pt-10">
        <div class="grid gap-8 lg:grid-cols-[minmax(0,0.72fr)_minmax(0,0.28fr)] lg:items-end">
          <div>
            <p class="section-kicker">Operating Posture</p>
            <h2 class="display-title mt-5 max-w-4xl text-[2.4rem] md:text-[3.4rem]">Read-only by default. Advisory first.</h2>
            <p class="mt-5 max-w-3xl text-base leading-8 text-argmin-mid md:text-lg">
              Argmin is designed to surface the accountable record first. Hard stops and enforcement paths are
              available only when a customer explicitly chooses them.
            </p>
          </div>
          <div class="flex flex-col gap-3">
            <a href="/demo" class="button-primary">Request a Demo</a>
            <a href="/platform" class="button-secondary">See platform details</a>
          </div>
        </div>
      </div>
    </section>

    <Footer />
  </main>
</BaseLayout>
