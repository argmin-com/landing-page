---
import BaseLayout from "../layouts/BaseLayout.astro";
import Footer from "../components/Footer.astro";
import PageHero from "../components/PageHero.astro";
import SectionNav from "../components/SectionNav.astro";

const securitySections = [
  { id: "security-principles", label: "Principles" },
  { id: "security-data-flow", label: "Data Flow" },
];

const principles = [
  {
    title: "Read-only connectors",
    description:
      "Argmin ingests cloud telemetry, billing, identity, and CI/CD data through read-only APIs. No write access to production systems, no agents running in your workloads.",
    icon: "lock",
  },
  {
    title: "Inside your environment",
    description:
      "All data processing happens inside the customer trust boundary. Attribution graphs, cost models, and decision records stay in your cloud, never exfiltrated to ours.",
    icon: "shield",
  },
  {
    title: "Advisory by default",
    description:
      "Argmin surfaces recommendations and decision records. Hard stops and enforcement are only activated when you explicitly opt in, never silently enabled.",
    icon: "eye",
  },
  {
    title: "Fail-open architecture",
    description:
      "If Argmin is unreachable, requests proceed normally. The system operates within a 50ms latency budget and never blocks production traffic on failure.",
    icon: "zap",
  },
];

const reads = [
  "Cloud billing exports and cost allocation data",
  "Identity and org mapping (SSO, IAM, HR systems)",
  "CI/CD metadata and deployment history",
  "Source control ownership (CODEOWNERS, commit metadata)",
  "Model usage telemetry (tokens, latency, routes)",
];

const neverDoes = [
  "Write access to production systems",
  "Agents or sidecars in your workloads",
  "Exfiltration of traces, logs, or cost data",
  "Mandatory inline interception of model calls",
  "Persistent storage outside your environment",
];
---

<BaseLayout
  title="Security: Read-Only, Inside Your Cloud | Argmin"
  description="Argmin runs inside your environment with read-only connectors, advisory-first workflows, and a narrow trust boundary. Your data never leaves your cloud."
  canonicalUrl="https://argmin.co/security"
  showMobileThemeToggle={false}
>
  <main id="main-content">
    <script is:inline type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "FAQPage",
      "mainEntity": [
        ...principles.map(p => ({
          "@type": "Question",
          "name": `How does Argmin handle ${p.title.toLowerCase()}?`,
          "acceptedAnswer": {
            "@type": "Answer",
            "text": p.description
          }
        })),
        ...neverDoes.map(item => ({
          "@type": "Question",
          "name": `How does Argmin handle ${item.toLowerCase()}?`,
          "acceptedAnswer": {
            "@type": "Answer",
            "text": `Argmin never does this: ${item}.`
          }
        }))
      ]
    })} />
    <PageHero
      eyebrow="Security"
      title="Your data never leaves your environment."
      lede="Argmin runs inside your cloud with read-only access. The product does not depend on broad telemetry exfiltration, write paths, or agents to deliver attribution and governance."
      notes={[
        { label: "Trust boundary", value: "Signals stay inside the customer environment." },
        { label: "Operating mode", value: "Advisory first, enforcement only by explicit opt-in." },
        { label: "Availability", value: "Fail-open architecture with a 50ms latency budget." },
      ]}
      actions={[
        { href: "/contact", label: "Request a Demo" },
        { href: "/contact", label: "Contact Us", variant: "secondary" },
      ]}
    />

    <SectionNav sections={securitySections} ariaLabel="Security page sections" />

    <section id="security-principles" class="px-6">
      <div class="site-shell section-divider pt-10">
        <div class="max-w-3xl rise-in">
          <p class="section-kicker">Security Principles</p>
          <h2 class="section-title mt-5 max-w-4xl">Narrow trust boundary. No shortcuts.</h2>
          <p class="mt-5 max-w-2xl text-base leading-8 text-argmin-mid md:text-lg">
            Enterprise security teams need to know exactly what Argmin accesses, where data lives, and what happens if the system fails.
          </p>
        </div>

        <div class="mx-auto mt-10 grid max-w-5xl gap-5 md:grid-cols-2">
          {principles.map((principle) => (
            <article class="surface-panel px-6 py-6 transition-transform duration-200 hover:translate-y-[-2px]">
              <div class="flex items-center gap-3">
                {principle.icon === "lock" && (
                  <svg viewBox="0 0 24 24" class="h-6 w-6 text-argmin-accent" aria-hidden="true" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
                    <rect x="4" y="11" width="16" height="10" rx="2" />
                    <path d="M8 11V7a4 4 0 018 0v4" />
                  </svg>
                )}
                {principle.icon === "shield" && (
                  <svg viewBox="0 0 24 24" class="h-6 w-6 text-argmin-accent" aria-hidden="true" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M12 3l8 3v6c0 5-3.5 8.5-8 9-4.5-.5-8-4-8-9V6l8-3z" />
                  </svg>
                )}
                {principle.icon === "eye" && (
                  <svg viewBox="0 0 24 24" class="h-6 w-6 text-argmin-accent" aria-hidden="true" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M2 12s3.5-7 10-7 10 7 10 7-3.5 7-10 7S2 12 2 12z" />
                    <circle cx="12" cy="12" r="3" />
                  </svg>
                )}
                {principle.icon === "zap" && (
                  <svg viewBox="0 0 24 24" class="h-6 w-6 text-argmin-accent" aria-hidden="true" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M13 2L4 14h7l-1 8 9-12h-7l1-8z" />
                  </svg>
                )}
                <h3 class="text-xl font-semibold tracking-[-0.03em] text-argmin-dark">{principle.title}</h3>
              </div>
              <p class="mt-4 text-base leading-7 text-argmin-mid">{principle.description}</p>
            </article>
          ))}
        </div>
      </div>
    </section>

    <section id="security-data-flow" class="px-6 bg-argmin-surface-alt/30">
      <div class="site-shell section-divider pt-10">
        <div class="max-w-3xl rise-in">
          <p class="section-kicker">Data Flow</p>
          <h2 class="section-title mt-5 max-w-4xl">What Argmin accesses and where it lives.</h2>
        </div>

        <div class="mx-auto mt-10 max-w-5xl">
          <div class="surface-panel overflow-hidden">
            <div class="grid gap-0 md:grid-cols-[1fr_1px_1fr]">
              <div class="p-6 md:p-8">
                <p class="flex items-center gap-2 text-sm font-semibold uppercase tracking-[0.18em] text-argmin-success">
                  <svg viewBox="0 0 24 24" class="h-5 w-5" aria-hidden="true" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M5 12l5 5 9-10" />
                  </svg>
                  What we access
                </p>
                <ul class="mt-5 space-y-3">
                  {reads.map((item) => (
                    <li class="flex items-start gap-3 text-base leading-7 text-argmin-mid">
                      <svg viewBox="0 0 24 24" class="mt-1 h-4 w-4 shrink-0 text-argmin-success" aria-hidden="true" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round">
                        <path d="M5 12l5 5 9-10" />
                      </svg>
                      <span>{item}</span>
                    </li>
                  ))}
                </ul>
              </div>

              <div class="bg-argmin-border md:w-px h-px w-full md:h-auto" aria-hidden="true"></div>

              <div class="p-6 md:p-8">
                <p class="flex items-center gap-2 text-sm font-semibold uppercase tracking-[0.18em] text-argmin-danger">
                  <svg viewBox="0 0 24 24" class="h-5 w-5" aria-hidden="true" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M6 6l12 12M18 6L6 18" />
                  </svg>
                  What we never do
                </p>
                <ul class="mt-5 space-y-3">
                  {neverDoes.map((item) => (
                    <li class="flex items-start gap-3 text-base leading-7 text-argmin-mid">
                      <svg viewBox="0 0 24 24" class="mt-1 h-4 w-4 shrink-0 text-argmin-danger" aria-hidden="true" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round">
                        <path d="M6 6l12 12M18 6L6 18" />
                      </svg>
                      <span>{item}</span>
                    </li>
                  ))}
                </ul>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <section class="px-6 bg-argmin-surface-alt/30">
      <div class="site-shell section-divider pt-10">
        <div class="mx-auto flex max-w-3xl flex-col items-center gap-5 text-center rise-in">
          <h2 class="section-title max-w-3xl">Ready to review the architecture?</h2>
          <p class="max-w-2xl text-base leading-8 text-argmin-mid">
            We walk through trust boundaries, data access, and deployment posture with your security and infrastructure teams before any connectors are deployed.
          </p>
          <div class="flex flex-wrap justify-center gap-3">
            <a href="/contact" class="button-primary">Request a Demo</a>
            <a href="/platform" class="button-secondary">See the platform</a>
          </div>
        </div>
      </div>
    </section>

    <Footer />
  </main>
</BaseLayout>
