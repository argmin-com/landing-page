---
import BaseLayout from "../layouts/BaseLayout.astro";
import Footer from "../components/Footer.astro";
import PageHero from "../components/PageHero.astro";

const roles = [
  {
    label: "Engineering",
    question: "Which service or release changed the bill, and can we catch that before production?",
    trigger: "A deployment doubles inference cost overnight. No one knows which service or model change caused it.",
    inputs: "Cloud telemetry, source control, CI/CD metadata, service identity, deployment history.",
    intervention:
      "Argmin shows projected monthly impact when a model route, fallback chain, or retry policy changes before the release goes wide.",
    outcome:
      "Catch model-route regressions before they hit production, then resolve spikes to the owner and release that caused them.",
    moment: "A model-route change shows projected monthly delta before the PR is approved.",
  },
  {
    label: "Finance / FinOps",
    question: "Who owns this spend and which budget actually absorbs it?",
    trigger: "The board asks for AI ROI by business unit. Finance has invoice totals and no way to break them down.",
    inputs: "Billing exports, budget hierarchy, org mapping, cost-center ownership, service attribution.",
    intervention:
      "Argmin resolves spend to accountable owners with confidence instead of leaving finance with invoice totals and detective work.",
    outcome:
      "Attribute spend to an owner and budget, reduce monthly close friction, and surface the highest-leverage cost decisions sooner.",
    moment: "Approvers see owner, budget, and lower-cost alternatives before rollout.",
  },
  {
    label: "Security",
    question: "Which identities and workflows can create ungoverned model spend inside our environment?",
    trigger: "An audit reveals service accounts with uncapped model access and no approval flow attached.",
    inputs: "SSO or IAM, service accounts, approval flows, runtime identity, org controls.",
    intervention:
      "Argmin ties access and deploy identities to real cost exposure without broad telemetry exfiltration or mandatory write paths.",
    outcome:
      "Resolve spend spikes to exact identities and close governance gaps before they turn into audit findings.",
    moment: "A spend spike resolves to the exact service, team, and deploy that caused it.",
  },
];

const bestFit = [
  "AI programs with multiple services, multiple budgets, and no reliable owner when spend moves.",
  "Teams that already have telemetry but still cannot answer who changed the unit economics.",
  "Organizations that need to keep decision evidence inside the customer trust boundary.",
];

const roleAnchors = ["engineering", "finance-finops", "security"];
---

<BaseLayout
  title="Use Cases | Argmin"
  description="How engineering, finance, and security teams use Argmin to trace AI spend and intervene earlier."
  canonicalUrl="https://argmin.co/use-cases"
  showMobileThemeToggle={false}
>
  <main id="main-content">
    <PageHero
      eyebrow="Use Cases"
      title="Three buyers. One decision layer."
      lede="Different stakeholders come with different questions. Argmin meets each where they are while relying on a single, unified attribution layer underneath."
      notes={[
        { label: "Engineering", value: "Catch model-route regressions before they land in production." },
        { label: "Finance / FinOps", value: "Move from invoice totals to accountable budget decisions." },
        { label: "Security", value: "Tie runtime identities and approval flows to real cost exposure." },
      ]}
      actions={[
        { href: "/platform", label: "See the platform" },
        { href: "/demo", label: "Bring a spend spike", variant: "secondary" },
      ]}
    />

    <section class="px-6 pb-8 pt-0 md:pb-10">
      <div class="site-shell">
        <div class="surface-panel mx-auto max-w-4xl px-6 py-5 md:px-8">
          <p class="section-kicker mb-3">Jump to section</p>
          <nav class="quick-links" aria-label="Use cases page sections">
            <a class="quick-link" href="#problem">Problem</a>
            <a class="quick-link" href="#personas">Personas</a>
            <a class="quick-link" href="#best-fit">Best fit</a>
          </nav>
        </div>
      </div>
    </section>

    <section id="problem" class="px-6 pb-10 pt-0 md:pb-14 md:pt-0">
      <div class="site-shell">
        <div class="surface-panel mx-auto max-w-4xl px-6 py-8 md:px-10 md:py-10">
          <p class="section-kicker mb-4">The Problem</p>
          <p class="text-xl leading-relaxed text-argmin-dark md:text-2xl max-w-[65ch]">
            AI spend is growing faster than any other infrastructure line item. Without attribution,
            every dollar is unaccountable, budgets are set by negotiation, overruns go undetected, and
            the board cannot distinguish productive AI investment from waste. The longer you wait, the
            harder the problem becomes.
          </p>
        </div>
      </div>
    </section>

    <section id="personas" class="px-6 py-8 md:py-12 bg-argmin-surface-alt/30">
      <div class="site-shell section-divider pt-10">
        <div class="flex flex-wrap gap-2 border-b border-argmin-border pb-0" role="tablist" aria-label="Use case personas" id="role-tabs">
          {roles.map((role, index) => (
            <button
              role="tab"
              id={`tab-${index}`}
              data-slug={roleAnchors[index]}
              aria-selected={index === 0 ? "true" : "false"}
              aria-controls={`panel-${index}`}
              tabindex={index === 0 ? "0" : "-1"}
              class:list={[
                "role-tab relative px-5 py-3 text-sm font-semibold tracking-[0.08em] uppercase transition-colors duration-180",
                "rounded-t-xl border border-b-0 border-transparent",
                "hover:text-argmin-dark focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-argmin-accent focus-visible:ring-offset-2",
                index === 0 ? "text-argmin-dark border-argmin-border bg-argmin-surface" : "text-argmin-light",
              ]}
            >
              {role.label}
            </button>
          ))}
        </div>

        {roles.map((role, index) => (
          <article
            role="tabpanel"
            id={`panel-${index}`}
            aria-labelledby={`tab-${index}`}
            class:list={[
              "role-panel grid gap-6 py-9 lg:grid-cols-[minmax(0,0.38fr)_minmax(0,0.62fr)] lg:gap-10",
              index !== 0 && "hidden",
            ]}
          >
            <div>
              <p class="section-kicker text-argmin-accent">{role.label}</p>
              <h2 class="mt-5 text-3xl font-semibold tracking-[-0.05em] text-argmin-dark md:text-4xl">{role.question}</h2>
              <p class="mt-5 text-base leading-8 text-argmin-mid">{role.moment}</p>
              <p class="mt-4 rounded-lg border border-argmin-border bg-argmin-surface-alt/60 px-4 py-3 text-sm leading-7 text-argmin-mid">
                <span class="font-semibold text-argmin-dark">What forces action:</span> {role.trigger}
              </p>
            </div>
            <div class="grid gap-4 md:grid-cols-2">
              <div class="surface-panel px-5 py-5">
                <p class="section-kicker">Signals</p>
                <p class="mt-4 text-base leading-8 text-argmin-dark">{role.inputs}</p>
              </div>
              <div class="surface-panel px-5 py-5">
                <p class="section-kicker">What Changes</p>
                <p class="mt-4 text-base leading-8 text-argmin-mid">{role.intervention}</p>
                <p class="mt-5 border-t border-argmin-border pt-5 text-base leading-8 text-argmin-dark">{role.outcome}</p>
              </div>
            </div>
          </article>
        ))}

        <noscript>
          <style>.role-panel { display: grid !important; border-bottom: 1px solid rgb(var(--color-argmin-border)); } .role-panel:last-of-type { border-bottom: none; } [role="tablist"] { display: none !important; }</style>
        </noscript>
      </div>
    </section>

    <script define:vars={{ roleAnchors }} is:inline>
      (function () {
        const tablist = document.getElementById("role-tabs");
        if (!tablist) return;
        const tabs = tablist.querySelectorAll("[role='tab']");
        const panels = document.querySelectorAll(".role-panel");

        function activate(index) {
          tabs.forEach(function (t, i) {
            var isActive = i === index;
            t.setAttribute("aria-selected", String(isActive));
            t.setAttribute("tabindex", isActive ? "0" : "-1");
            if (isActive) {
              t.classList.add("text-argmin-dark", "border-argmin-border", "bg-argmin-surface");
              t.classList.remove("text-argmin-light", "border-transparent");
            } else {
              t.classList.remove("text-argmin-dark", "border-argmin-border", "bg-argmin-surface");
              t.classList.add("text-argmin-light", "border-transparent");
            }
          });
          panels.forEach(function (p, i) {
            if (i === index) {
              p.classList.remove("hidden");
            } else {
              p.classList.add("hidden");
            }
          });
          var nextHash = "#" + roleAnchors[index];
          if (window.location.hash !== nextHash) {
            history.replaceState(null, "", nextHash);
          }
        }

        tabs.forEach(function (tab, i) {
          tab.addEventListener("click", function () { activate(i); });
        });

        tablist.addEventListener("keydown", function (e) {
          var current = Array.from(tabs).findIndex(function (t) { return t.getAttribute("aria-selected") === "true"; });
          var next = current;
          if (e.key === "ArrowRight") next = (current + 1) % tabs.length;
          else if (e.key === "ArrowLeft") next = (current - 1 + tabs.length) % tabs.length;
          else if (e.key === "Home") next = 0;
          else if (e.key === "End") next = tabs.length - 1;
          else return;
          e.preventDefault();
          activate(next);
          tabs[next].focus();
        });

        var hash = window.location.hash.replace("#", "");
        var matchedIndex = roleAnchors.indexOf(hash);
        if (matchedIndex >= 0) activate(matchedIndex);
      })();
    </script>

    <section id="best-fit" class="px-6 py-8 md:py-12">
      <div class="site-shell section-divider pt-10">
        <div class="grid gap-10 lg:grid-cols-[minmax(0,0.7fr)_minmax(0,1.3fr)] lg:gap-16">
          <div class="rise-in">
            <p class="section-kicker">Best Fit</p>
            <h2 class="display-title mt-5 max-w-3xl text-[2.4rem] md:text-[3.4rem]">Where the decision layer matters most.</h2>
          </div>

          <div class="rise-in rise-in-delay-1">
            <ul class="grid gap-4 md:grid-cols-3">
              {bestFit.map((item) => (
                <li class="surface-panel px-5 py-5 text-base leading-8 text-argmin-mid">{item}</li>
              ))}
            </ul>
          </div>
        </div>
      </div>
    </section>

    <section class="px-6 pb-10 pt-8 md:pb-14">
      <div class="site-shell section-divider pt-10">
        <div class="grid gap-8 lg:grid-cols-[minmax(0,0.72fr)_minmax(0,0.28fr)] lg:items-end">
          <div>
            <p class="section-kicker">Next Step</p>
            <h2 class="display-title mt-5 max-w-4xl text-[2.4rem] md:text-[3.4rem]">Start with the stakeholder already feeling the pain.</h2>
            <p class="mt-5 max-w-3xl text-base leading-8 text-argmin-mid md:text-lg">
              Usually that means an engineering owner plus finance or FinOps, and sometimes security when
              approval or access controls are part of the problem.
            </p>
          </div>
          <div class="flex flex-col gap-3">
            <a href="/contact" class="button-primary">Contact Us</a>
            <a href="/platform" class="button-secondary">See platform details</a>
          </div>
        </div>
      </div>
    </section>

    <Footer />
  </main>
</BaseLayout>
