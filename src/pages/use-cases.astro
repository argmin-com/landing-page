---
import BaseLayout from "../layouts/BaseLayout.astro";
import Footer from "../components/Footer.astro";
import PageHero from "../components/PageHero.astro";
import SectionNav from "../components/SectionNav.astro";

const useCasesSections = [
  { id: "personas", label: "Personas" },
  { id: "best-fit", label: "Best Fit" },
];

const roles = [
  {
    label: "Engineering",
    question: "Which service or release changed the bill, and can we catch that before production?",
    trigger: "A deployment doubles inference cost overnight. No one knows which service or model change caused it.",
    moment: "A model-route change shows projected monthly delta before the PR is approved.",
    signals: [
      "Cloud telemetry",
      "Source control",
      "CI/CD metadata",
      "Service identity",
      "Deployment history",
    ],
    intervention:
      "Argmin shows projected monthly impact when a model route, fallback chain, or retry policy changes before the release goes wide.",
    outcome:
      "Catch model-route regressions before they hit production, then resolve spikes to the owner and release that caused them.",
  },
  {
    label: "Finance / FinOps",
    question: "Who owns this spend and which budget actually absorbs it?",
    trigger: "The board asks for AI ROI by business unit. Finance has invoice totals and no way to break them down.",
    moment: "Approvers see owner, budget, and lower-cost alternatives before rollout.",
    signals: [
      "Billing exports",
      "Budget hierarchy",
      "Org mapping",
      "Cost-center ownership",
      "Service attribution",
    ],
    intervention:
      "Argmin resolves spend to accountable owners with confidence instead of leaving finance with invoice totals and detective work.",
    outcome:
      "Attribute spend to an owner and budget, reduce monthly close friction, and surface the highest-leverage cost decisions sooner.",
  },
  {
    label: "Security",
    question: "Which identities and workflows can create ungoverned model spend inside our environment?",
    trigger: "An audit reveals service accounts with uncapped model access and no approval flow attached.",
    moment: "A spend spike resolves to the exact service, team, and deploy that caused it.",
    signals: [
      "SSO / IAM",
      "Service accounts",
      "Approval flows",
      "Runtime identity",
      "Org controls",
    ],
    intervention:
      "Argmin ties access and deploy identities to real cost exposure without broad telemetry exfiltration or mandatory write paths.",
    outcome:
      "Resolve spend spikes to exact identities and close governance gaps before they turn into audit findings.",
  },
];

const bestFit = [
  "AI programs with multiple services, multiple budgets, and no reliable owner when spend moves.",
  "Teams that already have telemetry but still cannot answer who changed the unit economics.",
  "Organizations that need to keep decision evidence inside the customer trust boundary.",
];

const roleAnchors = ["engineering", "finance-finops", "security"];
---

<BaseLayout
  title="Use Cases: Engineering, Finance & Security Teams | Argmin"
  description="How engineering, finance, and security teams use Argmin to trace AI spend to owners, surface waste, and intervene before budgets overrun."
  canonicalUrl="https://argmin.co/use-cases"
  showMobileThemeToggle={false}
>
  <main id="main-content">
    <script is:inline type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "FAQPage",
      "mainEntity": roles.map(role => ({
        "@type": "Question",
        "name": role.question,
        "acceptedAnswer": {
          "@type": "Answer",
          "text": role.outcome
        }
      }))
    })} />
    <PageHero
      eyebrow="Use Cases"
      title="One platform. Every stakeholder's question answered."
      lede="Engineering wants to catch regressions before production. Finance needs spend tied to owners and budgets. Security requires governance without broadening the attack surface. Argmin serves all three from a single attribution layer."
      notes={[
        { label: "Engineering", value: "Catch model-route regressions before they land in production." },
        { label: "Finance / FinOps", value: "Move from invoice totals to accountable budget decisions." },
        { label: "Security", value: "Tie runtime identities and approval flows to real cost exposure." },
      ]}
      actions={[
        { href: "/contact", label: "Request a Demo" },
        { href: "/contact", label: "Contact Us", variant: "secondary" },
      ]}
    />

    <SectionNav sections={useCasesSections} ariaLabel="Use cases page sections" />

    <section id="personas" class="px-6">
      <div class="site-shell section-divider pt-10">
        <div class="max-w-3xl rise-in">
          <p class="section-kicker">Personas</p>
          <h2 class="section-title mt-5 max-w-4xl">Pick the stakeholder already feeling the pain.</h2>
        </div>

        <div class="role-tablist mt-10 flex flex-wrap gap-1 border-b border-argmin-border" role="tablist" aria-label="Use case personas" id="role-tabs">
          {roles.map((role, index) => (
            <button
              role="tab"
              id={`tab-${index}`}
              data-slug={roleAnchors[index]}
              aria-selected={index === 0 ? "true" : "false"}
              aria-controls={`panel-${index}`}
              tabindex={index === 0 ? "0" : "-1"}
              class:list={[
                "role-tab relative px-5 py-3 text-lg font-semibold tracking-[-0.01em] transition-colors duration-180",
                "border-b-[3px] hover:text-argmin-dark focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-argmin-accent focus-visible:ring-offset-2",
                index === 0 ? "text-argmin-dark border-argmin-accent" : "text-argmin-light border-transparent",
              ]}
            >
              {role.label}
            </button>
          ))}
        </div>

        {roles.map((role, index) => (
          <article
            role="tabpanel"
            id={`panel-${index}`}
            data-role-anchor={roleAnchors[index]}
            aria-labelledby={`tab-${index}`}
            data-role-index={index}
            class:list={[
              "role-panel grid gap-6 py-9 lg:grid-cols-[minmax(0,0.42fr)_minmax(0,0.58fr)] lg:gap-10",
              index !== 0 && "hidden",
            ]}
          >
            {/* Hash-target anchor so /use-cases#engineering etc. actually scroll to the panel */}
            <span id={roleAnchors[index]} class="role-panel-anchor" aria-hidden="true"></span>
            <p class="role-panel-mobile-label section-kicker">{role.label}</p>
            <div>
              <h3 class="section-title-lg max-w-xl">{role.question}</h3>
              <p class="mt-4 text-base leading-8 text-argmin-dark font-medium">{role.moment}</p>

              <div class="mt-6 rounded-xl border-l-[3px] border-l-argmin-warning border border-argmin-border bg-argmin-warning-surface/50 p-5">
                <p class="text-xs font-semibold uppercase tracking-[0.18em] text-argmin-warning">What forces action</p>
                <p class="mt-2 text-base leading-7 text-argmin-dark">{role.trigger}</p>
              </div>
            </div>

            <div class="space-y-6">
              <div>
                <p class="section-kicker">Signals</p>
                <div class="mt-3 flex flex-wrap gap-2">
                  {role.signals.map((signal) => (
                    <span class="inline-flex items-center rounded-full border border-argmin-border bg-argmin-surface-alt/70 px-3 py-1.5 text-sm text-argmin-mid">{signal}</span>
                  ))}
                </div>
              </div>

              <div>
                <p class="section-kicker">What Changes</p>
                <p class="mt-3 text-base leading-8 text-argmin-mid">{role.intervention}</p>
                <p class="mt-4 text-base leading-8 text-argmin-dark">{role.outcome}</p>
              </div>
            </div>
          </article>
        ))}

        <noscript>
          <style>.role-panel { display: grid !important; border-bottom: 1px solid rgb(var(--color-argmin-border)); } .role-panel:last-of-type { border-bottom: none; } [role="tablist"] { display: none !important; }</style>
        </noscript>
      </div>
    </section>

    <style>
      .role-panel-mobile-label {
        display: none;
      }

      .role-panel-anchor {
        display: block;
        position: relative;
        height: 0;
        scroll-margin-top: 96px;
      }

      @media (max-width: 767px) {
        .role-tablist {
          display: none !important;
        }
        .role-panel {
          display: grid !important;
          border-bottom: 1px solid rgb(var(--color-argmin-border));
          padding-block: 2rem;
        }
        .role-panel:last-of-type {
          border-bottom: none;
        }
        .role-panel-mobile-label {
          display: block;
          margin-bottom: 0.5rem;
        }
      }
    </style>

    <script define:vars={{ roleAnchors }} is:inline>
      (function () {
        const tablist = document.getElementById("role-tabs");
        if (!tablist) return;
        const tabs = tablist.querySelectorAll("[data-role-tab], [role='tab']");
        const panels = document.querySelectorAll(".role-panel");
        const mobileMedia = window.matchMedia("(max-width: 767px)");

        // Tag tabs with a stable selector so the mobile ARIA reset can still
        // find them after we strip role="tab".
        tabs.forEach(function (t) { t.setAttribute("data-role-tab", ""); });

        function isMobile() { return mobileMedia.matches; }

        function applyAriaForBreakpoint() {
          if (isMobile()) {
            // Mobile layout stacks all panels; the tablist is display:none and
            // would orphan its tabpanels, so strip the tab roles entirely.
            tablist.removeAttribute("role");
            tablist.removeAttribute("aria-label");
            tabs.forEach(function (t) {
              t.removeAttribute("role");
              t.removeAttribute("aria-selected");
              t.removeAttribute("aria-controls");
              t.removeAttribute("tabindex");
            });
            panels.forEach(function (p, i) {
              p.removeAttribute("role");
              p.removeAttribute("aria-labelledby");
              // Give each panel a stable landmark label via aria-label so it's
              // still announced as a region even without the tabpanel role.
              p.setAttribute("aria-label", roleAnchors[i]);
            });
          } else {
            tablist.setAttribute("role", "tablist");
            tablist.setAttribute("aria-label", "Use case personas");
            tabs.forEach(function (t, i) {
              t.setAttribute("role", "tab");
              t.setAttribute("aria-controls", "panel-" + i);
              t.setAttribute("id", "tab-" + i);
            });
            panels.forEach(function (p, i) {
              p.setAttribute("role", "tabpanel");
              p.setAttribute("aria-labelledby", "tab-" + i);
              p.removeAttribute("aria-label");
            });
          }
        }

        function activate(index) {
          tabs.forEach(function (t, i) {
            var isActive = i === index;
            if (!isMobile()) {
              t.setAttribute("aria-selected", String(isActive));
              t.setAttribute("tabindex", isActive ? "0" : "-1");
            }
            if (isActive) {
              t.classList.add("text-argmin-dark", "border-argmin-accent");
              t.classList.remove("text-argmin-light", "border-transparent");
            } else {
              t.classList.remove("text-argmin-dark", "border-argmin-accent");
              t.classList.add("text-argmin-light", "border-transparent");
            }
          });
          if (!isMobile()) {
            panels.forEach(function (p, i) {
              if (i === index) {
                p.classList.remove("hidden");
              } else {
                p.classList.add("hidden");
              }
            });
          } else {
            // Mobile: show all panels (stacked accordion style)
            panels.forEach(function (p) { p.classList.remove("hidden"); });
          }
          var nextHash = "#" + roleAnchors[index];
          if (window.location.hash !== nextHash) {
            history.replaceState(null, "", nextHash);
          }
        }

        applyAriaForBreakpoint();

        // When crossing the breakpoint, re-apply ARIA state and the current tab
        mobileMedia.addEventListener("change", function () {
          applyAriaForBreakpoint();
          var current = Array.from(tabs).findIndex(function (t) { return t.getAttribute("aria-selected") === "true"; });
          activate(current === -1 ? 0 : current);
        });

        tabs.forEach(function (tab, i) {
          tab.addEventListener("click", function () { activate(i); });
        });

        tablist.addEventListener("keydown", function (e) {
          var current = Array.from(tabs).findIndex(function (t) { return t.getAttribute("aria-selected") === "true"; });
          var next = current;
          if (e.key === "ArrowRight") next = (current + 1) % tabs.length;
          else if (e.key === "ArrowLeft") next = (current - 1 + tabs.length) % tabs.length;
          else if (e.key === "Home") next = 0;
          else if (e.key === "End") next = tabs.length - 1;
          else return;
          e.preventDefault();
          activate(next);
          tabs[next].focus();
        });

        var hash = window.location.hash.replace("#", "");
        var matchedIndex = roleAnchors.indexOf(hash);
        if (matchedIndex >= 0) activate(matchedIndex);
      })();
    </script>

    <section id="best-fit" class="px-6 bg-argmin-surface-alt/30">
      <div class="site-shell section-divider pt-10">
        <div class="mx-auto max-w-3xl text-center rise-in">
          <p class="section-kicker">Is Argmin right for you?</p>
          <h2 class="section-title mt-5">If these sound familiar, we should talk.</h2>
        </div>

        <ul class="mx-auto mt-10 grid max-w-3xl gap-4">
          {bestFit.map((item) => (
            <li class="flex items-start gap-4 rounded-xl border border-argmin-border bg-argmin-surface/80 p-5 transition-transform duration-200 hover:translate-y-[-2px]">
              <svg viewBox="0 0 24 24" class="mt-0.5 h-5 w-5 shrink-0 text-argmin-success" aria-hidden="true">
                <path d="M5 12l5 5 9-10" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" />
              </svg>
              <span class="text-base leading-7 text-argmin-dark">{item}</span>
            </li>
          ))}
        </ul>

        <p class="mx-auto mt-8 max-w-3xl text-center text-base leading-8 text-argmin-mid">
          Start with the stakeholder already feeling the pain — usually an engineering owner plus finance or FinOps, and sometimes security when approval or access controls are part of the problem.
        </p>

        <div class="mx-auto mt-8 flex max-w-3xl flex-wrap justify-center gap-3">
          <a href="/contact" class="button-primary">Request a Demo</a>
          <a href="/contact" class="button-secondary">Contact Us</a>
        </div>
      </div>
    </section>

    <Footer />
  </main>
</BaseLayout>
