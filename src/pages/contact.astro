---
import ContactForm from "../components/ContactForm.astro";
import BaseLayout from "../layouts/BaseLayout.astro";
import Footer from "../components/Footer.astro";
import PageHero from "../components/PageHero.astro";
import { sanitizeFormspreeUrl } from "../lib/formspree";

const formspreeUrl = sanitizeFormspreeUrl(import.meta.env.PUBLIC_FORMSPREE_URL);
---

<BaseLayout
  title="Contact | Argmin"
  description="Request a demo of Argmin's AI spend attribution and decision-control platform, or get in touch with our team."
  canonicalUrl="https://argmin.co/contact"
  showMobileThemeToggle={false}
>
  <main id="main-content">
    <PageHero
      eyebrow="Contact"
      title="Bring the workload where AI spend already hurts."
      lede="Show us the route change, approval bottleneck, or budget ambiguity that is already creating friction. We scope one workload first, connect read-only, and show the attribution path before you commit further."
      notes={[
        { label: "Best input", value: "One service, one route change, or one spend spike that already needs an answer." },
        { label: "What you see", value: "Owner, budget path, confidence, and lower-cost alternatives tied to the same event." },
        { label: "Who joins", value: "Usually an engineering owner plus finance or security, depending on the blocker." },
      ]}
    />

    <section class="px-6 pb-10 md:pb-14">
      <div class="site-shell">
        <div class="mx-auto max-w-2xl">
          <div class="page-section-intro mb-6 text-center">
            <p class="section-kicker">What happens next</p>
            <p class="text-sm leading-relaxed text-argmin-mid md:text-base">
              We usually respond within one business day. A member of the founding team follows up directly.
            </p>
          </div>

          <ContactForm
            formspreeUrl={formspreeUrl}
            headingId="contact-form-heading"
            headingText="Get in touch"
            variant="standalone"
          />
        </div>
      </div>
    </section>

    <Footer />
  </main>
</BaseLayout>
