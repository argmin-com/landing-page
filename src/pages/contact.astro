---
import ContactForm from "../components/ContactForm.astro";
import BaseLayout from "../layouts/BaseLayout.astro";
import Footer from "../components/Footer.astro";
import PageHero from "../components/PageHero.astro";
import { sanitizeFormspreeUrl } from "../lib/formspree";

const formspreeUrl = sanitizeFormspreeUrl(import.meta.env.PUBLIC_FORMSPREE_URL);
---

<BaseLayout
  title="Contact Argmin — Request a Demo or Talk to the Team"
  description="Request a demo, ask a question, or start a conversation with the Argmin team. Typical onboarding: one workload, 2–4 weeks to first attributable insight."
  canonicalUrl="https://argmin.co/contact"
  showMobileThemeToggle={false}
>
  <main id="main-content">
    <PageHero
      eyebrow="Contact"
      title="Let's talk about what you're building."
      lede="Whether you're managing AI spend, building governance workflows, or trying to trace ownership across services — start with one workload. We connect read-only and show the attribution path before you commit further."
      notes={[
        { label: "Good starting points", value: "A spend spike, a governance gap, a route change, or an ownership question that needs an answer." },
        { label: "Typical deployment", value: "2–4 weeks to first attributable insight. Single cloud, 1–2 workloads to start." },
        { label: "Who joins", value: "Usually an engineering owner plus finance or security, depending on the challenge." },
      ]}
    />

    <section class="px-6">
      <div class="site-shell section-divider pt-10">
        <div class="mx-auto max-w-2xl">
          <div class="page-section-intro mb-6 text-center rise-in">
            <p class="section-kicker">What happens next</p>
            <p class="mt-3 text-sm leading-relaxed text-argmin-mid md:text-base">
              We usually respond within one business day. A member of the founding team follows up directly.
            </p>
          </div>

          <ContactForm
            formspreeUrl={formspreeUrl}
            headingId="contact-form-heading"
            headingText="Get in touch"
            variant="standalone"
          />

          <div class="mt-6 flex flex-wrap justify-center gap-3 text-sm text-argmin-mid">
            <span class="quick-link">Read-only access</span>
            <span class="quick-link">Runs in your environment</span>
            <span class="quick-link">No data exfiltration</span>
          </div>
        </div>
      </div>
    </section>

    <Footer />
  </main>
</BaseLayout>
