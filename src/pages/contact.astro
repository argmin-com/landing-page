---
import BaseLayout from "../layouts/BaseLayout.astro";
import Footer from "../components/Footer.astro";
import PageHero from "../components/PageHero.astro";
import { sanitizeFormspreeUrl } from "../lib/formspree";

const formspreeUrl = sanitizeFormspreeUrl(import.meta.env.PUBLIC_FORMSPREE_URL);
const endpoint = formspreeUrl.trim();
const hasEndpoint = endpoint.length > 0;
---

<BaseLayout
  title="Contact Us | Argmin"
  description="Contact Argmin about enterprise AI spend attribution, governance, and optimization."
  canonicalUrl="https://argmin.co/contact"
>
  <main id="main-content">
    <PageHero
      eyebrow="Contact"
      title="Let's talk about your AI spend."
      lede="We are working with a limited number of design partners. If your team is spending on AI inference and cannot track what it is spending, who is spending it, or whether it is money well spent, we should talk."
      notes={[
        { label: "Typical deployment", value: "2–4 weeks to first attributable insight. Single cloud, 1–2 workloads to start." },
        { label: "What to expect", value: "We scope one workload, connect read-only, and show attribution before you commit." },
      ]}
    />

    <section class="px-6 pb-10 md:pb-14">
      <div class="site-shell">
        <div class="mx-auto max-w-2xl">
          <p class="mb-6 text-center text-sm leading-relaxed text-argmin-mid">
            We typically respond within one business day. A member of the founding team will follow up directly.
          </p>

          <div class="surface-panel px-6 py-8 md:px-10 md:py-10" id="form-container" aria-live="polite">
            <form
              id="contact-form"
              class="space-y-5"
              aria-labelledby="form-heading"
              data-form-configured={String(hasEndpoint)}
              action={hasEndpoint ? endpoint : undefined}
              method="POST"
            >
              <h2 id="form-heading" class="section-kicker">Send a message</h2>

              <div class="grid gap-5 sm:grid-cols-2">
                <div>
                  <label for="name" class="mb-2 block text-sm font-medium text-argmin-dark">Name</label>
                  <input
                    id="name"
                    name="name"
                    type="text"
                    required
                    placeholder="Your name"
                    class="w-full rounded-xl border border-argmin-border bg-argmin-surface px-4 py-3 text-base text-argmin-dark placeholder:text-argmin-light transition-colors duration-150 hover:border-argmin-accent/40 focus:border-transparent focus:outline-none focus:ring-2 focus:ring-argmin-accent"
                  />
                </div>
                <div>
                  <label for="email" class="mb-2 block text-sm font-medium text-argmin-dark">Email</label>
                  <input
                    id="email"
                    name="email"
                    type="email"
                    required
                    placeholder="work@company.com"
                    class="w-full rounded-xl border border-argmin-border bg-argmin-surface px-4 py-3 text-base text-argmin-dark placeholder:text-argmin-light transition-colors duration-150 hover:border-argmin-accent/40 focus:border-transparent focus:outline-none focus:ring-2 focus:ring-argmin-accent"
                  />
                </div>
              </div>
              <div>
                <label for="company" class="mb-2 block text-sm font-medium text-argmin-dark">Company</label>
                <input
                  id="company"
                  name="company"
                  type="text"
                  required
                  placeholder="Company name"
                  class="w-full rounded-xl border border-argmin-border bg-argmin-surface px-4 py-3 text-base text-argmin-dark placeholder:text-argmin-light transition-colors duration-150 hover:border-argmin-accent/40 focus:border-transparent focus:outline-none focus:ring-2 focus:ring-argmin-accent"
                />
              </div>
              <div class="grid gap-5 sm:grid-cols-2">
                <div>
                  <label for="cloud" class="mb-2 block text-sm font-medium text-argmin-dark">Primary cloud</label>
                  <select
                    id="cloud"
                    name="cloud"
                    class="w-full rounded-xl border border-argmin-border bg-argmin-surface px-4 py-3 text-base text-argmin-dark focus:border-transparent focus:outline-none focus:ring-2 focus:ring-argmin-accent"
                  >
                    <option value="">Select...</option>
                    <option value="aws">AWS</option>
                    <option value="azure">Azure</option>
                    <option value="gcp">GCP</option>
                    <option value="multi">Multi-cloud</option>
                    <option value="other">Other</option>
                  </select>
                </div>
                <div>
                  <label for="ai-spend" class="mb-2 block text-sm font-medium text-argmin-dark">Monthly AI spend</label>
                  <select
                    id="ai-spend"
                    name="ai_spend"
                    class="w-full rounded-xl border border-argmin-border bg-argmin-surface px-4 py-3 text-base text-argmin-dark focus:border-transparent focus:outline-none focus:ring-2 focus:ring-argmin-accent"
                  >
                    <option value="">Select...</option>
                    <option value="under-50k">Under $50k</option>
                    <option value="50k-250k">$50k–$250k</option>
                    <option value="250k-1m">$250k–$1M</option>
                    <option value="over-1m">Over $1M</option>
                    <option value="unsure">Not sure</option>
                  </select>
                </div>
              </div>
              <div>
                <label for="teams" class="mb-2 block text-sm font-medium text-argmin-dark">Teams using AI</label>
                <select
                  id="teams"
                  name="teams_using_ai"
                  class="w-full rounded-xl border border-argmin-border bg-argmin-surface px-4 py-3 text-base text-argmin-dark focus:border-transparent focus:outline-none focus:ring-2 focus:ring-argmin-accent"
                >
                  <option value="">Select...</option>
                  <option value="1-3">1–3 teams</option>
                  <option value="4-10">4–10 teams</option>
                  <option value="10-plus">10+ teams</option>
                  <option value="unsure">Not sure</option>
                </select>
              </div>
              <div>
                <label for="message" class="mb-2 block text-sm font-medium text-argmin-dark">Message</label>
                <textarea
                  id="message"
                  name="message"
                  rows="4"
                  placeholder="Tell us about your AI spend challenge"
                  class="w-full rounded-xl border border-argmin-border bg-argmin-surface px-4 py-3 text-base text-argmin-dark placeholder:text-argmin-light transition-colors duration-150 hover:border-argmin-accent/40 focus:border-transparent focus:outline-none focus:ring-2 focus:ring-argmin-accent"
                ></textarea>
              </div>
              <input type="text" id="gotcha" name="_gotcha" class="hidden" tabindex="-1" autocomplete="off" />
              <button
                id="submit-btn"
                type="submit"
                disabled={!hasEndpoint}
                aria-describedby={!hasEndpoint ? "form-config-error" : undefined}
                class="button-primary w-full py-4 text-base"
              >
                {hasEndpoint ? "Get in Touch" : "Form Unavailable"}
              </button>
              <p
                id="form-config-error"
                class={hasEndpoint ? "hidden text-center text-sm text-argmin-mid" : "text-center text-sm text-argmin-mid"}
              >
                Form submissions are currently unavailable. Please email
                <a class="font-medium text-argmin-dark underline decoration-from-font underline-offset-4" href="mailto:contact@argmin.co">contact@argmin.co</a>.
              </p>
              <p id="form-error" class="hidden text-center text-sm text-argmin-mid">
                Submission failed. Please email us directly at
                <a class="font-medium text-argmin-dark underline decoration-from-font underline-offset-4" href="mailto:contact@argmin.co">contact@argmin.co</a>.
              </p>
            </form>
          </div>

          <div class="mt-6 flex flex-wrap justify-center gap-3 text-sm text-argmin-mid">
            <span class="rounded-full border border-argmin-border px-4 py-2">Read-only access</span>
            <span class="rounded-full border border-argmin-border px-4 py-2">Runs in your environment</span>
            <span class="rounded-full border border-argmin-border px-4 py-2">No data exfiltration</span>
          </div>
        </div>

        <noscript>
          <p class="mt-6 text-center text-sm text-argmin-dark">
            Prefer email instead? Reach us directly at
            <a class="font-medium text-argmin-dark underline decoration-from-font underline-offset-4" href="mailto:contact@argmin.co">
              contact@argmin.co
            </a>
            .
          </p>
        </noscript>
      </div>
    </section>

    <Footer />
  </main>
</BaseLayout>

<script is:inline define:vars={{ endpoint }}>
  (function () {
    var form = document.getElementById("contact-form");
    var button = document.getElementById("submit-btn");
    var container = document.getElementById("form-container");
    var error = document.getElementById("form-error");
    var nameField = document.getElementById("name");
    var emailField = document.getElementById("email");
    var companyField = document.getElementById("company");
    var cloudField = document.getElementById("cloud");
    var aiSpendField = document.getElementById("ai-spend");
    var teamsField = document.getElementById("teams");
    var messageField = document.getElementById("message");
    var gotchaField = document.getElementById("gotcha");

    if (
      !endpoint ||
      !(form instanceof HTMLFormElement) ||
      !(button instanceof HTMLButtonElement) ||
      !(container instanceof HTMLElement) ||
      !(nameField instanceof HTMLInputElement) ||
      !(emailField instanceof HTMLInputElement) ||
      !(companyField instanceof HTMLInputElement) ||
      !(cloudField instanceof HTMLSelectElement) ||
      !(aiSpendField instanceof HTMLSelectElement) ||
      !(teamsField instanceof HTMLSelectElement) ||
      !(messageField instanceof HTMLTextAreaElement) ||
      !(gotchaField instanceof HTMLInputElement)
    ) {
      return;
    }

    form.addEventListener("submit", async function (event) {
      event.preventDefault();

      if (!form.reportValidity()) {
        return;
      }

      var payload = {
        name: nameField.value.trim(),
        email: emailField.value.trim(),
        company: companyField.value.trim(),
        cloud: cloudField.value,
        ai_spend: aiSpendField.value,
        teams_using_ai: teamsField.value,
        message: messageField.value.trim(),
        _gotcha: gotchaField.value.trim(),
      };

      button.disabled = true;
      button.textContent = "Sending...";
      if (error) error.classList.add("hidden");

      try {
        var controller = new AbortController();
        var timeout = setTimeout(function () { controller.abort(); }, 10000);
        var response = await fetch(endpoint, {
          method: "POST",
          headers: {
            Accept: "application/json",
            "Content-Type": "application/json",
          },
          body: JSON.stringify(payload),
          signal: controller.signal,
        });
        clearTimeout(timeout);

        if (!response.ok) {
          throw new Error("Form submission failed");
        }

        container.innerHTML =
          '<p class="py-8 text-center text-xl text-argmin-dark">Thank you. We will be in touch shortly.</p>';
        window.plausible && window.plausible("form_submit");
      } catch (submissionError) {
        console.error("Contact form submission failed:", submissionError);
        button.disabled = false;
        button.textContent = "Get in Touch";
        if (error) error.classList.remove("hidden");
      }
    });
  })();
</script>
