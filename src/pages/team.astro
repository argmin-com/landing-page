---
import BaseLayout from "../layouts/BaseLayout.astro";
import Footer from "../components/Footer.astro";
import PageHero from "../components/PageHero.astro";

const founders = [
  {
    name: "Richard McKinney",
    title: "CEO & Co-Founder",
    alt: "Richard McKinney, CEO & Co-Founder",
    webp: "/richard.webp",
    jpg: "/richard.jpg",
    bio: "Richard spent a decade building enterprise data and cost infrastructure at Amazon, Salesforce, and Cruise. At Amazon, he built global data platforms that saved $357M annually. He saw firsthand that AI cost attribution requires a fundamentally different approach—identity-resolved, graph-based, and embedded in the deployment path.",
    linkedin: "https://www.linkedin.com/in/richardcmckinney",
  },
  {
    name: "Charlotte Wargniez",
    title: "CTO & Co-Founder",
    alt: "Charlotte Wargniez, CTO & Co-Founder",
    webp: "/charlotte.webp",
    jpg: "/charlotte.jpg",
    bio: "Charlotte brings deep expertise in AI systems from Oxford and the European Space Agency. Her work in deep reinforcement learning directly powers Argmin's Heuristic Reconciliation Engine—the system that resolves fragmented signals into confidence-scored attribution. She designed the architecture to operate inside customer trust boundaries with read-only, advisory-first deployment.",
    linkedin: "https://www.linkedin.com/in/charlotte-wargniez",
  },
];
---

<BaseLayout
  title="Team | Argmin"
  description="Meet the team building attribution and optimization for enterprise AI spend."
  canonicalUrl="https://argmin.co/team"
>
  <main id="main-content">
    <PageHero
      eyebrow="Team"
      title="Built by operators, not observers."
      lede="We have spent years inside the infrastructure that creates the problem Argmin solves—cloud-scale cost attribution, security governance, and AI deployment. We built Argmin because we saw this problem from inside the systems that create it, and we know that incumbents are not going to solve it."
      actions={[
        { href: "/contact", label: "Get in touch" },
        { href: "/platform", label: "See the platform", variant: "secondary" },
      ]}
    />

    <section class="px-6 pb-10 md:pb-14">
      <div class="site-shell">
        <div class="mx-auto grid max-w-4xl gap-8 md:grid-cols-2">
          {founders.map((founder) => (
            <article class="surface-panel overflow-hidden px-6 pb-10 pt-8 md:px-8">
              <div class="flex items-start gap-5">
                <a
                  href={founder.linkedin}
                  target="_blank"
                  rel="noopener noreferrer"
                  aria-label={`View ${founder.name} on LinkedIn`}
                  class="group shrink-0 transition-transform duration-200 hover:scale-[1.02]"
                >
                  <picture>
                    <source srcset={founder.webp} type="image/webp" />
                    <img
                      src={founder.jpg}
                      alt={founder.alt}
                      class="h-28 w-20 rounded-2xl object-cover shadow-[0_12px_30px_rgba(0,0,0,0.2)] grayscale transition-[filter] duration-300 group-hover:grayscale-0 md:h-36 md:w-24"
                      width="96"
                      height="144"
                      loading="lazy"
                    />
                  </picture>
                </a>
                <div class="pt-1">
                  <div class="flex items-center gap-2">
                    <h2 class="text-xl font-bold text-argmin-dark">{founder.name}</h2>
                    <a
                      href={founder.linkedin}
                      target="_blank"
                      rel="noopener noreferrer"
                      aria-label={`View ${founder.name} on LinkedIn`}
                      class="text-argmin-light transition-colors duration-200 hover:text-argmin-dark"
                    >
                      <svg viewBox="0 0 24 24" class="h-4 w-4 fill-current" aria-hidden="true">
                        <path d="M4.98 3.5A2.49 2.49 0 1 1 5 8.48a2.49 2.49 0 0 1-.02-4.98ZM3 9h4v12H3Zm7 0h3.83v1.64h.05c.53-1 1.84-2.05 3.79-2.05 4.05 0 4.8 2.67 4.8 6.14V21h-4v-5.54c0-1.32-.02-3.02-1.84-3.02-1.85 0-2.13 1.44-2.13 2.93V21h-4Z" />
                      </svg>
                    </a>
                  </div>
                  <p class="mt-1.5 text-base font-semibold text-argmin-accent">{founder.title}</p>
                </div>
              </div>
              <p class="mt-8 text-base leading-8 text-argmin-mid">{founder.bio}</p>
            </article>
          ))}
        </div>
      </div>
    </section>

    <section class="px-6 pb-10 md:pb-14">
      <div class="site-shell">
        <div class="mx-auto max-w-4xl">
          <div class="surface-panel px-6 py-8 md:px-10 md:py-10">
            <p class="section-kicker mb-4">Why Now</p>
            <p class="text-base leading-8 text-argmin-dark md:text-lg">
              Enterprise AI spend is scaling faster than the systems designed to govern it. Cloud billing tools see accounts, not applications. Observability platforms see traces, not owners. FinOps frameworks were built for static infrastructure, not model calls that vary 700x in cost. The gap between AI adoption and AI accountability is widening every quarter—and incumbents are not closing it because their architectures were never designed to.
            </p>
            <div class="mt-6 grid gap-4 md:grid-cols-3">
              <div class="rounded-lg border border-argmin-border px-4 py-3">
                <p class="text-sm font-semibold text-argmin-dark">Distributed systems</p>
                <p class="mt-1 text-sm leading-6 text-argmin-mid">We built and operated the infrastructure that creates this problem at enterprise scale.</p>
              </div>
              <div class="rounded-lg border border-argmin-border px-4 py-3">
                <p class="text-sm font-semibold text-argmin-dark">Security-first architecture</p>
                <p class="mt-1 text-sm leading-6 text-argmin-mid">Read-only connectors, inside-environment deployment, and trust boundary design from day one.</p>
              </div>
              <div class="rounded-lg border border-argmin-border px-4 py-3">
                <p class="text-sm font-semibold text-argmin-dark">AI-native approach</p>
                <p class="mt-1 text-sm leading-6 text-argmin-mid">Graph-based attribution built specifically for AI workloads—not retrofitted onto cloud cost tools.</p>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <Footer />
  </main>
</BaseLayout>
