---
import BaseLayout from "../layouts/BaseLayout.astro";
import Footer from "../components/Footer.astro";
import PageHero from "../components/PageHero.astro";

const founders = [
  {
    name: "Richard McKinney",
    title: "CEO & Co-Founder",
    alt: "Richard McKinney, CEO & Co-Founder",
    webp: "/richard.webp",
    jpg: "/richard.jpg",
    bio: "Richard spent a decade building enterprise data and cost infrastructure at Amazon, Salesforce, and Cruise. He saw firsthand that attribution and accountable control need an identity-resolved, graph-based approach embedded in the deployment path.",
    bioExtended:
      "At Amazon, his work delivered $357M in annual infrastructure savings on top of global data platforms used across large engineering organizations. That track record shaped Argmin's focus on making ownership operational rather than retrospective, so decisions happen where the work does.",
    linkedin: "https://www.linkedin.com/in/richardcmckinney",
  },
  {
    name: "Charlotte Wargniez",
    title: "CTO & Co-Founder",
    alt: "Charlotte Wargniez, CTO & Co-Founder",
    webp: "/charlotte.webp",
    jpg: "/charlotte.jpg",
    bio: "Charlotte brings deep expertise in systems research from Oxford and the European Space Agency. She designed Argmin's reconciliation and attribution architecture to operate inside customer trust boundaries with read-only deployment.",
    bioExtended:
      "Her deep reinforcement learning background powers the confidence-scored reconciliation engine behind Argmin, built from the start for customer environments where governance constraints are real and the answer has to be defensible, not just plausible.",
    linkedin: "https://www.linkedin.com/in/charlotte-wargniez",
  },
];
---

<BaseLayout
  title="Team | Argmin"
  description="Meet the team building decision control, attribution, and accountable governance for enterprise environments."
  canonicalUrl="https://argmin.co/team"
  showMobileThemeToggle={false}
>
  <main id="main-content">
    <PageHero
      eyebrow="Team"
      title="Built by operators, not observers."
      lede="We have worked inside the infrastructure that creates this problem: cloud-scale cost ownership, security governance, and production AI deployment. Argmin exists because we saw the gap from inside the systems that create it."
    />

    <section class="px-6 pb-12 md:pb-20">
      <div class="site-shell">
        <div class="mx-auto mb-10 max-w-4xl text-center">
          <p class="section-kicker">Founders</p>
        </div>

        <div class="mx-auto grid max-w-6xl gap-8 md:grid-cols-2">
          {founders.map((founder) => (
            <article class="surface-panel overflow-hidden px-6 pb-10 pt-8 md:px-8">
              <div class="flex items-start gap-6">
                <a
                  href={founder.linkedin}
                  target="_blank"
                  rel="noopener noreferrer"
                  aria-label={`View ${founder.name} on LinkedIn`}
                  class="group shrink-0 transition-transform duration-200 hover:scale-[1.02]"
                >
                  <picture>
                    <source srcset={founder.webp} type="image/webp" />
                    <img
                      src={founder.jpg}
                      alt={founder.alt}
                      class="h-[120px] w-[120px] rounded-2xl object-cover shadow-[0_12px_30px_rgba(0,0,0,0.2)] grayscale transition-all duration-300 group-hover:grayscale-0 group-hover:shadow-[0_16px_40px_rgba(0,0,0,0.25)]"
                      width="120"
                      height="120"
                      loading="lazy"
                    />
                  </picture>
                </a>
                <div class="pt-1">
                  <div class="flex items-center gap-2">
                    <h2 class="text-xl font-bold text-argmin-dark">{founder.name}</h2>
                    <a
                      href={founder.linkedin}
                      target="_blank"
                      rel="noopener noreferrer"
                      aria-label={`View ${founder.name} on LinkedIn`}
                      class="text-argmin-light transition-colors duration-200 hover:text-argmin-dark"
                    >
                      <svg viewBox="0 0 24 24" class="h-4 w-4 fill-current" aria-hidden="true">
                        <path d="M4.98 3.5A2.49 2.49 0 1 1 5 8.48a2.49 2.49 0 0 1-.02-4.98ZM3 9h4v12H3Zm7 0h3.83v1.64h.05c.53-1 1.84-2.05 3.79-2.05 4.05 0 4.8 2.67 4.8 6.14V21h-4v-5.54c0-1.32-.02-3.02-1.84-3.02-1.85 0-2.13 1.44-2.13 2.93V21h-4Z" />
                      </svg>
                    </a>
                  </div>
                  <p class="mt-1.5 text-base font-semibold text-argmin-accent">{founder.title}</p>
                </div>
              </div>

              <p class="mt-6 text-base leading-8 text-argmin-mid">{founder.bio}</p>
              <p class="mt-5 text-base leading-8 text-argmin-mid">{founder.bioExtended}</p>
            </article>
          ))}
        </div>
      </div>
    </section>

    <Footer />
  </main>
</BaseLayout>
