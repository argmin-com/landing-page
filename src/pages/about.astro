---
import BaseLayout from "../layouts/BaseLayout.astro";
import Footer from "../components/Footer.astro";
import PageHero from "../components/PageHero.astro";

const beliefs = [
  {
    title: "Intervene before the invoice",
    description:
      "The product is designed for release review, approval flows, and budget decisions, not only post hoc reporting.",
  },
  {
    title: "Work with imperfect enterprise data",
    description:
      "Identity, billing, code, and telemetry rarely line up cleanly. The system has to expose confidence, not fake certainty.",
  },
];
---

<BaseLayout
  title="About | Argmin"
  description="Argmin is built by operators focused on AI spend attribution, governance, and decision-time control."
  canonicalUrl="https://argmin.co/about"
  showMobileThemeToggle={false}
>
  <main id="main-content">
    <PageHero
      eyebrow="About"
      title="Built from the systems where attribution actually breaks."
      lede="Argmin comes from enterprise environments where cloud cost ownership, approval controls, and operational accountability were already hard before AI inference spend accelerated them."
      notes={[
        { label: "Point of view", value: "AI cost governance should happen in the request path, not after close." },
        { label: "Constraint", value: "The product has to fit customer environments without broadening risk." },
        { label: "Today", value: "Working with a limited number of design partners on attribution and intervention." },
      ]}
      actions={[
        { href: "/contact", label: "Request a Demo" },
        { href: "/contact", label: "Contact Us", variant: "secondary" },
      ]}
    />

    <section class="px-6 py-10 md:py-14">
      <div class="site-shell section-divider pt-10">
        <div class="mx-auto max-w-3xl">
          <p class="section-kicker">What We Believe</p>
          <h2 class="section-title mt-5">The spend problem is not reporting. It is accountable control.</h2>
        </div>

        <div class="mx-auto mt-10 grid max-w-4xl gap-5 md:grid-cols-2">
          {beliefs.map((belief) => (
            <article class="surface-panel px-6 py-6">
              <p class="text-xl font-semibold tracking-[-0.03em] text-argmin-dark">{belief.title}</p>
              <p class="mt-3 text-base leading-7 text-argmin-mid">{belief.description}</p>
            </article>
          ))}
        </div>

        <p class="mx-auto mt-10 max-w-3xl text-center text-base leading-8 text-argmin-mid md:text-lg">
          We are working with a limited number of design partners.
        </p>

        <div class="mx-auto mt-8 flex max-w-3xl flex-wrap justify-center gap-3">
          <a href="/contact" class="button-primary">Request a Demo</a>
          <a href="/contact" class="button-secondary">Contact Us</a>
        </div>
      </div>
    </section>

    <Footer />
  </main>
</BaseLayout>
