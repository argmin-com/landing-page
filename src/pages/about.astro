---
import BaseLayout from "../layouts/BaseLayout.astro";
import Footer from "../components/Footer.astro";
import PageHero from "../components/PageHero.astro";

const beliefs = [
  {
    title: "Traceability over totals",
    description:
      "Cloud bills show the amount. Argmin shows the service, owner, budget, and decision path behind the spend.",
  },
  {
    title: "Intervene before the invoice",
    description:
      "The product is designed for release review, approval flows, and budget decisions, not only post hoc reporting.",
  },
  {
    title: "Work with imperfect enterprise data",
    description:
      "Identity, billing, code, and telemetry rarely line up cleanly. The system has to expose confidence, not fake certainty.",
  },
];

const designPartnerSignals = [
  "AI spend is growing faster than ownership can keep up.",
  "Telemetry exists, but no one can explain who changed the unit economics.",
  "Security, engineering, and finance each see only part of the same event.",
];
---

<BaseLayout
  title="About Argmin — AI Cost Attribution Built by Operators"
  description="Argmin builds AI cost attribution and governance tools. Founded by operators from Amazon and ESA who saw spend accountability break at scale."
  canonicalUrl="https://argmin.co/about"
  showMobileThemeToggle={false}
>
  <main id="main-content">
    <PageHero
      eyebrow="About"
      title="Built from the systems where attribution actually breaks."
      lede="Argmin comes from enterprise environments where cloud cost ownership, approval controls, and operational accountability were already hard before AI workloads accelerated them."
      notes={[
        { label: "Point of view", value: "Governance and attribution should happen in the decision path, not after the invoice." },
        { label: "Constraint", value: "The product has to fit customer environments without broadening risk." },
        { label: "Today", value: "Working with a limited number of design partners on attribution, governance, and intervention." },
      ]}
      actions={[
        { href: "/contact", label: "Request a Demo" },
        { href: "/team", label: "Meet the team", variant: "secondary" },
      ]}
    />

    <section class="px-6">
      <div class="site-shell section-divider pt-10">
        <div class="mx-auto max-w-3xl rise-in">
          <p class="section-kicker">What We Believe</p>
          <h2 class="section-title mt-5">The spend problem is not reporting. It is accountable control.</h2>
        </div>

        <div class="mx-auto mt-10 grid max-w-5xl gap-5 md:grid-cols-3">
          {beliefs.map((belief) => (
            <article class="surface-panel px-6 py-6 transition-transform duration-200 hover:translate-y-[-2px]">
              <p class="text-xl font-semibold tracking-[-0.03em] text-argmin-dark">{belief.title}</p>
              <p class="mt-3 text-base leading-7 text-argmin-mid">{belief.description}</p>
            </article>
          ))}
        </div>
      </div>
    </section>

    <section class="px-6 bg-argmin-surface-alt/30">
      <div class="site-shell section-divider pt-10">
        <div class="mx-auto max-w-3xl rise-in">
          <p class="section-kicker">Design Partners</p>
          <h2 class="section-title mt-5">The best conversations start with one painful workload.</h2>
        </div>

        <div class="mx-auto mt-8 grid max-w-4xl gap-4 md:grid-cols-3">
          {designPartnerSignals.map((signal) => (
            <div class="surface-panel px-5 py-4 text-base leading-7 text-argmin-mid transition-transform duration-200 hover:translate-y-[-2px]">
              {signal}
            </div>
          ))}
        </div>

        <div class="mx-auto mt-10 max-w-3xl text-center rise-in">
          <p class="text-base leading-8 text-argmin-mid md:text-lg">
            Bring the route change, approval bottleneck, or spend spike already bothering someone.
            That is usually enough to show where ownership breaks down, what evidence is missing, and how much waste is accumulating.
          </p>
          <div class="mt-8 flex flex-wrap justify-center gap-3">
            <a href="/contact" class="button-primary">Request a Demo</a>
            <a href="/contact" class="button-secondary">Contact Us</a>
          </div>
        </div>
      </div>
    </section>

    <Footer />
  </main>
</BaseLayout>
