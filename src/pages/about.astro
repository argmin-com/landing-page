---
import BaseLayout from "../layouts/BaseLayout.astro";
import Footer from "../components/Footer.astro";
import PageHero from "../components/PageHero.astro";

const beliefs = [
  {
    title: "Traceability over totals",
    description:
      "Cloud bills show the amount. Argmin shows the service, owner, budget, and decision path behind the spend.",
  },
  {
    title: "Intervene before the invoice",
    description:
      "The product is designed for release review, approval flows, and budget decisions, not only post hoc reporting.",
  },
  {
    title: "Work with imperfect enterprise data",
    description:
      "Identity, billing, code, and telemetry rarely line up cleanly. The system has to expose confidence, not fake certainty.",
  },
  {
    title: "Respect the trust boundary",
    description:
      "Read-only connectors and inside-environment deployment are table stakes when governance is the real job.",
  },
];

const designPartnerSignals = [
  "AI spend is growing faster than ownership can keep up.",
  "Telemetry exists, but no one can explain who changed the unit economics.",
  "Security, engineering, and finance each see only part of the same event.",
];
---

<BaseLayout
  title="About | Argmin"
  description="Argmin is built by operators focused on AI spend attribution, governance, and decision-time control."
  canonicalUrl="https://argmin.co/about"
  showMobileThemeToggle={false}
>
  <main id="main-content">
    <PageHero
      eyebrow="About"
      title="Built from the systems where attribution actually breaks."
      lede="Argmin comes from enterprise environments where cloud cost ownership, approval controls, and operational accountability were already hard before AI inference spend accelerated them."
      notes={[
        { label: "Point of view", value: "AI cost governance should happen in the request path, not after close." },
        { label: "Constraint", value: "The product has to fit customer environments without broadening risk." },
        { label: "Today", value: "Working with a limited number of design partners on attribution and intervention." },
      ]}
      actions={[
        { href: "/team", label: "Meet the team" },
        { href: "/demo", label: "Request a demo", variant: "secondary" },
      ]}
    />

    <section class="px-6 py-8 md:py-12">
      <div class="site-shell section-divider pt-10">
        <div class="grid gap-10 lg:grid-cols-[minmax(0,0.62fr)_minmax(0,1.38fr)] lg:gap-16">
          <div>
            <p class="section-kicker">What We Believe</p>
            <h2 class="display-title mt-5 max-w-4xl text-[2.4rem] md:text-[3.4rem]">
              The spend problem is not reporting. It is accountable control.
            </h2>
          </div>

          <div class="grid gap-4 md:grid-cols-2">
            {beliefs.map((belief) => (
              <article class="surface-panel px-5 py-6 md:px-6">
                <p class="text-2xl font-semibold tracking-[-0.04em] text-argmin-dark">{belief.title}</p>
                <p class="mt-4 text-base leading-8 text-argmin-mid">{belief.description}</p>
              </article>
            ))}
          </div>
        </div>
      </div>
    </section>

    <section class="px-6 py-8 md:py-12">
      <div class="site-shell section-divider pt-10">
        <div class="grid gap-10 lg:grid-cols-[minmax(0,0.6fr)_minmax(0,1.4fr)] lg:gap-16">
          <div>
            <p class="section-kicker">Design Partners</p>
            <h2 class="display-title mt-5 max-w-4xl text-[2.4rem] md:text-[3.4rem]">
              The best conversations start with one painful workload.
            </h2>
          </div>

          <div class="grid gap-4 md:grid-cols-3">
            {designPartnerSignals.map((item) => (
              <article class="surface-panel px-5 py-5 text-base leading-8 text-argmin-mid">{item}</article>
            ))}
          </div>
        </div>
      </div>
    </section>

    <section class="px-6 pb-10 pt-8 md:pb-14">
      <div class="site-shell section-divider pt-10">
        <div class="grid gap-8 lg:grid-cols-[minmax(0,0.72fr)_minmax(0,0.28fr)] lg:items-end">
          <div>
            <p class="section-kicker">Next Step</p>
            <h2 class="display-title mt-5 max-w-4xl text-[2.4rem] md:text-[3.4rem]">
              Bring the route change, approval bottleneck, or spend spike already bothering someone.
            </h2>
            <p class="mt-5 max-w-3xl text-base leading-8 text-argmin-mid md:text-lg">
              That is usually enough to show where ownership breaks down, what evidence is missing, and how much waste is accumulating.
            </p>
          </div>
          <div class="flex flex-col gap-3">
            <a href="/demo" class="button-primary">Request a Demo</a>
            <a href="/contact" class="button-secondary">Talk to us</a>
          </div>
        </div>
      </div>
    </section>

    <Footer />
  </main>
</BaseLayout>
