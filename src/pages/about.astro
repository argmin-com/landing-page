---
import BaseLayout from "../layouts/BaseLayout.astro";
import Footer from "../components/Footer.astro";
import Founders from "../components/Founders.astro";
import PageHero from "../components/PageHero.astro";

const beliefs = [
  {
    title: "From totals to traceability",
    description:
       "Cloud bills show totals. We show which team called which model, from which service, for what purpose, and at what cost.",
  },
  {
    title: "Decision-time intervention",
    description:
      "We act at the moment of inference: routing to cheaper equivalent models, enforcing budgets, flagging waste before money is spent.",
  },
  {
    title: "Built for imperfect data",
    description:
      "Enterprise data is fragmented and inconsistent. The attribution layer should surface confidence instead of pretending the graph is clean.",
  },
  {
    title: "Inside the customer trust boundary",
    description:
      "Read-only connectors and fail-open design matter because the product has to fit the environments where AI spend governance actually matters.",
  },
];

const whyNow = [
  "The same AI model can cost up to 700x more depending on how it is used.",
  "Enterprise AI programs are already running past $85K per month before ownership is clear.",
  "Finance, engineering, and security often see different fragments of the same cost event and none of them can act in time.",
];
---

<BaseLayout title="About | Argmin" canonicalUrl="https://argmin.co/about">
  <main id="main-content">
    <PageHero
      eyebrow="About"
      title="Built by operators who have already carried infrastructure risk."
      lede="The product point of view comes from environments where trust boundaries, cost ownership, and operational accountability were not optional: Amazon, Cruise, Salesforce, Oxford, and the European Space Agency."
      notes={[
        { label: "Today", value: "Working with a limited number of design partners on enterprise AI spend visibility and intervention." },
        { label: "Point of view", value: "AI cost governance should happen at the request path, not after the invoice lands." },
        { label: "Constraint", value: "The system has to fit real customer environments without broadening operational risk." },
      ]}
      actions={[
        { href: "/team", label: "Meet the team" },
        { href: "/contact", label: "Talk to us", variant: "secondary" },
      ]}
    />

    <section class="px-6 py-8 md:py-12">
      <div class="site-shell section-divider pt-10">
        <div class="grid gap-10 lg:grid-cols-[minmax(0,0.62fr)_minmax(0,1.38fr)] lg:gap-16">
          <div class="rise-in">
            <p class="section-kicker">Why Now</p>
            <h2 class="display-title mt-5 max-w-3xl text-[2.4rem] md:text-[3.4rem]">
              The spend problem shows up before the ownership graph does.
            </h2>
          </div>

          <div class="grid gap-4 rise-in rise-in-delay-1 md:grid-cols-3">
            {whyNow.map((item) => (
              <article class="surface-panel px-5 py-5 text-base leading-8 text-argmin-mid">{item}</article>
            ))}
          </div>
        </div>
      </div>
    </section>

    <section class="px-6 py-8 md:py-12">
      <div class="site-shell section-divider pt-10">
        <div class="max-w-3xl rise-in">
          <p class="section-kicker">Beliefs</p>
          <h2 class="display-title mt-5 max-w-4xl text-[2.4rem] md:text-[3.4rem]">What shapes the product.</h2>
        </div>

        <div class="mt-10 grid gap-4 md:grid-cols-2">
          {beliefs.map((belief) => (
            <article class="surface-panel px-5 py-6 md:px-6">
              <p class="text-2xl font-semibold tracking-[-0.04em] text-argmin-dark">{belief.title}</p>
              <p class="mt-4 text-base leading-8 text-argmin-mid">{belief.description}</p>
            </article>
          ))}
        </div>
      </div>
    </section>

    <section class="px-6 py-8 md:py-12">
      <div class="site-shell section-divider pt-10">
        <Founders
          title="Founders"
          intro="Charlotte Wargniez and Richard McKinney built Argmin from the overlap of enterprise infrastructure, applied AI, and the operational reality of governing complex systems."
        />
      </div>
    </section>

    <section class="px-6 pb-10 pt-8 md:pb-14">
      <div class="site-shell section-divider pt-10">
        <div class="grid gap-8 lg:grid-cols-[minmax(0,0.72fr)_minmax(0,0.28fr)] lg:items-end">
          <div>
            <p class="section-kicker">Design Partners</p>
            <h2 class="display-title mt-5 max-w-4xl text-[2.4rem] md:text-[3.4rem]">
              Bring the release, route, or budget problem that is already bothering someone.
            </h2>
            <p class="mt-5 max-w-3xl text-base leading-8 text-argmin-mid md:text-lg">
              The best conversations start with a concrete spend spike, approval bottleneck, or routing choice
              that is currently expensive but still not accountable.
            </p>
          </div>
          <div class="flex flex-col gap-3">
            <a href="/demo" class="button-primary">Request a Demo</a>
            <a href="/use-cases" class="button-secondary">See use cases</a>
          </div>
        </div>
      </div>
    </section>

    <Footer />
  </main>
</BaseLayout>
