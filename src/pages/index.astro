---
import AttributionFlowDiagram from "../components/AttributionFlowDiagram.astro";
import Contact from "../components/Contact.astro";
import DecisionRule from "../components/DecisionRule.astro";
import Footer from "../components/Footer.astro";
import Founders from "../components/Founders.astro";
import Hero from "../components/Hero.astro";
import HowItWorks from "../components/HowItWorks.astro";
import Problem from "../components/Problem.astro";
import ValueProps from "../components/ValueProps.astro";
import BaseLayout from "../layouts/BaseLayout.astro";

const formspreeUrl =
  import.meta.env.PUBLIC_FORMSPREE_URL ?? "https://formspree.io/f/mlgornql";
---

<BaseLayout showNavbarImmediately={false}>
  <main>
    <Hero revealContent={false} />
    <div class="initial-hidden">
      <Problem />
      <DecisionRule />
      <ValueProps />
      <HowItWorks />
      <section class="px-6 py-10 md:py-14">
        <div class="mx-auto flex w-full max-w-6xl flex-col items-center justify-center text-center">
          <AttributionFlowDiagram />
          <a
            href="/demo"
            onclick="window.plausible && window.plausible('cta_click')"
            class="mt-10 inline-flex items-center justify-center rounded-lg bg-argmin-accent px-8 py-4 text-lg font-semibold text-argmin-dark transition-colors duration-200 hover:bg-argmin-accent-hover focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-argmin-accent"
          >
            Request a Demo
          </a>
        </div>
      </section>
      <Founders imagesOnly={true} />
      <Contact formspreeUrl={formspreeUrl} />
    </div>
    <Footer />
  </main>
</BaseLayout>

<script is:inline>
  if (!document.body.classList.contains("revealed")) {
    const reveal = () => {
      document.body.classList.add("revealed");
      window.removeEventListener("scroll", reveal);
      window.removeEventListener("touchstart", reveal);
      window.removeEventListener("keydown", reveal);
      window.removeEventListener("hashchange", reveal);
    };

    if (window.location.hash) {
      reveal();
    }

    window.addEventListener("scroll", reveal, { passive: true, once: true });
    window.addEventListener("touchstart", reveal, { passive: true, once: true });
    window.addEventListener("keydown", reveal, { once: true });
    window.addEventListener("hashchange", reveal, { once: true });
  }
</script>
