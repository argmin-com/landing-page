---
import AttributionFlowDiagram from "../components/AttributionFlowDiagram.astro";
import Contact from "../components/Contact.astro";
import Footer from "../components/Footer.astro";
import Founders from "../components/Founders.astro";
import Hero from "../components/Hero.astro";
import HowItWorks from "../components/HowItWorks.astro";
import Problem from "../components/Problem.astro";
import SubHeroBreak from "../components/SubHeroBreak.astro";
import ValueProps from "../components/ValueProps.astro";
import BaseLayout from "../layouts/BaseLayout.astro";
import { sanitizeFormspreeUrl } from "../lib/formspree";

const formspreeUrl = sanitizeFormspreeUrl(import.meta.env.PUBLIC_FORMSPREE_URL);
---

<BaseLayout showNavbarImmediately={false}>
  <main id="main-content">
    <Hero fillViewport={true} />
    <div>
      <Problem />
      <ValueProps />
      <SubHeroBreak />
      <HowItWorks />
      <section class="px-6 py-10 md:py-14">
        <div class="mx-auto flex w-full max-w-6xl flex-col items-center justify-center text-center">
          <AttributionFlowDiagram />
          <a
            href="/demo"
            onclick="window.plausible && window.plausible('cta_click')"
            class="mt-10 inline-flex items-center justify-center rounded-lg bg-argmin-accent px-8 py-4 text-lg font-semibold text-argmin-accent-ink transition-colors duration-200 hover:bg-argmin-accent-hover focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-argmin-accent"
          >
            Request a Demo
          </a>
        </div>
      </section>
      <Founders imagesOnly={true} />
      <Contact formspreeUrl={formspreeUrl} />
    </div>
    <Footer />
  </main>
</BaseLayout>
