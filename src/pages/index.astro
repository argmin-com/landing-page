---
import AttributionFlowDiagram from "../components/AttributionFlowDiagram.astro";
import Contact from "../components/Contact.astro";
import Footer from "../components/Footer.astro";
import Founders from "../components/Founders.astro";
import Hero from "../components/Hero.astro";
import HowItWorks from "../components/HowItWorks.astro";
import Problem from "../components/Problem.astro";
import SubHeroBreak from "../components/SubHeroBreak.astro";
import ValueProps from "../components/ValueProps.astro";
import BaseLayout from "../layouts/BaseLayout.astro";
import { sanitizeFormspreeUrl } from "../lib/formspree";

const formspreeUrl = sanitizeFormspreeUrl(import.meta.env.PUBLIC_FORMSPREE_URL);
---

<BaseLayout showNavbarImmediately={false} homeHeroOnlyInitially={true}>
  <main id="main-content">
    <Hero fillViewport={true} revealContent={false} />
    <div data-home-stage="2">
      <div data-home-stage-content>
        <Problem />
        <ValueProps />
        <SubHeroBreak />
        <HowItWorks />
        <section class="px-6 py-10 md:py-14">
          <div class="mx-auto flex w-full max-w-6xl flex-col items-center justify-center text-center">
            <AttributionFlowDiagram />
            <a
              href="/demo"
              onclick="window.plausible && window.plausible('cta_click')"
              class="mt-10 inline-flex items-center justify-center rounded-lg bg-argmin-accent px-8 py-4 text-lg font-semibold text-argmin-accent-ink transition-colors duration-200 hover:bg-argmin-accent-hover focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-argmin-accent"
            >
              Request a Demo
            </a>
          </div>
        </section>
        <Founders imagesOnly={true} />
        <Contact formspreeUrl={formspreeUrl} />
        <Footer />
      </div>
    </div>
  </main>
  <script is:inline>
    (() => {
      const stageKey = "homeRevealStage";
      const stageChangeEvent = "argmin-home-reveal-stage-change";
      const finalStage = 2;
      const idleRevealDelay = 5000;
      const advanceOffset = Math.max(window.innerHeight * 0.14, 96);
      const stageConfigs = [
        { wheel: 3.5, touch: 8 },
        { wheel: 3.5, touch: 8 },
      ];
      const prefersReducedMotion = window.matchMedia("(prefers-reduced-motion: reduce)").matches;
      let stage = Number(document.body?.dataset[stageKey] ?? Number.NaN);
      let idleRevealTimeoutId = 0;
      let wheelNeedsRelease = false;
      let wheelReleaseFrameId = 0;
      let touchStartY = null;
      let touchNeedsRelease = false;

      const body = document.body;

      if (!(body instanceof HTMLElement) || stage !== 0) {
        return;
      }

      const wheelOptions = { passive: true };
      const touchOptions = { passive: true };

      const cleanup = () => {
        window.removeEventListener("wheel", onWheel, wheelOptions);
        window.removeEventListener("keydown", onKeyDown);
        window.removeEventListener("scroll", onScroll);
        window.removeEventListener("touchstart", onTouchStart, touchOptions);
        window.removeEventListener("touchmove", onTouchMove, touchOptions);
        window.removeEventListener("touchend", onTouchEnd, touchOptions);
        if (idleRevealTimeoutId) {
          window.clearTimeout(idleRevealTimeoutId);
        }
        if (wheelReleaseFrameId) {
          window.cancelAnimationFrame(wheelReleaseFrameId);
        }
      };

      const cancelIdleReveal = () => {
        if (!idleRevealTimeoutId) {
          return;
        }

        window.clearTimeout(idleRevealTimeoutId);
        idleRevealTimeoutId = 0;
      };

      const setStage = (nextStage, advanceIntoContent) => {
        cancelIdleReveal();
        body.dataset[stageKey] = String(nextStage);
        stage = nextStage;
        window.dispatchEvent(
          new CustomEvent(stageChangeEvent, {
            detail: { stage: nextStage },
          }),
        );

        if (nextStage < finalStage) {
          return;
        }

        cleanup();

        if (!advanceIntoContent || window.scrollY > 0) {
          return;
        }

        window.requestAnimationFrame(() => {
          window.requestAnimationFrame(() => {
            window.scrollBy({
              top: advanceOffset,
              behavior: prefersReducedMotion ? "auto" : "smooth",
            });
          });
        });
      };

      const advanceStage = (advanceIntoContent) => {
        if (stage >= finalStage) {
          return;
        }

        setStage(stage + 1, advanceIntoContent);
      };

      const getThreshold = (kind) => stageConfigs[Math.min(stage, stageConfigs.length - 1)][kind];

      const scheduleWheelRelease = () => {
        if (wheelReleaseFrameId) {
          window.cancelAnimationFrame(wheelReleaseFrameId);
        }

        wheelReleaseFrameId = window.requestAnimationFrame(() => {
          wheelReleaseFrameId = window.requestAnimationFrame(() => {
            wheelReleaseFrameId = 0;
            wheelNeedsRelease = false;
          });
        });
      };

      const onWheel = (event) => {
        cancelIdleReveal();
        scheduleWheelRelease();

        if (wheelNeedsRelease) {
          return;
        }

        if (event.deltaY > getThreshold("wheel")) {
          wheelNeedsRelease = true;
          advanceStage(true);
        }
      };

      const onKeyDown = (event) => {
        if (event.defaultPrevented) {
          return;
        }

        if (["ArrowDown", "PageDown", " ", "Spacebar"].includes(event.key)) {
          cancelIdleReveal();
          advanceStage(true);
        }
      };

      const onScroll = () => {
        if (window.scrollY > 0) {
          cancelIdleReveal();
          setStage(finalStage, false);
        }
      };

      const onTouchStart = (event) => {
        cancelIdleReveal();
        if (touchNeedsRelease) {
          return;
        }

        touchStartY = event.touches[0]?.clientY ?? null;
      };

      const onTouchMove = (event) => {
        const currentY = event.touches[0]?.clientY;

        if (touchStartY === null || typeof currentY !== "number") {
          return;
        }

        if (touchStartY - currentY > getThreshold("touch")) {
          touchNeedsRelease = true;
          advanceStage(true);
        }
      };

      const onTouchEnd = () => {
        touchStartY = null;
        touchNeedsRelease = false;
      };

      if (window.scrollY > 0) {
        setStage(finalStage, false);
        return;
      }

      window.addEventListener("wheel", onWheel, wheelOptions);
      window.addEventListener("keydown", onKeyDown);
      window.addEventListener("scroll", onScroll, { passive: true });
      window.addEventListener("touchstart", onTouchStart, touchOptions);
      window.addEventListener("touchmove", onTouchMove, touchOptions);
      window.addEventListener("touchend", onTouchEnd, touchOptions);
      idleRevealTimeoutId = window.setTimeout(() => {
        if (stage === 0 && window.scrollY === 0) {
          setStage(finalStage, false);
        }
      }, idleRevealDelay);
    })();
  </script>
</BaseLayout>
