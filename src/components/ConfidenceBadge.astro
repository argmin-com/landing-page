---
interface Props {
  value: string;
  tone?: "high" | "medium" | "low";
}

const { value, tone = "medium" } = Astro.props;

const toneClass = {
  high: "border-argmin-success/20 bg-argmin-success-light text-argmin-success",
  medium: "border-argmin-warning/20 bg-argmin-warning-light text-argmin-warning",
  low: "border-argmin-error/20 bg-argmin-error-light text-argmin-error",
}[tone];
---

<span
  class:list={[
    "inline-flex items-center justify-center rounded-full border px-3 py-1 font-mono text-[0.72rem] font-medium tracking-[0.02em]",
    toneClass,
  ]}
>
  Confidence {value}
</span>
