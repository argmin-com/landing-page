---
import { siteConfig } from "../content/site";

const { deployment } = siteConfig;
---

<section id="deployment" class="border-b border-argmin-slate-300/70 bg-white px-6 py-16 md:py-24">
  <div class="section-shell grid gap-12 lg:grid-cols-[minmax(0,0.72fr)_minmax(0,1.28fr)] lg:gap-16">
    <div class="max-w-xl">
      <p class="section-eyebrow">Deployment</p>
      <h2 class="section-title max-w-none">{deployment.title}</h2>
      <p class="section-copy">{deployment.intro}</p>

      <ul class="mt-8 space-y-3">
        {deployment.notes.map((note) => (
          <li class="grid grid-cols-[18px_minmax(0,1fr)] gap-3">
            <span class="mt-2 h-2.5 w-2.5 rounded-full bg-argmin-sky"></span>
            <p class="text-sm leading-7 text-argmin-slate-700 md:text-base">{note}</p>
          </li>
        ))}
      </ul>
    </div>

    <div class="rounded-[1.75rem] border border-argmin-slate-300/80 bg-argmin-slate-100/55 p-6 md:p-8">
      {deployment.phases.map((phase, index) => (
        <article
          class:list={[
            "grid gap-4 py-5 md:grid-cols-[100px_minmax(0,1fr)] md:gap-8",
            index > 0 && "border-t border-argmin-slate-300/80",
          ]}
        >
          <p class="data-label text-argmin-azure">{phase.label}</p>
          <div>
            <h3 class="font-display text-[1.28rem] font-semibold tracking-[-0.03em] text-argmin-navy md:text-[1.52rem]">
              {phase.title}
            </h3>
            <p class="mt-3 max-w-[52ch] text-base leading-7 text-argmin-slate-700">
              {phase.description}
            </p>
          </div>
        </article>
      ))}
    </div>
  </div>
</section>
