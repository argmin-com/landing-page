---
interface Props {
  revealContent?: boolean;
  fillViewport?: boolean;
}

const { revealContent = true, fillViewport = false } = Astro.props;
---

<section
  data-home-hero
  class:list={[
    "flex items-center",
    fillViewport ? "min-h-[100svh]" : "min-h-[calc(100svh-6.75rem)] md:min-h-[calc(100svh-8.5rem)]",
  ]}
>
  <div class="mx-auto flex w-full max-w-6xl flex-col items-start justify-center px-6 pb-0 pt-10 text-left md:pt-14">
    <h1
      class="hero-headline hero-title-intro max-w-5xl text-5xl font-semibold leading-[0.92] tracking-[-0.06em] text-argmin-dark md:text-6xl lg:text-7xl xl:text-[5.5rem]"
    >
      <span class="hero-headline-dark block">Argmin</span>
    </h1>
    <p
      data-home-stage={revealContent ? undefined : "1"}
      class="hero-headline mt-6 max-w-4xl text-3xl font-semibold leading-[1.02] tracking-[-0.05em] text-argmin-dark md:text-5xl lg:text-6xl"
    >
      The attribution layer for enterprise AI.
    </p>
  </div>
</section>

<style>
  .hero-headline {
    font-family:
      "SF Pro Display",
      "Inter",
      "Inter Tight",
      "Helvetica Neue",
      "Segoe UI",
      sans-serif;
    font-weight: 650;
    text-rendering: optimizeLegibility;
    font-feature-settings: "rlig" 1, "ss01" 1, "cv11" 1;
    text-wrap: balance;
  }

  .hero-headline-dark {
    color: rgb(var(--color-argmin-dark));
  }

  .hero-title-intro {
    animation: hero-title-intro 560ms cubic-bezier(0.22, 1, 0.36, 1) both;
  }

  @keyframes hero-title-intro {
    from {
      opacity: 0;
      transform: translateY(18px);
    }

    to {
      opacity: 1;
      transform: translateY(0);
    }
  }
</style>
