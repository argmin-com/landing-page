---
import { siteConfig } from "../content/site";

const { hero } = siteConfig;
---

<section class="hero-section overflow-hidden border-b border-white/10 bg-argmin-navy px-6 py-8">
  <div class="hero-backdrop" aria-hidden="true"></div>
  <div class="section-shell hero-grid lg:grid-cols-[minmax(0,1.02fr)_minmax(0,0.98fr)]">
    <div class="hero-copy-block">
      <p class="font-display text-[1.55rem] font-bold tracking-[-0.03em] text-white">{hero.wordmark}</p>
      <p class="mt-6 text-[0.72rem] font-semibold uppercase tracking-[0.18em] text-argmin-sky">
        {hero.eyebrow}
      </p>
      <h1 class="hero-title mt-4">{hero.headline}</h1>
      <p class="hero-copy">{hero.subheadline}</p>

      <div class="mt-8 flex flex-col gap-3 sm:flex-row">
        <a href="#contact" class="primary-button" data-cta-button>
          {hero.primaryCtaLabel}
        </a>
        <a href="#how" class="hero-secondary-link">
          See the attribution chain
        </a>
      </div>

      <dl class="hero-proof-list">
        {hero.proofPoints.map((item) => (
          <div class="hero-proof-item">
            <dt class="hero-proof-label">{item.label}</dt>
            <dd class="hero-proof-value">{item.value}</dd>
          </div>
        ))}
      </dl>
    </div>

    <div class="hidden lg:block" aria-hidden="true">
      <div class="hero-logic">
        <div class="hero-logic-column">
          <p class="hero-logic-label">Signals in</p>
          <ul class="hero-logic-list">
            {hero.signalInputs.map((item) => (
              <li>{item}</li>
            ))}
          </ul>
        </div>

        <div class="hero-logic-core">
          <p class="hero-logic-label">Argmin</p>
          <p class="hero-logic-title">Attribution graph</p>
          <p class="hero-logic-copy">
            Resolve each inference through service, code owner, identity, org unit, and budget
            with explicit confidence.
          </p>
        </div>

        <div class="hero-logic-column hero-logic-column--right">
          <p class="hero-logic-label">Decisions out</p>
          <ul class="hero-logic-list">
            {hero.signalOutputs.map((item) => (
              <li>{item}</li>
            ))}
          </ul>
        </div>
      </div>
    </div>
  </div>
</section>
