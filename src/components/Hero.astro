---
import { siteConfig } from "../content/site";

const { hero } = siteConfig;
---

<section class="relative overflow-hidden bg-argmin-navy">
  <div class="absolute inset-0 bg-[radial-gradient(circle_at_top_left,rgba(74,159,217,0.26),transparent_34%),linear-gradient(180deg,rgba(255,255,255,0.04),transparent_44%)]"></div>
  <div class="absolute inset-y-0 right-0 hidden w-[42%] bg-[linear-gradient(180deg,rgba(255,255,255,0.05),transparent_24%,transparent_78%,rgba(255,255,255,0.03))] lg:block"></div>

  <div class="section-shell relative grid min-h-[calc(100svh-73px)] items-center gap-10 px-6 py-8 md:py-10 lg:grid-cols-[minmax(0,1.18fr)_minmax(0,0.82fr)] lg:gap-8">
    <div class="relative z-10 max-w-[44rem]">
      <p class="font-display text-[1.55rem] font-bold tracking-[-0.02em] text-white sm:text-[1.8rem] js-reveal">
        {hero.wordmark}
      </p>
      <p class="mt-6 text-[0.6875rem] font-semibold uppercase tracking-[0.16em] text-argmin-sky js-reveal" data-reveal-delay="60">
        {hero.eyebrow}
      </p>
      <h1 class="mt-3 max-w-[11ch] font-display text-[clamp(2.55rem,4.9vw,4.45rem)] font-bold leading-[0.94] tracking-[-0.04em] text-white js-reveal" data-reveal-delay="120">
        {hero.headline}
      </h1>
      <p class="mt-4 max-w-[60ch] text-[1.02rem] leading-7 text-white/88 js-reveal" data-reveal-delay="180">
        {hero.subheadline}
      </p>

      <div class="mt-6 flex flex-col gap-3 sm:flex-row js-reveal" data-reveal-delay="240">
        <a href="#contact" class="primary-button text-base" data-plausible-event="cta_click">
          {hero.primaryCtaLabel}
        </a>
        <a href="#how" class="inverse-secondary-button text-base">
          {hero.secondaryCtaLabel}
        </a>
      </div>

      <dl class="mt-7 grid gap-4 border-t border-white/12 pt-5 sm:grid-cols-3 js-reveal" data-reveal-delay="300">
        {hero.proofPoints.map((item) => (
          <div class="border-l border-white/12 pl-4">
            <dt class="text-[0.6875rem] font-semibold uppercase tracking-[0.16em] text-white/62">
              {item.label}
            </dt>
            <dd class="mt-2 text-sm leading-6 text-white/88">{item.value}</dd>
          </div>
        ))}
      </dl>
    </div>

    <div class="relative hidden min-h-[420px] lg:block" aria-hidden="true">
      <div class="hero-logic absolute inset-y-4 inset-x-0 js-reveal" data-reveal-delay="210">
        <div class="hero-logic-column">
          <p class="hero-logic-label">Signals in</p>
          <ul class="hero-logic-list">
            {hero.signalInputs.map((item) => (
              <li>{item}</li>
            ))}
          </ul>
        </div>

        <div class="hero-logic-core">
          <p class="hero-logic-label">Argmin</p>
          <p class="hero-logic-title">Attribution graph</p>
          <p class="hero-logic-copy">
            Resolve every inference through service, code owner, identity, org unit, and budget with explicit confidence.
          </p>
        </div>

        <div class="hero-logic-column hero-logic-column--right">
          <p class="hero-logic-label">Decisions out</p>
          <ul class="hero-logic-list">
            {hero.signalOutputs.map((item) => (
              <li>{item}</li>
            ))}
          </ul>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .hero-logic {
    display: grid;
    grid-template-columns: minmax(0, 0.9fr) minmax(220px, 280px) minmax(0, 0.72fr);
    align-items: center;
    gap: 1rem;
  }

  .hero-logic::before,
  .hero-logic::after {
    content: "";
    position: absolute;
    top: 50%;
    height: 1px;
    background:
      linear-gradient(90deg, rgb(255 255 255 / 0.08), rgb(74 159 217 / 0.65), rgb(255 255 255 / 0.08));
    transform: translateY(-50%);
  }

  .hero-logic::before {
    left: 10%;
    right: 49%;
  }

  .hero-logic::after {
    left: 55%;
    right: 0;
  }

  .hero-logic-column {
    position: relative;
    display: grid;
    gap: 0.9rem;
  }

  .hero-logic-column--right {
    text-align: right;
  }

  .hero-logic-label {
    font-family: var(--font-body);
    font-size: 0.6875rem;
    font-weight: 600;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: rgb(255 255 255 / 0.58);
  }

  .hero-logic-list {
    display: grid;
    gap: 0.8rem;
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .hero-logic-list li {
    position: relative;
    font-size: 0.9rem;
    color: rgb(255 255 255 / 0.88);
  }

  .hero-logic-column:not(.hero-logic-column--right) .hero-logic-list li {
    padding-left: 1.45rem;
  }

  .hero-logic-column--right .hero-logic-list li {
    padding-right: 1.45rem;
  }

  .hero-logic-list li::before {
    content: "";
    position: absolute;
    top: 0.7rem;
    width: 0.5rem;
    height: 0.5rem;
    border-radius: 9999px;
    background: rgb(74 159 217 / 0.88);
    box-shadow: 0 0 0 6px rgb(74 159 217 / 0.12);
  }

  .hero-logic-column:not(.hero-logic-column--right) .hero-logic-list li::before {
    left: 0;
  }

  .hero-logic-column--right .hero-logic-list li::before {
    right: 0;
  }

  .hero-logic-core {
    position: relative;
    z-index: 1;
    border: 1px solid rgb(255 255 255 / 0.14);
    border-radius: 20px;
    background:
      linear-gradient(180deg, rgb(255 255 255 / 0.08), rgb(255 255 255 / 0.03));
    padding: 1.75rem 1.5rem;
    box-shadow: 0 30px 60px rgb(6 24 44 / 0.18);
    backdrop-filter: blur(12px);
  }

  .hero-logic-title {
    margin-top: 0.75rem;
    font-family: var(--font-display);
    font-size: 1.55rem;
    font-weight: 700;
    letter-spacing: -0.03em;
    color: white;
  }

  .hero-logic-copy {
    margin-top: 0.9rem;
    font-size: 0.9rem;
    line-height: 1.7;
    color: rgb(255 255 255 / 0.78);
  }
</style>
