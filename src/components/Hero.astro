---
interface Props {
  revealContent?: boolean;
}

const { revealContent = true } = Astro.props;
const revealClass = revealContent ? "" : "initial-hidden";
---

<section class="flex min-h-screen items-center">
  <div class="mx-auto flex w-full max-w-6xl -translate-y-6 flex-col items-start justify-center px-6 py-16 text-left md:-translate-y-8 md:py-20">
    <h1
      class="hero-headline max-w-5xl text-5xl font-semibold leading-[0.92] tracking-[-0.06em] text-argmin-dark md:text-6xl lg:text-7xl xl:text-[5.5rem]"
    >
      <span class="hero-headline-dark block">Argmin</span>
    </h1>
    <p
      class:list={[
        "hero-headline mt-6 max-w-4xl text-3xl font-semibold leading-[1.02] tracking-[-0.05em] text-argmin-dark md:text-5xl lg:text-6xl",
        revealClass,
      ]}
    >
      Know which teams use which AI models, at what cost, and why.
    </p>
  </div>
</section>

<style>
  .hero-headline {
    font-family:
      "SF Pro Display",
      "Inter",
      "Inter Tight",
      "Helvetica Neue",
      "Segoe UI",
      sans-serif;
    font-weight: 650;
    text-rendering: optimizeLegibility;
    font-feature-settings: "rlig" 1, "ss01" 1, "cv11" 1;
    text-wrap: balance;
  }

  .hero-headline-dark {
    color: rgb(17 17 17);
  }
</style>
