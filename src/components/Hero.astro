---
import { siteConfig } from "../content/site";

const { hero } = siteConfig;
---

<section class="hero-section overflow-hidden border-b border-white/10 bg-argmin-navy px-6 py-8">
  <div class="hero-backdrop" aria-hidden="true"></div>
  <div class="section-shell hero-grid lg:grid-cols-[minmax(0,0.94fr)_minmax(0,1.06fr)]">
    <div class="hero-copy-block fade-rise">
      <p class="font-display text-[1.55rem] font-bold tracking-[-0.03em] text-white">{hero.wordmark}</p>
      <p class="mt-6 text-[0.72rem] font-semibold uppercase tracking-[0.18em] text-argmin-sky">
        {hero.eyebrow}
      </p>
      <h1 class="hero-title mt-4 max-w-[11ch]">{hero.headline}</h1>
      <p class="hero-copy">{hero.subheadline}</p>

      <div class="mt-8 flex flex-col gap-3 sm:flex-row sm:flex-wrap sm:items-center">
        <a href="#how" class="primary-button" data-track-event="hero_graph_view">
          {hero.primaryCtaLabel}
        </a>
        <a href="#sample-output" class="inverse-secondary-button" data-track-event="hero_sample_view">
          {hero.secondaryCtaLabel}
        </a>
        <a
          href="#contact"
          class="inline-flex items-center text-sm font-medium text-white underline decoration-from-font underline-offset-4 hover:text-argmin-sky"
          data-cta-button
          data-track-event="hero_leakage_estimate"
          data-contact-template={hero.contactTemplate}
        >
          {hero.contactCtaLabel}
        </a>
      </div>

      <dl class="hero-proof-list">
        {hero.proofPoints.map((item) => (
          <div class="hero-proof-item">
            <dt class="hero-proof-label">{item.label}</dt>
            <dd class="hero-proof-value">{item.value}</dd>
          </div>
        ))}
      </dl>
    </div>

    <div class="fade-rise fade-rise-delay-1 lg:pl-8">
      <div class="hero-poster">
        <div class="hero-poster-chip">{hero.posterChip}</div>
        <h2 class="hero-poster-title">{hero.posterTitle}</h2>
        <p class="hero-poster-copy">{hero.posterCopy}</p>

        <div class="hero-moment-list" aria-label="Key decision moments">
          {hero.decisionMoments.map((moment) => (
            <article class="hero-moment-item">
              <p class="hero-moment-label">{moment.label}</p>
              <p class="hero-moment-copy">{moment.detail}</p>
            </article>
          ))}
        </div>

        <div class="hero-output-band">
          <p class="hero-output-label">Decision surfaces</p>
          <ul class="hero-output-list">
            {hero.decisionOutputs.map((item) => (
              <li>{item}</li>
            ))}
          </ul>
        </div>
      </div>
    </div>
  </div>

  <a href="#problem" class="scroll-hint" aria-label="Scroll to content">
    <svg width="20" height="20" viewBox="0 0 20 20" fill="none" aria-hidden="true">
      <path d="M4 7l6 6 6-6" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"></path>
    </svg>
  </a>
</section>
