---
import { CONTACT_EMAIL } from "../lib/contact";

interface Props {
  formspreeUrl?: string;
  headingId: string;
  headingText?: string;
  variant?: "embedded" | "standalone";
}

const {
  formspreeUrl = "",
  headingId,
  headingText,
  variant = "embedded",
} = Astro.props;

const endpoint = formspreeUrl.trim();
const hasEndpoint = endpoint.length > 0;
const isStandalone = variant === "standalone";
const contactEmailHref = `mailto:${CONTACT_EMAIL}`;

const containerClass = isStandalone
  ? "surface-panel px-6 py-8 md:px-10 md:py-10"
  : "mt-10";
const formClass = isStandalone ? "space-y-5" : "space-y-4 p-6 md:p-8";
const textInputClass = isStandalone
  ? "w-full rounded-xl border border-argmin-border bg-argmin-surface px-4 py-3 text-base text-argmin-dark placeholder:text-argmin-light transition-colors duration-150 hover:border-argmin-accent/40 focus:border-transparent focus:outline-none focus:ring-2 focus:ring-argmin-accent"
  : "w-full rounded-lg border border-argmin-border bg-argmin-surface px-4 py-3 text-base text-argmin-dark placeholder:text-argmin-light focus:border-transparent focus:outline-none focus:ring-2 focus:ring-argmin-accent";
const selectClass = isStandalone
  ? "w-full rounded-xl border border-argmin-border bg-argmin-surface px-4 py-3 text-base text-argmin-dark focus:border-transparent focus:outline-none focus:ring-2 focus:ring-argmin-accent"
  : "w-full rounded-lg border border-argmin-border bg-argmin-surface px-4 py-3 text-base text-argmin-dark focus:border-transparent focus:outline-none focus:ring-2 focus:ring-argmin-accent";
const buttonClass = isStandalone
  ? "button-primary w-full py-4 text-base"
  : "w-full rounded-lg bg-argmin-accent px-8 py-4 text-lg font-semibold text-argmin-accent-ink transition-colors duration-200 hover:bg-argmin-accent-hover focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-argmin-accent disabled:cursor-not-allowed disabled:opacity-50";
const helperTextClass = isStandalone
  ? "text-center text-sm text-argmin-mid"
  : "text-center text-sm text-argmin-dark";
const linkClass = isStandalone
  ? "font-medium text-argmin-dark underline decoration-from-font underline-offset-4"
  : "underline decoration-from-font underline-offset-4";
const noScriptClass = "mt-6 text-center text-sm text-argmin-dark";
---

<div id="form-container" class={containerClass} aria-live="polite">
  <form
    id="contact-form"
    class={formClass}
    aria-labelledby={headingId}
    data-form-configured={String(hasEndpoint)}
    action={hasEndpoint ? endpoint : undefined}
    method="POST"
  >
    {headingText ? (
      <h2 id={headingId} class="section-kicker">{headingText}</h2>
    ) : null}

    {isStandalone ? (
      <>
        <div class="grid gap-5 sm:grid-cols-2">
          <div>
            <label for="name" class="mb-2 block text-sm font-medium text-argmin-dark">Name</label>
            <input
              id="name"
              name="name"
              type="text"
              required
              placeholder="Your name"
              class={textInputClass}
            />
          </div>
          <div>
            <label for="email" class="mb-2 block text-sm font-medium text-argmin-dark">Email</label>
            <input
              id="email"
              name="email"
              type="email"
              required
              placeholder="work@company.com"
              class={textInputClass}
            />
          </div>
        </div>
        <div>
          <label for="company" class="mb-2 block text-sm font-medium text-argmin-dark">Company</label>
          <input
            id="company"
            name="company"
            type="text"
            required
            placeholder="Company name"
            class={textInputClass}
          />
        </div>
        <div class="grid gap-5 sm:grid-cols-2">
          <div>
            <label for="cloud" class="mb-2 block text-sm font-medium text-argmin-dark">Primary cloud</label>
            <select id="cloud" name="cloud" required class={selectClass}>
              <option value="">Select...</option>
              <option value="aws">AWS</option>
              <option value="azure">Azure</option>
              <option value="gcp">GCP</option>
              <option value="multi">Multi-cloud</option>
              <option value="other">Other</option>
            </select>
          </div>
          <div>
            <label for="ai-spend" class="mb-2 block text-sm font-medium text-argmin-dark">Monthly AI spend</label>
            <select id="ai-spend" name="ai_spend" required class={selectClass}>
              <option value="">Select...</option>
              <option value="under-50k">Under $50k</option>
              <option value="50k-250k">$50k–$250k</option>
              <option value="250k-1m">$250k–$1M</option>
              <option value="over-1m">Over $1M</option>
              <option value="unsure">Not sure</option>
            </select>
          </div>
        </div>
        <div>
          <label for="teams" class="mb-2 block text-sm font-medium text-argmin-dark">Teams using AI</label>
          <select id="teams" name="teams_using_ai" required class={selectClass}>
            <option value="">Select...</option>
            <option value="1-3">1–3 teams</option>
            <option value="4-10">4–10 teams</option>
            <option value="10-plus">10+ teams</option>
            <option value="unsure">Not sure</option>
          </select>
        </div>
      </>
    ) : (
      <>
        <div>
          <label for="name" class="mb-2 block text-sm font-medium text-argmin-dark">Name</label>
          <input
            id="name"
            name="name"
            type="text"
            required
            placeholder="Your name"
            class={textInputClass}
          />
        </div>
        <div>
          <label for="email" class="mb-2 block text-sm font-medium text-argmin-dark">Email</label>
          <input
            id="email"
            name="email"
            type="email"
            required
            placeholder="work@company.com"
            class={textInputClass}
          />
        </div>
        <div>
          <label for="company" class="mb-2 block text-sm font-medium text-argmin-dark">Company</label>
          <input
            id="company"
            name="company"
            type="text"
            required
            placeholder="Company name"
            class={textInputClass}
          />
        </div>
        <div class="grid gap-4 sm:grid-cols-3">
          <div>
            <label for="cloud" class="mb-2 block text-sm font-medium text-argmin-dark">Primary cloud</label>
            <select id="cloud" name="cloud" required class={selectClass}>
              <option value="">Select...</option>
              <option value="aws">AWS</option>
              <option value="azure">Azure</option>
              <option value="gcp">GCP</option>
              <option value="multi">Multi-cloud</option>
              <option value="other">Other</option>
            </select>
          </div>
          <div>
            <label for="ai-spend" class="mb-2 block text-sm font-medium text-argmin-dark">Monthly AI spend</label>
            <select id="ai-spend" name="ai_spend" required class={selectClass}>
              <option value="">Select...</option>
              <option value="under-50k">Under $50k</option>
              <option value="50k-250k">$50k–$250k</option>
              <option value="250k-1m">$250k–$1M</option>
              <option value="over-1m">Over $1M</option>
              <option value="unsure">Not sure</option>
            </select>
          </div>
          <div>
            <label for="teams" class="mb-2 block text-sm font-medium text-argmin-dark">Teams using AI</label>
            <select id="teams" name="teams_using_ai" required class={selectClass}>
              <option value="">Select...</option>
              <option value="1-3">1–3 teams</option>
              <option value="4-10">4–10 teams</option>
              <option value="10-plus">10+ teams</option>
              <option value="unsure">Not sure</option>
            </select>
          </div>
        </div>
      </>
    )}

    <div>
      <label for="message" class="mb-2 block text-sm font-medium text-argmin-dark">Message</label>
      <textarea
        id="message"
        name="message"
        rows="4"
        placeholder="Tell us about your AI spend challenge"
        class={textInputClass}
      ></textarea>
    </div>
    <input type="text" id="gotcha" name="_gotcha" class="hidden" tabindex="-1" autocomplete="off" />
    <button
      id="submit-btn"
      type="submit"
      disabled={!hasEndpoint}
      aria-describedby={!hasEndpoint ? "form-config-error" : undefined}
      data-default-label="Get in Touch"
      data-loading-label="Sending..."
      class={buttonClass}
    >
      {hasEndpoint ? "Get in Touch" : "Form Unavailable"}
    </button>
    <p id="form-config-error" class:list={[helperTextClass, hasEndpoint && "hidden"]}>
      Form submissions are currently unavailable. Please email
      <a class={linkClass} href={contactEmailHref}>{CONTACT_EMAIL}</a>.
    </p>
    <p id="form-error" class:list={[helperTextClass, "hidden"]}>
      Submission failed. Please email us directly at
      <a class={linkClass} href={contactEmailHref}>{CONTACT_EMAIL}</a>.
    </p>
  </form>
</div>

<noscript>
  <p class={noScriptClass}>
    Prefer email instead? Reach us directly at
    <a class="font-medium text-argmin-dark underline decoration-from-font underline-offset-4" href={contactEmailHref}>
      {CONTACT_EMAIL}
    </a>
    .
  </p>
</noscript>

<script is:inline define:vars={{ endpoint }}>
  (function () {
    var form = document.getElementById("contact-form");
    var button = document.getElementById("submit-btn");
    var container = document.getElementById("form-container");
    var error = document.getElementById("form-error");
    var nameField = document.getElementById("name");
    var emailField = document.getElementById("email");
    var companyField = document.getElementById("company");
    var cloudField = document.getElementById("cloud");
    var aiSpendField = document.getElementById("ai-spend");
    var teamsField = document.getElementById("teams");
    var messageField = document.getElementById("message");
    var gotchaField = document.getElementById("gotcha");

    if (
      !endpoint ||
      !(form instanceof HTMLFormElement) ||
      !(button instanceof HTMLButtonElement) ||
      !(container instanceof HTMLElement) ||
      !(nameField instanceof HTMLInputElement) ||
      !(emailField instanceof HTMLInputElement) ||
      !(companyField instanceof HTMLInputElement) ||
      !(cloudField instanceof HTMLSelectElement) ||
      !(aiSpendField instanceof HTMLSelectElement) ||
      !(teamsField instanceof HTMLSelectElement) ||
      !(messageField instanceof HTMLTextAreaElement) ||
      !(gotchaField instanceof HTMLInputElement)
    ) {
      return;
    }

    var defaultButtonLabel = button.dataset.defaultLabel || "Get in Touch";
    var loadingButtonLabel = button.dataset.loadingLabel || "Sending...";

    form.addEventListener("submit", async function (event) {
      event.preventDefault();

      if (!form.reportValidity()) {
        return;
      }

      var payload = {
        name: nameField.value.trim(),
        email: emailField.value.trim(),
        company: companyField.value.trim(),
        cloud: cloudField.value,
        ai_spend: aiSpendField.value,
        teams_using_ai: teamsField.value,
        message: messageField.value.trim(),
        _gotcha: gotchaField.value.trim(),
      };

      button.disabled = true;
      button.textContent = loadingButtonLabel;
      if (error) {
        error.classList.add("hidden");
      }

      var controller = new AbortController();
      var timeoutId = window.setTimeout(function () {
        controller.abort();
      }, 10000);

      try {
        var response = await fetch(endpoint, {
          method: "POST",
          headers: {
            Accept: "application/json",
            "Content-Type": "application/json",
          },
          body: JSON.stringify(payload),
          signal: controller.signal,
        });

        if (!response.ok) {
          throw new Error("Form submission failed");
        }

        container.innerHTML =
          '<p class="py-8 text-center text-xl text-argmin-dark">Thank you. We will be in touch shortly.</p>';
        window.plausible && window.plausible("form_submit");
      } catch (submissionError) {
        console.error("Contact form submission failed:", submissionError);
        button.disabled = false;
        button.textContent = defaultButtonLabel;
        if (error) {
          error.classList.remove("hidden");
        }
      } finally {
        window.clearTimeout(timeoutId);
      }
    });
  })();
</script>
