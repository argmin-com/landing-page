---
import { siteConfig } from "../content/site";

const { founders, foundersSection } = siteConfig;
---

<section id="founders" class="border-b border-argmin-slate-300/70 bg-argmin-ice/20 px-6 py-16 md:py-24">
  <div class="section-shell">
    <p class="section-eyebrow">Founders</p>
    <h2 class="section-title max-w-none">{foundersSection.title}</h2>
    <p class="section-copy max-w-3xl">{foundersSection.copy}</p>

    <div class="mt-12 grid grid-cols-1 gap-12 md:grid-cols-2">
      {founders.map((founder) => (
        <article class="border-t border-argmin-slate-300/80 pt-6">
          <div class="flex flex-col gap-5 sm:flex-row sm:items-start">
            <picture class="shrink-0">
              <source srcset={founder.webp} type="image/webp" />
              <img
                src={founder.jpg}
                alt={founder.alt}
                class="h-28 w-28 rounded-full object-cover md:h-32 md:w-32"
                width="128"
                height="128"
                loading="lazy"
              />
            </picture>

            <div class="min-w-0">
              <div class="flex flex-wrap items-center gap-3">
                <h3 class="font-display text-[1.55rem] font-semibold tracking-[-0.03em] text-argmin-navy">
                  {founder.name}
                </h3>
                <p class="text-[0.72rem] font-semibold uppercase tracking-[0.18em] text-argmin-slate-500">
                  {founder.title}
                </p>
              </div>
              <a
                href={founder.linkedin}
                target="_blank"
                rel="noopener noreferrer"
                aria-label={`View ${founder.name} on LinkedIn`}
                class="mt-3 inline-flex text-sm font-medium text-argmin-azure underline decoration-from-font underline-offset-4 hover:text-argmin-sky"
              >
                LinkedIn
              </a>
            </div>
          </div>

          <p class="mt-5 text-base leading-7 text-argmin-slate-700">{founder.bio}</p>
        </article>
      ))}
    </div>
  </div>
</section>
