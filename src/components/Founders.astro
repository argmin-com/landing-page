---
interface Props {
  title?: string;
  intro?: string;
  stack?: boolean;
}

const founders = [
  {
    name: "Charlotte Wargniez",
    title: "CTO",
    alt: "Charlotte Wargniez, CTO",
    webp: "/charlotte.webp",
    jpg: "/charlotte.jpg",
    bio: "University of Oxford DPhil researcher in AI for critical infrastructure (Intelligent Earth CDT). Visiting Researcher at the European Space Agency. Research focus: deep reinforcement learning for adaptive planning and optimization. Rose Sheinin Award: top woman in science across the University of Toronto (21,000 graduates).",
    linkedin: "https://www.linkedin.com/in/charlotte-wargniez",
  },
  {
    name: "Richard McKinney",
    title: "CEO",
    alt: "Richard McKinney, CEO",
    webp: "/richard.webp",
    jpg: "/richard.jpg",
    bio: "Oxford alum. 14 years building enterprise infrastructure at Amazon, Cruise/GM, and Salesforce. Built Amazon's greenhouse gas data platform across 94 countries. Co-founded the AI Energy Score with Hugging Face. Led product for Salesforce Shield Platform Encryption.",
    linkedin: "https://www.linkedin.com/in/richardcmckinney",
  },
];

const { title = "Founders", intro, stack = false } = Astro.props;
---

<section id="founders" class="bg-argmin-bg px-6 py-10 md:py-14">
  <div class="mx-auto max-w-6xl">
    <h2 class="text-center text-sm font-semibold uppercase tracking-[0.24em] text-argmin-light">{title}</h2>
    {intro && <p class="mx-auto mt-6 max-w-2xl text-center text-base leading-relaxed text-argmin-mid">{intro}</p>}
    <div class:list={["mt-8 grid grid-cols-1 gap-12", stack ? "max-w-4xl mx-auto" : "md:grid-cols-2"]}>
      {founders.map((founder) => (
        <article class="text-center">
          <picture>
            <source srcset={founder.webp} type="image/webp" />
            <img
              src={founder.jpg}
              alt={founder.alt}
              class="mx-auto mb-4 h-32 w-32 rounded-full object-cover md:h-40 md:w-40"
              width="200"
              height="200"
              loading="lazy"
            />
          </picture>
          <div class="flex items-center justify-center gap-2">
            <h3 class="text-xl font-bold text-argmin-dark">{founder.name}</h3>
            <a
              href={founder.linkedin}
              target="_blank"
              rel="noopener noreferrer"
              aria-label={`View ${founder.name} on LinkedIn`}
              class="text-argmin-accent transition-colors duration-200 hover:text-argmin-accent-hover focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-argmin-accent"
            >
              <svg viewBox="0 0 24 24" class="h-4 w-4 fill-current" aria-hidden="true">
                <path
                  d="M4.98 3.5A2.49 2.49 0 1 1 5 8.48a2.49 2.49 0 0 1-.02-4.98ZM3 9h4v12H3Zm7 0h3.83v1.64h.05c.53-1 1.84-2.05 3.79-2.05 4.05 0 4.8 2.67 4.8 6.14V21h-4v-5.54c0-1.32-.02-3.02-1.84-3.02-1.85 0-2.13 1.44-2.13 2.93V21h-4Z"
                />
              </svg>
            </a>
          </div>
          <p class="mb-3 mt-2 text-sm font-medium text-argmin-accent">{founder.title}</p>
          <p class="text-left text-base leading-relaxed text-argmin-mid md:text-center">{founder.bio}</p>
        </article>
      ))}
    </div>
  </div>
</section>
