          {node.label}
        </text>
      </g>
    ))}

    <g data-group="attribution" class="diagram-group">
      <circle cx="642" cy="266" r="78" class="engine-shell" />
      <circle cx="642" cy="266" r="50" class="engine-core" />
      <circle cx="642" cy="266" r="17" class="engine-kernel" />
      <path d="M642 196v-14M642 350v-14M572 266h-14M726 266h-14" class="engine-port" />
      <path d="M598 222c20 18 30 28 44 44" class="engine-port" />
      <path d="M686 222c-20 18-30 28-44 44" class="engine-port" />
      <path d="M598 310c20-18 30-28 44-44" class="engine-port" />
      <path d="M686 310c-20-18-30-28-44-44" class="engine-port" />
      <text x="642" y="258" text-anchor="middle" class="diagram-label diagram-label--center">
        Heuristic Attribution Engine
      </text>
      <text x="642" y="284" text-anchor="middle" class="diagram-copy">
        Reconciles fragmented signals
      </text>
    </g>

    <g data-group="attribution" class="diagram-group diagram-node">
      <circle cx="946" cy="222" r="40" class="output-shell" />
      <circle cx="946" cy="222" r="20" class="output-core" />
      <circle cx="1000" cy="266" r="11" class="junction-dot junction-dot--large" />
      <text x="946" y="172" text-anchor="middle" class="diagram-label">
        Attribution Layer
      </text>
      <text x="946" y="289" text-anchor="middle" class="diagram-copy">
        Confidence-scored graph
      </text>
    </g>

    <g data-group="attribution" class="diagram-group diagram-node">
      <rect x="1018" y="218" width="144" height="96" rx="30" class="dashboard-shell" />
      <rect x="1048" y="242" width="84" height="48" rx="18" class="dashboard-screen" />
      <path d="M1064 281v-16M1084 281v-28M1104 281v-12M1124 281v-22" class="icon-line" />
      <path d="M1060 288h68" class="icon-line" />
      <text x="1090" y="352" text-anchor="middle" class="diagram-label">
        Dashboard
      </text>
      <text x="1090" y="373" text-anchor="middle" class="diagram-copy">
        Attributable outputs
      </text>
    </g>
  </svg>

  <figcaption class="sr-only">
    Enterprise signals from billing, identity, CI/CD, source control, model usage, and telemetry converge into a heuristic attribution engine that produces confidence-scored attribution outputs for a dashboard.
  </figcaption>

  <div class="mt-6 flex flex-wrap items-center justify-center gap-3">
    <button type="button" class="diagram-keyword" data-keyword data-target="inputs" aria-pressed="false">
      Data Inputs
    </button>
    <button type="button" class="diagram-keyword" data-keyword data-target="model" aria-pressed="false">
      Model
    </button>
    <button type="button" class="diagram-keyword" data-keyword data-target="attribution" aria-pressed="false">
      Attribution
    </button>
  </div>

  <div class="dr-panel" data-detail-panel>
    <div class="dr-header">
      <p class="dr-eyebrow">Attribution Graph</p>
      <h3 class="dr-title">
        Resolve the chain progressively instead of hiding it behind a total.
      </h3>
      <p class="dr-copy">Each stage adds evidence until the request becomes an attributable decision with visible confidence and a next action.</p>
    </div>

    <div class="dr-inputs" data-dr-group="inputs">
      <p class="dr-label">Read-only inputs</p>
      <ul class="dr-chips">
        {detailInputs.map((item) => (
          <li class="dr-chip" data-dr-chip={item.group}>
            {item.label}
          </li>
        ))}
      </ul>
    </div>

    <div class="dr-record">
      <div class="dr-record-head">
        <p class="dr-label">Resolved attribution record</p>
        <p class="dr-record-copy">One request, six layers, visible confidence.</p>
      </div>

      <ol class="dr-list">
        {attributionLayers.map((layer) => (
          <li class="dr-row" data-dr-row data-dr-row-group={layer.group}>
            <div>
              <p class="dr-row-label">{layer.label}</p>
            </div>
            <p class="dr-row-value">{layer.value}</p>
            <span class:list={["dr-badge", `is-${layer.tone}`]}>
              Confidence {layer.confidence}
            </span>
          </li>
        ))}
      </ol>
    </div>

    <div class="dr-decision" data-dr-group="attribution" data-dr-decision>
      <p class="dr-label">{decisionRecord.title}</p>
      <h4 class="dr-decision-title">{decisionRecord.heading}</h4>
      <p class="dr-decision-copy">{decisionRecord.body}</p>

      <dl class="dr-decision-grid">
        {decisionRecord.fields.map((field) => (
          <div class="dr-field">
            <dt class="dr-row-label">{field.label}</dt>
            <dd class="dr-field-value">{field.value}</dd>
          </div>
        ))}
      </dl>
    </div>
  </div>
</figure>

<script is:inline>
  const diagrams = document.querySelectorAll("[data-diagram]");

  const setDiagramState = (diagram, value) => {
    diagram.setAttribute("data-active", value);

    for (const keyword of diagram.querySelectorAll("[data-keyword]")) {
      const isActive = keyword.getAttribute("data-target") === value;
      keyword.setAttribute("aria-pressed", String(isActive));
    }
  };

  for (const diagram of diagrams) {
    const keywords = diagram.querySelectorAll("[data-keyword]");
    setDiagramState(diagram, "none");

    for (const keyword of keywords) {
      const target = keyword.getAttribute("data-target") || "none";
      const activate = () => setDiagramState(diagram, target);
      const reset = () => setDiagramState(diagram, "none");

      keyword.addEventListener("mouseenter", activate);
      keyword.addEventListener("focus", activate);
      keyword.addEventListener("mouseleave", reset);
      keyword.addEventListener("blur", reset);
    }
  }
</script>

<style>
