---
interface Props {
  className?: string;
}

const { className = "" } = Astro.props;

const inputNodes = [
  { key: "billing", label: "Cloud Billing", cx: 132, cy: 96, group: "inputs" },
  { key: "identity", label: "Identity / HR", cx: 148, cy: 174, group: "inputs" },
  { key: "cicd", label: "CI/CD", cx: 124, cy: 252, group: "inputs" },
  { key: "source", label: "Source Control", cx: 156, cy: 330, group: "inputs" },
  { key: "model", label: "Model Usage", cx: 136, cy: 408, group: "inputs" },
  { key: "telemetry", label: "Cloud Telemetry", cx: 166, cy: 486, group: "inputs" },
];

const liveConfidenceScores = [
  { label: "Person -> Workload", value: "94.2%", width: 0.942 },
  { label: "Service -> Cost Event", value: "91.6%", width: 0.916 },
  { label: "Team -> Budget", value: "88.4%", width: 0.884 },
];

const dashboardTeamCosts = [
  { label: "Engineering", value: "$42.5k", width: 0.84 },
  { label: "Product", value: "$18.2k", width: 0.48 },
  { label: "Marketing", value: "$9.9k", width: 0.26 },
];
---

<figure
  class:list={["attribution-diagram relative mx-auto w-full max-w-6xl", className]}
  data-diagram
  data-active="none"
  data-hover="none"
>
  <div class="diagram-controls pointer-events-none absolute inset-x-0 top-5 z-10 flex justify-center px-4">
    <div class="flex flex-wrap items-center justify-center gap-3 pointer-events-auto">
      <button type="button" class="diagram-keyword" data-keyword data-target="inputs">
        Data Inputs
      </button>
      <button type="button" class="diagram-keyword" data-keyword data-target="attribution" data-hover-value="layer">
        Attribution
      </button>
      <button type="button" class="diagram-keyword" data-keyword data-target="control" data-hover-value="dashboard">
        Control
      </button>
    </div>
  </div>

  <svg
    viewBox="0 0 1280 620"
    class="h-auto w-full"
    role="img"
    aria-labelledby="attribution-flow-title attribution-flow-desc"
  >
    <title id="attribution-flow-title">Argmin attribution flow diagram</title>
    <desc id="attribution-flow-desc">
      Fragmented enterprise inputs route through a heuristic reconciliation engine, into an attribution layer with confidence scoring, and finally into a dashboard with spend forecasts and suggested interventions.
    </desc>

    <g class="diagram-backdrop" aria-hidden="true">
      <path d="M120 86C278 84 364 120 470 252" class="pipe-shell" />
      <path d="M136 164C286 164 374 190 470 258" class="pipe-shell" />
      <path d="M112 242C280 242 378 248 470 266" class="pipe-shell" />
      <path d="M144 320C300 318 386 300 470 274" class="pipe-shell" />
      <path d="M124 398C288 392 382 352 470 282" class="pipe-shell" />
      <path d="M154 476C326 468 404 408 470 290" class="pipe-shell" />

      <path d="M120 86C278 84 364 120 470 252" class="pipe-line" data-group="inputs" />
      <path d="M136 164C286 164 374 190 470 258" class="pipe-line" data-group="inputs" />
      <path d="M112 242C280 242 378 248 470 266" class="pipe-line" data-group="inputs" />
      <path d="M144 320C300 318 386 300 470 274" class="pipe-line" data-group="inputs" />
      <path d="M124 398C288 392 382 352 470 282" class="pipe-line" data-group="inputs" />
      <path d="M154 476C326 468 404 408 470 290" class="pipe-line" data-group="inputs" />

      <path d="M470 270C500 264 532 262 570 264" class="pipe-shell" />
      <path d="M470 270C500 264 532 262 570 264" class="pipe-line strong" data-group="attribution" />

      <path d="M720 266C792 266 836 266 884 266" class="pipe-shell" />
      <path d="M720 266C792 266 836 266 884 266" class="pipe-line strong" data-group="attribution" />

      <path d="M1006 266C1040 266 1078 266 1108 266" class="pipe-shell" />
      <path d="M1006 266C1040 266 1078 266 1108 266" class="pipe-line strong" data-group="control" />
    </g>

    {inputNodes.map((node) => (
      <g data-group={node.group} class="diagram-group diagram-node">
        <circle cx={node.cx} cy={node.cy} r="33" class="node-shell" />
        <circle cx={node.cx} cy={node.cy} r="19" class="node-core" />

        {node.key === "billing" && (
          <g class="node-icon">
            <rect x={node.cx - 9} y={node.cy - 7} width="18" height="14" rx="3" class="icon-fill" />
            <path d={`M${node.cx - 10} ${node.cy - 1}h20`} class="icon-line" />
          </g>
        )}
        {node.key === "identity" && (
          <g class="node-icon">
            <circle cx={node.cx} cy={node.cy - 4} r="5" class="icon-fill" />
            <path d={`M${node.cx - 8} ${node.cy + 10}c2-6 14-6 16 0`} class="icon-line" />
          </g>
        )}
        {node.key === "cicd" && (
          <g class="node-icon">
            <path d={`M${node.cx - 11} ${node.cy}h7l4-6 5 12 5-8h8`} class="icon-line" />
          </g>
        )}
        {node.key === "source" && (
          <g class="node-icon">
            <path d={`M${node.cx - 10} ${node.cy - 4}l-6 6 6 6`} class="icon-line" />
            <path d={`M${node.cx + 10} ${node.cy - 4}l6 6-6 6`} class="icon-line" />
          </g>
        )}
        {node.key === "model" && (
          <g class="node-icon">
            <circle cx={node.cx} cy={node.cy} r="7" class="icon-fill" />
            <path d={`M${node.cx} ${node.cy - 12}v24M${node.cx - 12} ${node.cy}h24`} class="icon-line" />
          </g>
        )}
        {node.key === "telemetry" && (
          <g class="node-icon">
            <path d={`M${node.cx - 12} ${node.cy + 8}l9-10 7 5 10-12`} class="icon-line" />
          </g>
        )}

        <text x={node.cx - 36} y={node.cy + 4} text-anchor="end" class="diagram-label">
          {node.label}
        </text>
      </g>
    ))}

    <g data-group="attribution" class="diagram-group">
      <circle cx="642" cy="266" r="78" class="engine-shell" />
      <circle cx="642" cy="266" r="50" class="engine-core" />
      <circle cx="642" cy="266" r="17" class="engine-kernel" />
      <path d="M642 196v-14M642 350v-14M572 266h-14M726 266h-14" class="engine-port" />
      <text x="642" y="370" text-anchor="middle" class="diagram-label diagram-label--center">
        Heuristic Attribution Engine
      </text>
      <text x="642" y="392" text-anchor="middle" class="diagram-copy">
        Reconciles fragmented signals
      </text>
    </g>

    <g
      data-group="attribution"
      class="diagram-group diagram-node"
    >
      <rect x="884" y="198" width="122" height="136" rx="32" class="output-shell" />
      <path d="M941 230L925 250L957 250L933 274L965 284" class="mini-line" />
      <path d="M941 230L967 232" class="mini-line" />
      <path d="M957 250L965 284" class="mini-line" />
      <circle cx="941" cy="230" r="4.5" class="mini-point" />
      <circle cx="925" cy="250" r="4.5" class="mini-point" />
      <circle cx="957" cy="250" r="4.5" class="mini-point" />
      <circle cx="933" cy="274" r="4.5" class="mini-point" />
      <circle cx="965" cy="284" r="4.5" class="mini-point" />
      <circle cx="967" cy="232" r="4.5" class="mini-point" />
      <text x="945" y="362" text-anchor="middle" class="diagram-label">
        Attribution Graph
      </text>
      <text x="945" y="384" text-anchor="middle" class="diagram-copy">
        Confidence-scored graph
      </text>
    </g>

    <g class="diagram-group diagram-hover-card" data-hover-panel="layer" aria-hidden="true">
      <rect x="760" y="128" width="332" height="286" rx="30" class="detail-panel-shell" />
      <text x="790" y="184" class="detail-eyebrow">
        Live Confidence Scores
      </text>
      <text x="790" y="210" class="detail-title">
        Ownership graph updates in real time
      </text>
      {liveConfidenceScores.map((score, index) => {
        const y = 254 + index * 42;
        return (
          <g class="detail-row">
            <text x="790" y={y} class="detail-copy" dominant-baseline="middle">
              {score.label}
            </text>
            <text x="1060" y={y} text-anchor="end" class="detail-value" dominant-baseline="middle">
              {score.value}
            </text>
            <rect x="790" y={y + 16} width="202" height="6" rx="999" class="detail-track" />
            <rect x="790" y={y + 16} width={202 * score.width} height="6" rx="999" class="detail-fill" />
          </g>
        );
      })}
    </g>

    <g
      data-group="control"
      class="diagram-group diagram-node"
    >
      <rect x="1108" y="206" width="154" height="122" rx="32" class="dashboard-shell" />
      <rect x="1133" y="234" width="104" height="62" rx="20" class="dashboard-screen" />
      <path d="M1149 281v-14M1171 281v-28M1193 281v-12M1215 281v-22" class="icon-line" />
      <path d="M1145 288h74" class="icon-line" />
      <text x="1185" y="362" text-anchor="middle" class="diagram-label">
        Dashboard
      </text>
      <text x="1185" y="384" text-anchor="middle" class="diagram-copy">
        Attributable outputs
      </text>
    </g>

    <g
      class="diagram-group diagram-hover-card"
      data-hover-panel="dashboard"
      aria-hidden="true"
    >
      <rect x="628" y="92" width="442" height="424" rx="32" class="detail-panel-shell" />
      <text x="662" y="151" class="detail-eyebrow">
        Spend Forecast
      </text>
      <text x="1036" y="151" text-anchor="end" class="detail-copy detail-copy--caps">
        +30 days
      </text>
      <rect x="662" y="157" width="376" height="92" rx="18" class="detail-subpanel" />
      <path d="M680 225C724 225 760 223 792 217C800 214 806 209 812 203" class="forecast-line forecast-line--shared" />
      <path d="M812 203C842 200 874 191 908 180C946 168 984 162 1020 162" class="forecast-line forecast-line--baseline" />
      <path d="M812 203C842 200 876 196 912 192C952 188 988 185 1020 184" class="forecast-line forecast-line--optimized" />
      <circle cx="812" cy="203" r="11" class="forecast-dot forecast-dot--halo" />
      <circle cx="812" cy="203" r="5.5" class="forecast-dot" />
      <text x="662" y="269" class="detail-copy detail-copy--caps">
        <tspan class="detail-copy detail-copy--caps">Current</tspan>
      </text>
      <text x="1038" y="269" text-anchor="end" class="detail-copy detail-copy--caps">
        Projected
      </text>
      <g class="forecast-legend">
        <path d="M662 287h18" class="forecast-line forecast-line--baseline" />
        <text x="688" y="291" class="detail-copy">Without optimization</text>
        <path d="M828 287h18" class="forecast-line forecast-line--optimized" />
        <text x="854" y="291" class="detail-copy">With optimization</text>
      </g>
      <text x="662" y="319" class="detail-eyebrow">
        AI Costs Per Team
      </text>
      {dashboardTeamCosts.map((team, index) => {
        const y = 343 + index * 30;
        return (
          <g class="detail-row">
            <text x="662" y={y} class="detail-copy">
              {team.label}
            </text>
            <text x="1038" y={y} text-anchor="end" class="detail-value">
              {team.value}
            </text>
            <rect x="662" y={y + 10} width="286" height="6" rx="999" class="detail-track" />
            <rect x="662" y={y + 10} width={286 * team.width} height="6" rx="999" class="detail-fill" />
          </g>
        );
      })}
      <rect x="662" y="437" width="376" height="30" rx="15" class="suggestion-shell" />
      <text x="678" y="457" class="detail-copy detail-copy--strong">
        Suggested intervention
      </text>
      <text x="1022" y="457" text-anchor="end" class="detail-value detail-value--accent">
        Re-route budget owner
      </text>
    </g>
  </svg>

  <figcaption class="sr-only">
    Enterprise signals from billing, identity, CI/CD, source control, model usage, and telemetry converge into a heuristic attribution engine, then an attribution layer with visible confidence scores, and finally a dashboard that surfaces forecasts, team costs, and suggested interventions.
  </figcaption>
</figure>

<script is:inline>
  const diagrams = document.querySelectorAll("[data-diagram]");

  for (const diagram of diagrams) {
    const keywords = diagram.querySelectorAll("[data-keyword]");
    const setActive = (value) => {
      diagram.setAttribute("data-active", value);
    };
    const setHover = (value) => {
      diagram.setAttribute("data-hover", value);
    };

    for (const keyword of keywords) {
      const target = keyword.getAttribute("data-target") || "none";
      const hoverValue = keyword.getAttribute("data-hover-value") || "none";
      const activate = () => {
        setActive(target);
        setHover(hoverValue);
      };
      const reset = () => {
        setActive("none");
        setHover("none");
      };

      keyword.addEventListener("mouseenter", activate);
      keyword.addEventListener("focus", activate);
      keyword.addEventListener("mouseleave", reset);
      keyword.addEventListener("blur", reset);
    }
  }
</script>

<style>
  .attribution-diagram {
    --diagram-border: rgb(var(--color-argmin-border));
    --diagram-muted: rgb(var(--color-argmin-mid));
    --diagram-text: rgb(var(--color-argmin-dark));
    --diagram-accent: rgb(var(--color-argmin-accent));
    --diagram-dim-opacity: 0.1;
  }

  .pipe-shell {
    fill: none;
    stroke: rgb(var(--color-argmin-border) / 0.95);
    stroke-linecap: round;
    stroke-width: 18;
  }

  .pipe-line {
    fill: none;
    stroke: rgb(var(--color-argmin-accent) / 0.24);
    stroke-linecap: round;
    stroke-width: 6;
    transition: opacity 160ms ease, stroke 160ms ease;
  }

  .pipe-line.strong {
    stroke-width: 7;
  }

  .node-shell,
  .output-shell,
  .dashboard-shell,
  .detail-panel-shell,
  .detail-subpanel,
  .suggestion-shell {
    fill: rgb(var(--color-argmin-surface));
    stroke: var(--diagram-border);
    stroke-width: 2;
  }

  .node-core,
  .output-core,
  .dashboard-screen {
    fill: rgb(var(--color-argmin-accent) / 0.08);
    stroke: rgb(var(--color-argmin-accent) / 0.32);
    stroke-width: 1.5;
  }

  .engine-shell {
    fill: rgb(var(--color-argmin-surface));
    stroke: rgb(var(--color-argmin-accent) / 0.46);
    stroke-width: 3;
  }

  .engine-core {
    fill: rgb(var(--color-argmin-accent) / 0.1);
    stroke: rgb(var(--color-argmin-accent) / 0.4);
    stroke-width: 2;
  }

  .engine-kernel,
  .junction-dot,
  .junction-dot--large {
    fill: var(--diagram-accent);
    opacity: 0.22;
  }

  .junction-dot--large {
    opacity: 0.28;
  }

  .engine-port,
  .icon-line,
  .mini-line {
    fill: none;
    stroke: var(--diagram-accent);
    stroke-linecap: round;
    stroke-linejoin: round;
    stroke-width: 2;
  }

  .mini-point,
  .detail-node {
    fill: var(--diagram-accent);
  }

  .detail-node--soft {
    opacity: 0.32;
  }

  .icon-fill {
    fill: rgb(var(--color-argmin-accent) / 0.1);
    stroke: var(--diagram-accent);
    stroke-width: 1.5;
  }

  .diagram-group {
    transition: opacity 160ms ease, transform 160ms ease;
    transform-origin: center;
    transform-box: fill-box;
  }

  .diagram-label,
  .diagram-copy,
  .detail-eyebrow,
  .detail-title,
  .detail-value,
  .detail-copy {
    fill: var(--diagram-text);
    opacity: 1;
    transition: opacity 160ms ease;
  }

  .diagram-label {
    font-size: 14px;
    font-weight: 600;
  }

  .diagram-label--center {
    font-size: 16px;
  }

  .diagram-copy {
    fill: var(--diagram-muted);
    font-size: 13px;
  }

  .detail-eyebrow {
    fill: var(--diagram-muted);
    font-size: 10px;
    font-weight: 700;
    letter-spacing: 0.22em;
    text-transform: uppercase;
  }

  .detail-title {
    font-size: 16px;
    font-weight: 600;
  }

  .detail-copy {
    fill: var(--diagram-muted);
    font-size: 12px;
  }

  .detail-copy--caps,
  .detail-copy--strong {
    letter-spacing: 0.14em;
    text-transform: uppercase;
  }

  .detail-copy--strong {
    fill: var(--diagram-text);
    font-size: 10px;
    font-weight: 700;
  }

  .detail-value {
    font-size: 12px;
    font-weight: 600;
  }

  .detail-value--accent {
    fill: var(--diagram-accent);
  }

  .detail-track {
    fill: rgb(var(--color-argmin-border) / 0.72);
  }

  .detail-fill {
    fill: var(--diagram-accent);
  }

  .detail-graph-line,
  .forecast-line {
    fill: none;
    stroke-linecap: round;
    stroke-linejoin: round;
  }

  .detail-graph-line {
    stroke: rgb(var(--color-argmin-accent) / 0.55);
    stroke-width: 2;
  }

  .forecast-line {
    stroke: var(--diagram-accent);
    stroke-width: 2.25;
  }

  .forecast-line--shared {
    stroke: rgb(var(--color-argmin-accent) / 0.42);
  }

  .forecast-line--optimized {
    stroke: var(--diagram-accent);
  }

  .forecast-line--baseline {
    stroke: rgb(var(--color-argmin-dark) / 0.18);
    stroke-dasharray: 10 10;
  }

  .forecast-dot {
    fill: var(--diagram-accent);
  }

  .forecast-dot--halo {
    fill: rgb(var(--color-argmin-accent) / 0.12);
  }

  .diagram-hover-card {
    display: none;
    opacity: 0;
    pointer-events: none;
    transform: translateY(12px) scale(0.98);
  }

  .diagram-keyword {
    border: 1px solid var(--diagram-border);
    border-radius: 999px;
    background: rgb(var(--color-argmin-surface));
    color: var(--diagram-muted);
    font-size: 0.95rem;
    font-weight: 500;
    line-height: 1;
    padding: 0.75rem 1rem;
    transition: border-color 150ms ease, color 150ms ease, background-color 150ms ease;
  }

  .diagram-keyword:hover,
  .diagram-keyword:focus-visible {
    border-color: var(--diagram-accent);
    color: var(--diagram-text);
    outline: none;
  }

  .attribution-diagram[data-active="inputs"] [data-group="attribution"],
  .attribution-diagram[data-active="inputs"] [data-group="control"],
  .attribution-diagram[data-active="attribution"] [data-group="inputs"],
  .attribution-diagram[data-active="attribution"] [data-group="control"],
  .attribution-diagram[data-active="control"] [data-group="inputs"],
  .attribution-diagram[data-active="control"] [data-group="attribution"] {
    opacity: var(--diagram-dim-opacity);
  }

  .attribution-diagram[data-active="inputs"] [data-group="inputs"] .diagram-label,
  .attribution-diagram[data-active="inputs"] [data-group="inputs"] .diagram-copy,
  .attribution-diagram[data-active="attribution"] [data-group="attribution"] .diagram-label,
  .attribution-diagram[data-active="attribution"] [data-group="attribution"] .diagram-copy,
  .attribution-diagram[data-active="control"] [data-group="control"] .diagram-label,
  .attribution-diagram[data-active="control"] [data-group="control"] .diagram-copy {
    opacity: 1;
  }

  .attribution-diagram[data-hover="layer"] [data-hover-panel="layer"],
  .attribution-diagram[data-hover="dashboard"] [data-hover-panel="dashboard"] {
    display: inline;
    opacity: 1;
    transform: translateY(0) scale(1);
  }

  .attribution-diagram[data-hover="layer"] .output-shell,
  .attribution-diagram[data-hover="layer"] .output-core,
  .attribution-diagram[data-hover="dashboard"] .dashboard-shell,
  .attribution-diagram[data-hover="dashboard"] .dashboard-screen {
    stroke: var(--diagram-accent);
  }

  .attribution-diagram[data-hover="layer"] .diagram-node[data-group="attribution"],
  .attribution-diagram[data-hover="dashboard"] .diagram-node[data-group="control"] {
    transform: translateY(-6px) scale(1.05);
  }

  .attribution-diagram[data-active="inputs"] [data-group="inputs"],
  .attribution-diagram[data-active="attribution"] [data-group="attribution"],
  .attribution-diagram[data-active="control"] [data-group="control"] {
    opacity: 1;
  }

  .attribution-diagram[data-active="inputs"] .diagram-node[data-group="inputs"],
  .attribution-diagram[data-active="attribution"] .diagram-node[data-group="attribution"],
  .attribution-diagram[data-active="control"] .diagram-node[data-group="control"] {
    transform: scale(1.04);
  }

  .attribution-diagram[data-active="inputs"] [data-group="inputs"] .pipe-line,
  .attribution-diagram[data-active="attribution"] [data-group="attribution"] .pipe-line,
  .attribution-diagram[data-active="control"] [data-group="control"] .pipe-line {
    stroke: rgb(var(--color-argmin-accent) / 0.55);
  }

  .attribution-diagram[data-active="inputs"] [data-group="inputs"] .diagram-label,
  .attribution-diagram[data-active="inputs"] [data-group="inputs"] .diagram-copy,
  .attribution-diagram[data-active="attribution"] [data-group="attribution"] .diagram-label,
  .attribution-diagram[data-active="attribution"] [data-group="attribution"] .diagram-copy,
  .attribution-diagram[data-active="control"] [data-group="control"] .diagram-label,
  .attribution-diagram[data-active="control"] [data-group="control"] .diagram-copy {
    fill: var(--diagram-text);
  }

  @media (max-width: 767px) {
    .attribution-diagram {
      max-width: 100%;
    }

    .diagram-controls {
      top: 1rem;
    }

    .diagram-keyword {
      font-size: 0.9rem;
      padding: 0.7rem 0.95rem;
    }
  }
</style>
