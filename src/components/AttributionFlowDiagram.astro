---
interface Props {
  className?: string;
}

const { className = "" } = Astro.props;

const inputNodes = [
  { key: "billing", label: "Cloud Billing", cx: 132, cy: 96, group: "inputs" },
  { key: "identity", label: "Identity / HR", cx: 148, cy: 174, group: "inputs" },
  { key: "cicd", label: "CI/CD", cx: 124, cy: 252, group: "inputs" },
  { key: "source", label: "Source Control", cx: 156, cy: 330, group: "inputs" },
  { key: "model", label: "Model Usage", cx: 136, cy: 408, group: "model" },
  { key: "telemetry", label: "Cloud Telemetry", cx: 166, cy: 486, group: "inputs" },
];

const detailInputs = inputNodes.map(({ label, group }) => ({ label, group }));

const attributionLayers = [
  { label: "Model call", value: "gpt-4.1 / 58k tokens / tier-1 triage", confidence: "0.97", tone: "high", group: "model" },
  {
    label: "Service",
    value: "support-router-prod / release 2026.03.18",
    confidence: "0.95",
    tone: "high",
    group: "attribution",
  },
  {
    label: "Code owner",
    value: "Customer Ops Platform / cost center 4421",
    confidence: "0.91",
    tone: "high",
    group: "attribution",
  },
  {
    label: "Identity",
    value: "svc-support-router@prod / GitHub Actions deploy",
    confidence: "0.88",
    tone: "medium",
    group: "attribution",
  },
  {
    label: "Org unit",
    value: "Customer Operations / Support Automation",
    confidence: "0.84",
    tone: "medium",
    group: "attribution",
  },
  {
    label: "Budget",
    value: "FY26 Assistants / projected run-rate +$28.6k",
    confidence: "0.80",
    tone: "low",
    group: "attribution",
  },
];

const decisionRecord = {
  title: "Intervention point",
  heading: "Block broad rollout of the support-router model change until route economics are fixed.",
  body:
    "A release pushed low-value triage traffic to GPT-4.1. Argmin tied the change to the service, deploy identity, and budget before the higher run rate spread.",
  fields: [
    { label: "Current run rate", value: "$91.4k / month if rollout continues" },
    {
      label: "Suggested action",
      value: "Default tier-1 intents to GPT-4.1 mini, cap fallback escalation, and require owner approval before wider rollout",
    },
  ],
};
---

<figure
  class:list={["attribution-diagram diagram-v2-restore-r964 mx-auto w-full max-w-6xl", className]}
  data-diagram
  data-active="none"
>
  <svg
    viewBox="0 0 1280 620"
    class="h-auto w-full"
    role="img"
    aria-labelledby="attribution-flow-title attribution-flow-desc"
  >
    <title id="attribution-flow-title">Argmin attribution flow diagram</title>
    <desc id="attribution-flow-desc">
      Fragmented enterprise inputs route through a heuristic reconciliation engine and flow into an attribution layer and dashboard.
    </desc>

    <g class="diagram-backdrop" aria-hidden="true">
      <path d="M120 86C280 86 322 86 430 166" class="pipe-shell" />
      <path d="M136 164C286 164 330 164 432 206" class="pipe-shell" />
      <path d="M112 242C278 242 322 236 432 246" class="pipe-shell" />
      <path d="M144 320C300 320 336 304 438 286" class="pipe-shell" />
      <path d="M124 398C286 398 330 372 448 326" class="pipe-shell" />
      <path d="M154 476C318 476 358 430 470 366" class="pipe-shell" />

      <path d="M120 86C280 86 322 86 430 166" class="pipe-line" data-group="inputs" />
      <path d="M136 164C286 164 330 164 432 206" class="pipe-line" data-group="inputs" />
      <path d="M112 242C278 242 322 236 432 246" class="pipe-line" data-group="inputs" />
      <path d="M144 320C300 320 336 304 438 286" class="pipe-line" data-group="inputs" />
      <path d="M124 398C286 398 330 372 448 326" class="pipe-line" data-group="model" />
      <path d="M154 476C318 476 358 430 470 366" class="pipe-line" data-group="inputs" />

      <path d="M498 266C512 222 546 180 596 152" class="pipe-shell" />
      <path d="M498 266C542 256 576 254 620 260" class="pipe-shell" />
      <path d="M498 266C518 308 552 342 602 372" class="pipe-shell" />

      <path d="M498 266C512 222 546 180 596 152" class="pipe-line" data-group="attribution" />
      <path d="M498 266C542 256 576 254 620 260" class="pipe-line" data-group="attribution" />
      <path d="M498 266C518 308 552 342 602 372" class="pipe-line" data-group="attribution" />

      <path d="M712 266C820 266 870 266 932 222" class="pipe-shell" />
      <path d="M712 266C846 266 898 286 970 332" class="pipe-shell" />
      <path d="M712 266C862 266 930 266 1038 266" class="pipe-shell" />

      <path d="M712 266C820 266 870 266 932 222" class="pipe-line" data-group="attribution" />
      <path d="M712 266C846 266 898 286 970 332" class="pipe-line" data-group="attribution" />
      <path d="M712 266C862 266 930 266 1038 266" class="pipe-line strong" data-group="attribution" />
    </g>

    {inputNodes.map((node) => (
      <g data-group={node.group} class="diagram-group diagram-node">
        <circle cx={node.cx} cy={node.cy} r="33" class="node-shell" />
        <circle cx={node.cx} cy={node.cy} r="19" class="node-core" />
        <circle cx={node.cx + 45} cy={node.cy} r="6" class="junction-dot" />

        {node.key === "billing" && (
          <g class="node-icon">
            <rect x={node.cx - 9} y={node.cy - 7} width="18" height="14" rx="3" class="icon-fill" />
            <path d={`M${node.cx - 10} ${node.cy - 1}h20`} class="icon-line" />
          </g>
        )}
        {node.key === "identity" && (
          <g class="node-icon">
            <circle cx={node.cx} cy={node.cy - 4} r="5" class="icon-fill" />
            <path d={`M${node.cx - 8} ${node.cy + 10}c2-6 14-6 16 0`} class="icon-line" />
          </g>
        )}
        {node.key === "cicd" && (
          <g class="node-icon">
            <path d={`M${node.cx - 11} ${node.cy}h7l4-6 5 12 5-8h8`} class="icon-line" />
          </g>
        )}
        {node.key === "source" && (
          <g class="node-icon">
            <path d={`M${node.cx - 10} ${node.cy - 4}l-6 6 6 6`} class="icon-line" />
            <path d={`M${node.cx + 10} ${node.cy - 4}l6 6-6 6`} class="icon-line" />
          </g>
        )}
        {node.key === "model" && (
          <g class="node-icon">
            <circle cx={node.cx} cy={node.cy} r="7" class="icon-fill" />
            <path d={`M${node.cx} ${node.cy - 12}v24M${node.cx - 12} ${node.cy}h24`} class="icon-line" />
          </g>
        )}
        {node.key === "telemetry" && (
          <g class="node-icon">
            <path d={`M${node.cx - 12} ${node.cy + 8}l9-10 7 5 10-12`} class="icon-line" />
          </g>
