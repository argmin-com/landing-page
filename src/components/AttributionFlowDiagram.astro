---
interface Props {
  className?: string;
}

const { className = "" } = Astro.props;

const inputNodes = [
  { key: "billing", label: "Cloud Billing", cx: 132, cy: 96, group: "inputs" },
  { key: "identity", label: "Identity / HR", cx: 148, cy: 174, group: "inputs" },
  { key: "cicd", label: "CI/CD", cx: 124, cy: 252, group: "inputs" },
  { key: "source", label: "Source Control", cx: 156, cy: 330, group: "inputs" },
  { key: "model", label: "Model Usage", cx: 136, cy: 408, group: "model" },
  { key: "telemetry", label: "Cloud Telemetry", cx: 166, cy: 486, group: "inputs" },
];
---

<figure class:list={["attribution-diagram mx-auto w-full max-w-6xl", className]} data-diagram data-active="none">
  <svg
    viewBox="0 0 1280 620"
    class="h-auto w-full"
    role="img"
    aria-labelledby="attribution-flow-title attribution-flow-desc"
  >
    <title id="attribution-flow-title">Argmin attribution flow diagram</title>
    <desc id="attribution-flow-desc">
      Fragmented enterprise inputs route through a heuristic reconciliation engine and flow into an attribution layer and dashboard.
    </desc>

    <g class="diagram-backdrop" aria-hidden="true">
      <path d="M120 86C280 86 322 86 430 166" class="pipe-shell" />
      <path d="M136 164C286 164 330 164 432 206" class="pipe-shell" />
      <path d="M112 242C278 242 322 236 432 246" class="pipe-shell" />
      <path d="M144 320C300 320 336 304 438 286" class="pipe-shell" />
      <path d="M124 398C286 398 330 372 448 326" class="pipe-shell" />
      <path d="M154 476C318 476 358 430 470 366" class="pipe-shell" />

      <path d="M120 86C280 86 322 86 430 166" class="pipe-line" data-group="inputs" />
      <path d="M136 164C286 164 330 164 432 206" class="pipe-line" data-group="inputs" />
      <path d="M112 242C278 242 322 236 432 246" class="pipe-line" data-group="inputs" />
      <path d="M144 320C300 320 336 304 438 286" class="pipe-line" data-group="inputs" />
      <path d="M124 398C286 398 330 372 448 326" class="pipe-line" data-group="model" />
      <path d="M154 476C318 476 358 430 470 366" class="pipe-line" data-group="inputs" />

      <path d="M498 266C512 222 546 180 596 152" class="pipe-shell" />
      <path d="M498 266C542 256 576 254 620 260" class="pipe-shell" />
      <path d="M498 266C518 308 552 342 602 372" class="pipe-shell" />

      <path d="M498 266C512 222 546 180 596 152" class="pipe-line" data-group="attribution" />
      <path d="M498 266C542 256 576 254 620 260" class="pipe-line" data-group="attribution" />
      <path d="M498 266C518 308 552 342 602 372" class="pipe-line" data-group="attribution" />

      <path d="M712 266C820 266 870 266 932 222" class="pipe-shell" />
      <path d="M712 266C846 266 898 286 970 332" class="pipe-shell" />
      <path d="M712 266C862 266 930 266 1038 266" class="pipe-shell" />

      <path d="M712 266C820 266 870 266 932 222" class="pipe-line" data-group="attribution" />
      <path d="M712 266C846 266 898 286 970 332" class="pipe-line" data-group="attribution" />
      <path d="M712 266C862 266 930 266 1038 266" class="pipe-line strong" data-group="attribution" />
    </g>

    {inputNodes.map((node) => (
      <g data-group={node.group} class="diagram-group diagram-node">
        <circle cx={node.cx} cy={node.cy} r="33" class="node-shell" />
        <circle cx={node.cx} cy={node.cy} r="19" class="node-core" />
        <circle cx={node.cx + 45} cy={node.cy} r="6" class="junction-dot" />

        {node.key === "billing" && (
          <g class="node-icon">
            <rect x={node.cx - 9} y={node.cy - 7} width="18" height="14" rx="3" class="icon-fill" />
            <path d={`M${node.cx - 10} ${node.cy - 1}h20`} class="icon-line" />
          </g>
        )}
        {node.key === "identity" && (
          <g class="node-icon">
            <circle cx={node.cx} cy={node.cy - 4} r="5" class="icon-fill" />
            <path d={`M${node.cx - 8} ${node.cy + 10}c2-6 14-6 16 0`} class="icon-line" />
          </g>
        )}
        {node.key === "cicd" && (
          <g class="node-icon">
            <path d={`M${node.cx - 11} ${node.cy}h7l4-6 5 12 5-8h8`} class="icon-line" />
          </g>
        )}
        {node.key === "source" && (
          <g class="node-icon">
            <path d={`M${node.cx - 10} ${node.cy - 4}l-6 6 6 6`} class="icon-line" />
            <path d={`M${node.cx + 10} ${node.cy - 4}l6 6-6 6`} class="icon-line" />
          </g>
        )}
        {node.key === "model" && (
          <g class="node-icon">
            <circle cx={node.cx} cy={node.cy} r="7" class="icon-fill" />
            <path d={`M${node.cx} ${node.cy - 12}v24M${node.cx - 12} ${node.cy}h24`} class="icon-line" />
          </g>
        )}
        {node.key === "telemetry" && (
          <g class="node-icon">
            <path d={`M${node.cx - 12} ${node.cy + 8}l9-10 7 5 10-12`} class="icon-line" />
          </g>
        )}

        <text x={node.cx + 62} y={node.cy + 4} class="diagram-label">
          {node.label}
        </text>
      </g>
    ))}

    <g data-group="attribution" class="diagram-group">
      <circle cx="642" cy="266" r="78" class="engine-shell" />
      <circle cx="642" cy="266" r="50" class="engine-core" />
      <circle cx="642" cy="266" r="17" class="engine-kernel" />
      <path d="M642 196v-14M642 350v-14M572 266h-14M726 266h-14" class="engine-port" />
      <path d="M598 222c20 18 30 28 44 44" class="engine-port" />
      <path d="M686 222c-20 18-30 28-44 44" class="engine-port" />
      <path d="M598 310c20-18 30-28 44-44" class="engine-port" />
      <path d="M686 310c-20-18-30-28-44-44" class="engine-port" />
      <text x="642" y="258" text-anchor="middle" class="diagram-label diagram-label--center">
        Heuristic Attribution Engine
      </text>
      <text x="642" y="284" text-anchor="middle" class="diagram-copy">
        Reconciles fragmented signals
      </text>
    </g>

    <g data-group="attribution" class="diagram-group diagram-node">
      <circle cx="946" cy="222" r="40" class="output-shell" />
      <circle cx="946" cy="222" r="20" class="output-core" />
      <circle cx="1000" cy="266" r="11" class="junction-dot junction-dot--large" />
      <text x="946" y="172" text-anchor="middle" class="diagram-label">
        Attribution Layer
      </text>
      <text x="946" y="289" text-anchor="middle" class="diagram-copy">
        Confidence-scored graph
      </text>
    </g>

    <g data-group="attribution" class="diagram-group diagram-node">
      <rect x="1018" y="218" width="144" height="96" rx="30" class="dashboard-shell" />
      <rect x="1048" y="242" width="84" height="48" rx="18" class="dashboard-screen" />
      <path d="M1064 281v-16M1084 281v-28M1104 281v-12M1124 281v-22" class="icon-line" />
      <path d="M1060 288h68" class="icon-line" />
      <text x="1090" y="352" text-anchor="middle" class="diagram-label">
        Dashboard
      </text>
      <text x="1090" y="373" text-anchor="middle" class="diagram-copy">
        Attributable outputs
      </text>
    </g>
  </svg>

  <figcaption class="sr-only">
    Enterprise signals from billing, identity, CI/CD, source control, model usage, and telemetry converge into a heuristic attribution engine that produces confidence-scored attribution outputs for a dashboard.
  </figcaption>

  <div class="mt-6 flex flex-wrap items-center justify-center gap-3">
    <button type="button" class="diagram-keyword" data-keyword data-target="inputs">
      Data Inputs
    </button>
    <button type="button" class="diagram-keyword" data-keyword data-target="model">
      Model
    </button>
    <button type="button" class="diagram-keyword" data-keyword data-target="attribution">
      Attribution
    </button>
  </div>
</figure>

<script is:inline>
  const diagrams = document.querySelectorAll("[data-diagram]");

  for (const diagram of diagrams) {
    const keywords = diagram.querySelectorAll("[data-keyword]");
    const setActive = (value) => {
      diagram.setAttribute("data-active", value);
    };

    for (const keyword of keywords) {
      const target = keyword.getAttribute("data-target") || "none";
      const activate = () => setActive(target);
      const reset = () => setActive("none");

      keyword.addEventListener("mouseenter", activate);
      keyword.addEventListener("focus", activate);
      keyword.addEventListener("mouseleave", reset);
      keyword.addEventListener("blur", reset);
    }
  }
</script>

<style>
  .attribution-diagram {
    --diagram-border: #d7dee7;
    --diagram-muted: #6b7280;
    --diagram-text: #1a1a1a;
    --diagram-accent: #2d6a9f;
    --diagram-soft: rgba(45, 106, 159, 0.1);
    --diagram-dim-opacity: 0.18;
  }

  .pipe-shell {
    fill: none;
    stroke: rgba(215, 222, 231, 0.55);
    stroke-linecap: round;
    stroke-width: 18;
  }

  .pipe-line {
    fill: none;
    stroke: rgba(45, 106, 159, 0.18);
    stroke-linecap: round;
    stroke-width: 6;
    transition: opacity 160ms ease, stroke 160ms ease;
  }

  .pipe-line.strong {
    stroke-width: 7;
  }

  .node-shell,
  .output-shell,
  .dashboard-shell {
    fill: #ffffff;
    stroke: var(--diagram-border);
    stroke-width: 2;
  }

  .node-core,
  .output-core,
  .dashboard-screen {
    fill: rgba(45, 106, 159, 0.06);
    stroke: rgba(45, 106, 159, 0.28);
    stroke-width: 1.5;
  }

  .engine-shell {
    fill: #ffffff;
    stroke: rgba(45, 106, 159, 0.42);
    stroke-width: 3;
  }

  .engine-core {
    fill: rgba(45, 106, 159, 0.08);
    stroke: rgba(45, 106, 159, 0.4);
    stroke-width: 2;
  }

  .engine-kernel,
  .junction-dot,
  .junction-dot--large {
    fill: var(--diagram-accent);
    opacity: 0.22;
  }

  .junction-dot--large {
    opacity: 0.28;
  }

  .engine-port,
  .icon-line {
    fill: none;
    stroke: var(--diagram-accent);
    stroke-linecap: round;
    stroke-linejoin: round;
    stroke-width: 2;
  }

  .icon-fill {
    fill: rgba(45, 106, 159, 0.08);
    stroke: var(--diagram-accent);
    stroke-width: 1.5;
  }

  .diagram-group {
    transition: opacity 160ms ease, transform 160ms ease;
  }

  .diagram-label,
  .diagram-copy {
    fill: var(--diagram-text);
    opacity: 0;
    transition: opacity 160ms ease;
  }

  .diagram-label {
    font-size: 14px;
    font-weight: 600;
  }

  .diagram-label--center {
    font-size: 16px;
  }

  .diagram-copy {
    fill: var(--diagram-muted);
    font-size: 13px;
  }

  .diagram-keyword {
    border: 1px solid var(--diagram-border);
    border-radius: 999px;
    background: #ffffff;
    color: var(--diagram-muted);
    font-size: 0.95rem;
    font-weight: 500;
    line-height: 1;
    padding: 0.75rem 1rem;
    transition: border-color 150ms ease, color 150ms ease, background-color 150ms ease;
  }

  .diagram-keyword:hover,
  .diagram-keyword:focus-visible {
    border-color: var(--diagram-accent);
    color: var(--diagram-accent);
    outline: none;
  }

  .attribution-diagram[data-active="inputs"] [data-group="model"],
  .attribution-diagram[data-active="inputs"] [data-group="attribution"],
  .attribution-diagram[data-active="model"] [data-group="inputs"],
  .attribution-diagram[data-active="model"] [data-group="attribution"],
  .attribution-diagram[data-active="attribution"] [data-group="inputs"],
  .attribution-diagram[data-active="attribution"] [data-group="model"] {
    opacity: var(--diagram-dim-opacity);
  }

  .attribution-diagram[data-active="inputs"] [data-group="inputs"] .diagram-label,
  .attribution-diagram[data-active="inputs"] [data-group="inputs"] .diagram-copy,
  .attribution-diagram[data-active="model"] [data-group="model"] .diagram-label,
  .attribution-diagram[data-active="model"] [data-group="model"] .diagram-copy,
  .attribution-diagram[data-active="attribution"] [data-group="attribution"] .diagram-label,
  .attribution-diagram[data-active="attribution"] [data-group="attribution"] .diagram-copy {
    opacity: 1;
  }

  @media (max-width: 767px) {
    .attribution-diagram {
      max-width: 100%;
    }

    .diagram-keyword {
      font-size: 0.9rem;
      padding: 0.7rem 0.95rem;
    }
  }
</style>
