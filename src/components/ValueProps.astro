---
import { siteConfig } from "../content/site";

const { valueProps, valuePropsIntro } = siteConfig;
---

<section id="capabilities" class="border-b border-argmin-slate-300/70 bg-argmin-ice/60 px-6 py-16 md:py-24">
  <div class="section-shell grid gap-12 lg:grid-cols-[minmax(0,0.78fr)_minmax(0,1.22fr)] lg:gap-16">
    <div class="max-w-xl self-start lg:sticky lg:top-24">
      <p class="section-eyebrow">Capabilities</p>
      <h2 class="section-title max-w-none">What changes once attribution is real.</h2>
      <p class="section-copy">{valuePropsIntro}</p>
    </div>

    <div class="border-t border-argmin-slate-300/80">
      {valueProps.map((item) => (
        <article class="grid gap-4 border-b border-argmin-slate-300/80 py-7 md:py-8 lg:grid-cols-[72px_minmax(0,0.68fr)_minmax(0,1fr)] lg:gap-8">
          <p class="data-label text-argmin-azure">{item.label}</p>
          <h3 class="font-display text-[1.4rem] font-semibold tracking-[-0.03em] text-argmin-navy md:text-[1.7rem]">
            {item.title}
          </h3>
          <p class="max-w-[44ch] text-base leading-7 text-argmin-slate-700 md:text-[1.02rem]">
            {item.description}
          </p>
        </article>
      ))}
    </div>
  </div>
</section>
