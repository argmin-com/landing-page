---
import { siteConfig } from "../content/site";

const { valueProps } = siteConfig;
---

<section id="capabilities" class="border-b border-argmin-slate-300/70 bg-argmin-ice/45 px-6 py-16 md:py-24">
  <div class="section-shell">
    <div class="max-w-3xl js-reveal">
      <p class="section-eyebrow">Capabilities</p>
      <h2 class="section-title">Four things the system has to do well.</h2>
      <p class="section-copy">
        Buyers should understand the mechanism in one scan. The page should communicate function first and let the visual system stay calm.
      </p>
    </div>

    <div class="mt-12 border-y border-argmin-slate-300/80">
      {valueProps.map((item, index) => (
        <article
          class:list={[
            "grid gap-4 py-6 md:grid-cols-[72px_minmax(0,0.36fr)_minmax(0,0.64fr)] md:gap-8 js-reveal",
            index > 0 && "border-t border-argmin-slate-300/70",
          ]}
          data-reveal-delay={String(index * 70)}
        >
          <p class="font-mono text-sm text-argmin-slate-500">{item.label}</p>
          <h3 class="font-display text-xl font-semibold tracking-[-0.02em] text-argmin-azure">
            {item.title}
          </h3>
          <p class="text-base leading-7 text-argmin-slate-700">{item.description}</p>
        </article>
      ))}
    </div>
  </div>
</section>
