---
import { siteConfig } from "../content/site";

const { controlPoints, controlPointsIntro, controlPointsTitle } = siteConfig;
---

<section id="capabilities" class="border-b border-argmin-slate-300/70 bg-argmin-ice/50 px-6 py-16 md:py-24">
  <div class="section-shell grid gap-12 lg:grid-cols-[minmax(0,0.76fr)_minmax(0,1.24fr)] lg:gap-16">
    <div class="max-w-xl self-start lg:sticky lg:top-24">
      <p class="section-eyebrow">Control Points</p>
      <h2 class="section-title max-w-none">{controlPointsTitle}</h2>
      <p class="section-copy">{controlPointsIntro}</p>
    </div>

    <div class="border-t border-argmin-slate-300/80">
      {controlPoints.map((item) => (
        <article class="grid gap-4 border-b border-argmin-slate-300/80 py-7 md:py-8 lg:grid-cols-[72px_minmax(0,0.28fr)_minmax(0,0.72fr)] lg:gap-8">
          <div>
            <p class="data-label text-argmin-azure">{item.label}</p>
            <p class="mt-3 text-[0.72rem] font-semibold uppercase tracking-[0.18em] text-argmin-slate-500">
              {item.stage}
            </p>
          </div>
          <div>
            <h3 class="font-display text-[1.4rem] font-semibold tracking-[-0.03em] text-argmin-navy md:text-[1.7rem]">
              {item.title}
            </h3>
            <p class="mt-3 text-sm leading-6 text-argmin-slate-500 md:text-base">{item.outcome}</p>
          </div>
          <p class="max-w-[46ch] text-base leading-7 text-argmin-slate-700 md:text-[1.02rem]">
            {item.description}
          </p>
        </article>
      ))}
    </div>
  </div>
</section>
