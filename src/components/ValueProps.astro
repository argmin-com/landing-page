---
import { siteConfig } from "../content/site";

const { valueProps, valuePropsIntro } = siteConfig;
---

<section id="capabilities" class="border-b border-argmin-slate-300/70 bg-argmin-ice/40 px-6 py-16 md:py-24">
  <div class="section-shell">
    <p class="section-eyebrow">Capabilities</p>
    <h2 class="section-title max-w-none">What the product actually has to do.</h2>
    <p class="section-copy max-w-3xl">{valuePropsIntro}</p>

    <div class="mt-12 grid grid-cols-1 gap-8 md:grid-cols-2 md:gap-x-12 md:gap-y-10">
      {valueProps.map((item) => (
        <article class="border-t border-argmin-slate-300/80 pt-5">
          <p class="text-[0.72rem] font-semibold uppercase tracking-[0.18em] text-argmin-azure">
            {item.label}
          </p>
          <h3 class="font-display text-[1.25rem] font-semibold tracking-[-0.02em] text-argmin-navy">
            {item.title}
          </h3>
          <p class="mt-3 text-base leading-7 text-argmin-slate-700">{item.description}</p>
        </article>
      ))}
    </div>
  </div>
</section>
