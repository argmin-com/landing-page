---
import { siteConfig } from "../content/site";

const { problem } = siteConfig;
---

<section id="problem" class="border-b border-argmin-slate-300/70 bg-white px-6 py-16 md:py-24">
  <div class="section-shell grid gap-10 lg:grid-cols-[minmax(0,1.02fr)_minmax(0,0.98fr)] lg:gap-16">
    <div class="max-w-3xl">
      <div class="section-rule" aria-hidden="true"></div>
      <p class="section-eyebrow">The Problem</p>
      <h2 id="problem-heading" class="section-title max-w-none">{problem.title}</h2>
      <p class="section-copy">{problem.body}</p>
    </div>

    <ul class="space-y-5 lg:pt-12">
      {problem.constraints.map((constraint, index) => (
        <li class="border-t border-argmin-slate-300/80 pt-5">
          <p class="text-[0.72rem] font-semibold uppercase tracking-[0.18em] text-argmin-azure">
            Constraint {String(index + 1).padStart(2, "0")}
          </p>
          <p class="mt-3 text-base leading-7 text-argmin-slate-700">{constraint}</p>
        </li>
      ))}
    </ul>
  </div>
</section>
