---
import { siteConfig } from "../content/site";

const { problem } = siteConfig;
---

<section id="problem" class="border-b border-argmin-slate-300/70 bg-white px-6 py-16 md:py-24">
  <div class="section-shell">
    <div class="max-w-4xl">
      <div class="section-rule" aria-hidden="true"></div>
      <p class="section-eyebrow">Decision Gap</p>
      <h2 id="problem-heading" class="section-title max-w-none">{problem.title}</h2>
      <p class="section-copy max-w-[72ch]">{problem.intro}</p>
    </div>

    <div class="mt-12 grid gap-8 lg:grid-cols-2">
      <article class="rounded-[1.75rem] border border-argmin-slate-300/80 bg-argmin-slate-100/70 p-6 md:p-8">
        <p class="text-[0.72rem] font-semibold uppercase tracking-[0.18em] text-argmin-slate-500">
          {problem.beforeTitle}
        </p>
        <ul class="mt-5 space-y-4">
          {problem.before.map((item) => (
            <li class="grid grid-cols-[18px_minmax(0,1fr)] gap-3">
              <span class="mt-2 h-2.5 w-2.5 rounded-full bg-argmin-slate-500/50"></span>
              <p class="text-base leading-7 text-argmin-slate-700">{item}</p>
            </li>
          ))}
        </ul>
      </article>

      <article class="rounded-[1.75rem] border border-argmin-azure/20 bg-argmin-ice/60 p-6 md:p-8">
        <p class="text-[0.72rem] font-semibold uppercase tracking-[0.18em] text-argmin-azure">
          {problem.afterTitle}
        </p>
        <ul class="mt-5 space-y-4">
          {problem.after.map((item) => (
            <li class="grid grid-cols-[18px_minmax(0,1fr)] gap-3">
              <span class="mt-2 h-2.5 w-2.5 rounded-full bg-argmin-sky"></span>
              <p class="text-base leading-7 text-argmin-slate-700">{item}</p>
            </li>
          ))}
        </ul>
      </article>
    </div>
  </div>
</section>
