---
import { siteConfig } from "../content/site";

const { problem } = siteConfig;
---

<section id="problem" class="border-b border-argmin-slate-300/70 bg-white px-6 py-16 md:py-24">
  <div class="section-shell grid gap-10 lg:grid-cols-[minmax(0,0.92fr)_minmax(0,1.08fr)] lg:gap-16">
    <div class="js-reveal">
      <p class="section-eyebrow">The Problem</p>
      <h2 class="section-title">{problem.title}</h2>
    </div>

    <div class="js-reveal" data-reveal-delay="80">
      <p class="section-copy mt-0">{problem.body}</p>

      <div class="mt-10 border-y border-argmin-slate-300/80">
        {problem.constraints.map((constraint, index) => (
          <div class:list={["grid gap-3 py-5 md:grid-cols-[92px_1fr] md:gap-6", index > 0 && "border-t border-argmin-slate-300/70"]}>
            <p class="font-mono text-sm text-argmin-slate-500">Constraint</p>
            <p class="text-base leading-7 text-argmin-slate-700">{constraint}</p>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>
