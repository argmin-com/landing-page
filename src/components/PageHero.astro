---
interface Note {
  label: string;
  value: string;
}

interface Action {
  href: string;
  label: string;
  variant?: "primary" | "secondary";
}

interface Props {
  eyebrow: string;
  title: string;
  lede: string;
  notes?: Note[];
  actions?: Action[];
}

const { eyebrow, title, lede, notes = [], actions = [] } = Astro.props;
const hasNotes = notes.length > 0;
---

<section class="px-6 pb-10 pt-6 md:pb-14 md:pt-10">
  <div class="site-shell">
    <div class="page-hero-shell">
      <div class:list={["page-hero-grid lg:gap-16", hasNotes && "lg:grid-cols-[minmax(0,0.95fr)_minmax(0,0.55fr)]"]}>
        <div class="rise-in">
          <p class="section-kicker">{eyebrow}</p>
          <h1 class="page-title mt-5 max-w-5xl">{title}</h1>
          <p class="page-lede mt-6 max-w-3xl">{lede}</p>

          {actions.length > 0 && (
            <div class="mt-8 flex flex-wrap gap-3">
              {actions.map((action) => (
                <a
                  href={action.href}
                  class:list={[
                    action.variant === "secondary" ? "button-secondary" : "button-primary",
                  ]}
                >
                  {action.label}
                </a>
              ))}
            </div>
          )}
        </div>

        {hasNotes && (
          <div class="rise-in rise-in-delay-1">
            <dl class="page-note-grid">
              {notes.map((note) => (
                <div class="page-note">
                  <dt class="page-note-label">{note.label}</dt>
                  <dd class="page-note-value">{note.value}</dd>
                </div>
              ))}
            </dl>
          </div>
        )}
      </div>
    </div>
  </div>
</section>
