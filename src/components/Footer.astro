---
import { footerLinks, siteSummary } from "../content/site";

interface Props {
  compact?: boolean;
}

const { compact = false } = Astro.props;
---

{compact ? (
  <footer class="border-t border-argmin-border px-6 py-6 text-center text-sm text-argmin-dark">
    <p class="font-semibold tracking-[0.08em] text-argmin-dark">{siteSummary.brand}</p>
    <p class="mt-2">&copy; 2026 Argmin</p>
  </footer>
) : (
  <footer class="px-6 pb-10 pt-12 md:px-8 md:pb-12">
    <div class="site-shell section-divider pt-8">
      <div class="flex flex-col gap-6 md:flex-row md:items-center md:justify-between md:gap-8">
        <div class="flex items-center gap-4 text-sm text-argmin-light">
          <p class="site-wordmark text-argmin-dark">{siteSummary.brand}</p>
          <p>&copy; 2026 Argmin</p>
        </div>

        <nav aria-label="Footer">
          <ul class="flex flex-wrap items-center gap-x-6 gap-y-2">
            {footerLinks.map((link) => (
              <li>
                <a
                  href={link.href}
                  class="text-sm text-argmin-mid transition-colors duration-200 hover:text-argmin-dark focus-visible:text-argmin-dark focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-argmin-accent focus-visible:ring-offset-2 rounded-sm"
                >
                  {link.label}
                </a>
              </li>
            ))}
          </ul>
        </nav>

        <a href="/contact" class="button-primary text-sm">Request a Demo</a>
      </div>
    </div>
  </footer>
)}
