---
const sourceSystems = [
  { name: "Billing", detail: "Cost telemetry", accent: "Finance", icon: "billing" },
  { name: "Identity / HR", detail: "User-team map", accent: "Org", icon: "identity" },
  { name: "CI/CD", detail: "Deploy context", accent: "Runtime", icon: "cicd" },
  { name: "Source Control", detail: "Code ownership", accent: "Code", icon: "source" },
  { name: "Model Usage", detail: "Inference traces", accent: "AI", icon: "model" },
  { name: "Cloud Telemetry", detail: "Infra signals", accent: "Infra", icon: "telemetry" },
];

const engineStages = [
  {
    title: "Entity Resolution",
  },
  {
    title: "Namespace Mapping",
  },
  {
    title: "Probabilistic Joins",
  },
];

const graphNodes = [
  { label: "Person", x: "50%", y: "16%", icon: "person" },
  { label: "Team", x: "28%", y: "41%", icon: "team" },
  { label: "Service", x: "72%", y: "41%", icon: "service" },
  { label: "Workload", x: "50%", y: "68%", emphasized: true, icon: "workload" },
  { label: "Cost Event", x: "50%", y: "89%", warning: true, icon: "cost" },
];

const teamCosts = [
  { team: "Engineering", amount: "$42.5k", width: "85%" },
  { team: "Product", amount: "$18.2k", width: "40%" },
  { team: "Marketing", amount: "$9.9k", width: "20%" },
];
---

<div class="architecture-shell">
  <div class="mx-auto w-full max-w-6xl">
    <div class="architecture-heading">
      <h3 class="architecture-hero-title">
        <span class="architecture-hero-line">Your AI Spend is Invisible.</span>
        <span class="architecture-hero-line">We Make it Attributable.</span>
      </h3>
    </div>

    <div class="architecture-grid mt-8 grid grid-cols-1 gap-5 lg:grid-cols-6">
      <section class="layer-card layer-card--interactive lg:col-span-1">
        <div class="layer-initial">
          <div class="initial-symbol initial-symbol--collect">
            <svg viewBox="0 0 24 24" class="initial-icon">
              <rect x="4" y="7" width="16" height="10" rx="2"></rect>
              <path d="M7 11h10M7 14h5"></path>
            </svg>
          </div>
          <p class="layer-kicker">Collect</p>
          <h4 class="layer-title text-center">Source Systems</h4>
        </div>
        <div class="layer-detail">
          <div class="layer-header">
            <p class="layer-kicker">Collect</p>
          </div>
          <div class="source-grid">
            {sourceSystems.map((system) => (
              <article class="signal-item">
                <div class="signal-row">
                  <div class="signal-icon" aria-hidden="true">
                    {system.icon === "billing" && (
                      <svg viewBox="0 0 24 24" class="icon-svg">
                        <rect x="4" y="7" width="16" height="10" rx="2"></rect>
                        <path d="M7 11h10M7 14h5"></path>
                      </svg>
                    )}
                    {system.icon === "identity" && (
                      <svg viewBox="0 0 24 24" class="icon-svg">
                        <rect x="6" y="6" width="12" height="12" rx="2"></rect>
                        <circle cx="12" cy="11" r="2.3"></circle>
                        <path d="M9.4 16c.7-1.4 1.8-2.1 2.6-2.1.9 0 2 .7 2.6 2.1"></path>
                      </svg>
                    )}
                    {system.icon === "cicd" && (
                      <svg viewBox="0 0 24 24" class="icon-svg">
                        <path d="M7 6v5l-3 2 3 2v3"></path>
                        <path d="M17 6v5l3 2-3 2v3"></path>
                        <path d="M10 12h4"></path>
                      </svg>
                    )}
                    {system.icon === "source" && (
                      <svg viewBox="0 0 24 24" class="icon-svg">
                        <path d="M8 7h5a3 3 0 0 1 3 3v7"></path>
                        <path d="M8 17H5v-3"></path>
                        <circle cx="8" cy="7" r="1.6"></circle>
                        <circle cx="16" cy="17" r="1.6"></circle>
                      </svg>
                    )}
                    {system.icon === "model" && (
                      <svg viewBox="0 0 24 24" class="icon-svg">
                        <circle cx="12" cy="12" r="3.1"></circle>
                        <path d="M12 4v3M12 17v3M4 12h3M17 12h3"></path>
                      </svg>
                    )}
                    {system.icon === "telemetry" && (
                      <svg viewBox="0 0 24 24" class="icon-svg">
                        <path d="M5 16l4-5 3 2 5-7 2 2"></path>
                        <path d="M5 19h14"></path>
                      </svg>
                    )}
                  </div>
                  <div>
                    <div class="signal-badge">{system.accent}</div>
                    <p class="signal-title">{system.name}</p>
                    <p class="signal-copy">{system.detail}</p>
                  </div>
                </div>
              </article>
            ))}
          </div>
          <p class="layer-explainer">
            IDs and tags rarely line up.
          </p>
        </div>
      </section>

      <section class="layer-card layer-card--engine layer-card--interactive lg:col-span-3">
        <div class="layer-initial">
          <div class="initial-symbol initial-symbol--resolve-attribute">
            <svg viewBox="0 0 24 24" class="initial-icon">
              <circle cx="7" cy="8" r="1.7"></circle>
              <circle cx="12" cy="5.5" r="1.7"></circle>
              <circle cx="17" cy="8" r="1.7"></circle>
              <circle cx="12" cy="12.5" r="1.7"></circle>
              <rect x="10" y="16" width="4" height="4" rx="1"></rect>
              <path d="M8.4 8h2M13.6 8h2M12 7.1v3M8.6 14.2l2.3-1.2M15.4 14.2l-2.3-1.2M12 14.6v1.5"></path>
            </svg>
          </div>
          <p class="layer-kicker">Resolve and Attribute</p>
          <h4 class="layer-title text-center">Heuristic Engine</h4>
        </div>
        <div class="layer-detail">
          <div class="layer-header">
            <p class="layer-kicker">Resolve and Attribute</p>
          </div>
          <div class="resolve-attribute-grid">
            <div>
              <div class="space-y-4">
                {engineStages.map((stage) => (
                  <article class="engine-step">
                    <div class="engine-dot" aria-hidden="true"></div>
                    <div>
                      <p class="engine-title">{stage.title}</p>
                    </div>
                  </article>
                ))}
              </div>
              <div class="engine-status">
                <span class="engine-status-dot" aria-hidden="true"></span>
                <span>Confidence updating live</span>
              </div>
            </div>

            <div>
              <div class="graph-card graph-card--compact">
                <svg viewBox="0 0 320 320" class="graph-lines" aria-hidden="true">
                  <path d="M160 48L92 118" />
                  <path d="M160 48L228 118" />
                  <path d="M92 118L160 202" />
                  <path d="M228 118L160 202" />
                  <path d="M160 202L160 278" class="graph-lines--dashed" />
                </svg>
                {graphNodes.map((node) => (
                  <div
                    class:list={[
                      "graph-node",
                      node.emphasized && "graph-node--focus",
                      node.warning && "graph-node--warning",
                    ]}
                    style={`left:${node.x};top:${node.y};`}
                  >
                    <div class="graph-node-icon" aria-hidden="true">
                      {node.icon === "person" && (
                        <svg viewBox="0 0 24 24" class="icon-svg">
                          <circle cx="12" cy="8" r="3.3"></circle>
                          <path d="M6.8 18c.9-3 3.7-4.6 5.2-4.6S16.3 15 17.2 18"></path>
                        </svg>
                      )}
                      {node.icon === "team" && (
                        <svg viewBox="0 0 24 24" class="icon-svg">
                          <circle cx="9" cy="9" r="2.6"></circle>
                          <circle cx="15.5" cy="10.2" r="2.2"></circle>
                          <path d="M4.8 18c.7-2.5 2.8-3.9 4.3-3.9 1.3 0 3.3 1.1 4.1 3.1"></path>
                          <path d="M13 17.7c.5-1.7 2-2.8 3.4-2.8 1 0 2.4.7 3 2"></path>
                        </svg>
                      )}
                      {node.icon === "service" && (
                        <svg viewBox="0 0 24 24" class="icon-svg">
                          <rect x="6" y="6" width="12" height="4.2" rx="1.2"></rect>
                          <rect x="6" y="13.8" width="12" height="4.2" rx="1.2"></rect>
                          <path d="M9 8.1h.01M9 15.9h.01"></path>
                        </svg>
                      )}
                      {node.icon === "workload" && (
                        <svg viewBox="0 0 24 24" class="icon-svg">
                          <path d="M7 7h10v10H7z"></path>
                          <path d="M10 4v3M14 4v3M10 17v3M14 17v3M17 10h3M17 14h3M4 10h3M4 14h3"></path>
                        </svg>
                      )}
                      {node.icon === "cost" && (
                        <svg viewBox="0 0 24 24" class="icon-svg">
                          <path d="M12 5v14"></path>
                          <path d="M15.2 8.2c-.6-.9-1.8-1.5-3.2-1.5-2 0-3.5 1.1-3.5 2.7 0 1.8 1.4 2.4 3.8 2.9 2 .5 3.2.9 3.2 2.5 0 1.5-1.4 2.7-3.5 2.7-1.7 0-3-.6-3.8-1.8"></path>
                        </svg>
                      )}
                    </div>
                    <span>{node.label}</span>
                  </div>
                ))}
              </div>
              <div class="confidence-panel">
                <div class="confidence-row">
                  <span>Confidence score</span>
                  <span>94.2%</span>
                </div>
                <div class="confidence-bar" aria-hidden="true">
                  <div class="confidence-bar-fill"></div>
                </div>
              </div>
            </div>
          </div>
          <p class="layer-explainer layer-explainer--wide">
            Turns fragmented signals into a confidence-scored ownership graph.
          </p>
        </div>
      </section>

      <section class="layer-card layer-card--interactive lg:col-span-2">
        <div class="layer-initial">
          <div class="initial-symbol initial-symbol--explain">
            <svg viewBox="0 0 24 24" class="initial-icon">
              <rect x="5" y="5.5" width="14" height="11" rx="2"></rect>
              <path d="M8 18.5h8M9 9.5v4M12 8v5.5M15 10.5v3"></path>
            </svg>
          </div>
          <p class="layer-kicker">Interface</p>
          <h4 class="layer-title text-center">Control Dashboard</h4>
        </div>
        <div class="layer-detail">
          <div class="layer-header">
            <p class="layer-kicker">Interface</p>
          </div>
          <div class="space-y-4">
            <article class="controller-card">
              <div class="controller-row">
                <p class="controller-kicker">Spend Forecast</p>
                <p class="controller-metric">+30 days</p>
              </div>
              <div class="forecast-card" aria-hidden="true">
                <svg viewBox="0 0 100 100" preserveAspectRatio="none" class="forecast-svg">
                  <path d="M0 80 Q25 70, 50 40 T100 10" class="forecast-line forecast-line--projected"></path>
                  <path d="M0 80 Q25 75, 50 65 T100 55" class="forecast-line forecast-line--current"></path>
                </svg>
              </div>
              <div class="controller-axis">
                <span>Current</span>
                <span>Projected</span>
              </div>
            </article>

            <article class="controller-card">
              <div class="controller-row">
                <p class="controller-kicker">AI Costs per Team</p>
                <p class="controller-metric">Resolved</p>
              </div>
              <div class="team-costs">
                {teamCosts.map((item) => (
                  <div class="team-cost-row">
                    <div class="team-cost-labels">
                      <span>{item.team}</span>
                      <strong>{item.amount}</strong>
                    </div>
                    <div class="team-cost-bar" aria-hidden="true">
                      <div class="team-cost-fill" style={`width:${item.width};`}></div>
                    </div>
                  </div>
                ))}
              </div>
            </article>

            <article class="controller-card controller-card--accent">
              <div class="controller-row">
                <p class="controller-kicker">Optimization Potential</p>
                <p class="controller-savings">-$12.4k</p>
              </div>
              <p class="controller-title">Suggested action</p>
              <p class="controller-copy">
                Route, budget, or warn based on confidence.
              </p>
            </article>
          </div>
          <p class="layer-explainer">
            Forecast spend, show team costs, and surface actions.
          </p>
        </div>
      </section>
    </div>
  </div>
</div>

<style>
  .architecture-shell {
    position: relative;
    overflow: hidden;
    padding: 0;
  }

  .architecture-heading {
    max-width: none;
    margin-bottom: 0.5rem;
  }

  .architecture-hero-title {
    font-family: var(--font-display);
    font-size: clamp(2.8rem, 5.6vw, 5rem);
    line-height: 0.93;
    font-weight: 700;
    letter-spacing: -0.05em;
    color: rgb(255 255 255);
  }

  .architecture-hero-line {
    display: block;
    white-space: nowrap;
  }

  .architecture-shell::before {
    content: "";
    position: absolute;
    inset: auto -14% 6% auto;
    width: 22rem;
    height: 22rem;
    border-radius: 999px;
    background:
      radial-gradient(circle, rgb(93 168 255 / 0.14) 0%, rgb(93 168 255 / 0.02) 56%, transparent 72%);
    pointer-events: none;
  }

  .layer-card {
    position: relative;
    overflow: hidden;
    border: 1px solid rgb(215 222 232);
    border-radius: 1.75rem;
    background: linear-gradient(180deg, rgb(255 255 255) 0%, rgb(248 248 246) 100%);
    padding: 1.45rem;
    box-shadow:
      0 1px 0 rgb(255 255 255 / 0.8) inset,
      0 14px 36px rgb(15 23 42 / 0.05);
    min-height: 100%;
    transition:
      box-shadow 180ms ease,
      border-color 180ms ease,
      transform 180ms ease;
  }

  .layer-card--engine::before {
    content: "";
    position: absolute;
    inset: -12% -18% auto auto;
    width: 12rem;
    height: 12rem;
    border-radius: 999px;
    background: radial-gradient(circle, rgb(93 168 255 / 0.1) 0%, transparent 70%);
    pointer-events: none;
  }

  .layer-header {
    position: relative;
    z-index: 1;
    margin-bottom: 1rem;
  }

  .layer-initial,
  .layer-detail {
    position: relative;
    z-index: 1;
  }

  .layer-initial {
    display: flex;
    min-height: 32rem;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    padding: 1.25rem;
    text-align: center;
    transition:
      opacity 220ms ease,
      transform 220ms ease;
  }

  .layer-detail {
    position: absolute;
    inset: 0;
    display: flex;
    flex-direction: column;
    padding: 1.15rem;
    opacity: 0;
    pointer-events: none;
    transform: translateY(12px) scale(0.98);
    transition:
      opacity 260ms ease,
      transform 260ms ease;
  }

  .initial-symbol {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 5.5rem;
    height: 5.5rem;
    margin-bottom: 1.5rem;
    border-radius: 999px;
    background: rgb(93 168 255 / 0.08);
    color: rgb(61 141 234);
    box-shadow: inset 0 0 0 1px rgb(93 168 255 / 0.12);
  }

  .initial-symbol--attribute,
  .initial-symbol--resolve,
  .initial-symbol--resolve-attribute {
    background: rgb(93 168 255 / 0.06);
  }

  .resolve-attribute-grid {
    display: grid;
    gap: 0.9rem;
    grid-template-columns: minmax(0, 0.9fr) minmax(0, 1.1fr);
    align-items: start;
  }

  .initial-icon {
    width: 2rem;
    height: 2rem;
    stroke: currentColor;
    fill: none;
    stroke-width: 1.7;
    stroke-linecap: round;
    stroke-linejoin: round;
  }

  .layer-kicker {
    font-size: 0.72rem;
    font-weight: 700;
    letter-spacing: 0.26em;
    text-transform: uppercase;
    color: rgb(93 168 255);
  }

  .layer-title {
    margin-top: 0.45rem;
    font-size: 1.4rem;
    line-height: 1.1;
    font-weight: 700;
    letter-spacing: -0.04em;
    color: rgb(17 17 17);
  }

  .engine-step,
  .controller-card {
    border: 1px solid rgb(215 222 232);
    border-radius: 1.1rem;
    background: rgb(252 253 255 / 0.94);
  }

  .source-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 0.5rem;
  }

  .signal-item {
    min-width: 0;
    padding: 0.1rem 0;
  }

  .signal-row {
    display: flex;
    align-items: flex-start;
    gap: 0.5rem;
  }

  .signal-icon {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 1.5rem;
    height: 1.5rem;
    flex: none;
    border-radius: 0.5rem;
    background: rgb(93 168 255 / 0.09);
    color: rgb(61 141 234);
  }

  .signal-badge {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    border-radius: 999px;
    background: rgb(93 168 255 / 0.1);
    color: rgb(61 141 234);
    font-size: 0.46rem;
    font-weight: 700;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    padding: 0.16rem 0.28rem;
  }

  .signal-title,
  .engine-title,
  .controller-title {
    color: rgb(17 17 17);
    font-weight: 650;
  }

  .signal-title {
    margin-top: 0.16rem;
    font-size: 0.72rem;
    line-height: 1.15;
  }

  .signal-copy,
  .controller-copy,
  .layer-explainer {
    color: rgb(17 17 17 / 0.72);
    line-height: 1.55;
  }

  .signal-copy {
    margin-top: 0.14rem;
    font-size: 0.6rem;
    line-height: 1.25;
  }

  .layer-explainer {
    margin-top: auto;
    padding-top: 0.95rem;
    font-size: 0.96rem;
    line-height: 1.45;
    text-align: center;
    align-self: center;
    max-width: 24rem;
  }

  .layer-explainer--wide {
    max-width: 42rem;
  }

  .engine-step {
    display: flex;
    gap: 0.7rem;
    align-items: flex-start;
    padding: 0.72rem 0.8rem;
    position: relative;
    z-index: 1;
  }

  .engine-dot,
  .engine-status-dot {
    flex: none;
    border-radius: 999px;
    background: rgb(93 168 255);
    box-shadow: 0 0 0 6px rgb(93 168 255 / 0.12);
  }

  .engine-dot {
    width: 0.5rem;
    height: 0.5rem;
    margin-top: 0.38rem;
  }

  .engine-title {
    font-size: 0.82rem;
    line-height: 1.25;
  }

  .engine-status {
    position: relative;
    z-index: 1;
    margin-top: 0.7rem;
    display: inline-flex;
    align-items: center;
    gap: 0.45rem;
    border-radius: 999px;
    border: 1px solid rgb(93 168 255 / 0.24);
    background: rgb(93 168 255 / 0.08);
    padding: 0.42rem 0.62rem;
    color: rgb(17 17 17 / 0.82);
    font-size: 0.58rem;
    font-weight: 700;
    letter-spacing: 0.14em;
    text-transform: uppercase;
  }

  .engine-status-dot {
    width: 0.35rem;
    height: 0.35rem;
    animation: architecture-pulse 2.8s ease-in-out infinite;
  }

  .graph-card {
    position: relative;
    margin-top: 0.35rem;
    min-height: 13rem;
    overflow: hidden;
    border-radius: 1.25rem;
    border: 1px solid rgb(215 222 232);
    background:
      radial-gradient(circle at top, rgb(93 168 255 / 0.06), transparent 45%),
      linear-gradient(180deg, rgb(248 248 246) 0%, rgb(255 255 255) 100%);
  }

  .graph-card--compact {
    min-height: 12rem;
  }

  .graph-lines {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    stroke: rgb(93 168 255 / 0.38);
    stroke-width: 1.5;
  }

  .graph-lines--dashed {
    stroke-dasharray: 5 6;
  }

  .graph-node {
    position: absolute;
    transform: translate(-50%, -50%);
    display: inline-flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    min-width: 3.8rem;
    padding: 0.34rem 0.5rem 0.38rem;
    border-radius: 0.9rem;
    border: 1px solid rgb(215 222 232);
    background: rgb(255 255 255 / 0.96);
    color: rgb(17 17 17 / 0.78);
    box-shadow: 0 10px 24px rgb(15 23 42 / 0.06);
    font-size: 0.52rem;
    font-weight: 700;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    text-align: center;
  }

  .graph-node-icon {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 1.45rem;
    height: 1.45rem;
    margin-bottom: 0.18rem;
    border-radius: 999px;
    background: rgb(255 255 255);
    box-shadow: 0 0 0 1px rgb(215 222 232);
    color: rgb(17 17 17);
  }

  .icon-svg {
    width: 0.72rem;
    height: 0.72rem;
    stroke: currentColor;
    fill: none;
    stroke-width: 1.8;
    stroke-linecap: round;
    stroke-linejoin: round;
  }

  .graph-node--focus {
    border-color: rgb(93 168 255 / 0.58);
    background: rgb(93 168 255 / 0.08);
    color: rgb(17 17 17);
    box-shadow:
      0 0 0 6px rgb(93 168 255 / 0.1),
      0 10px 24px rgb(15 23 42 / 0.08);
  }

  .graph-node--warning {
    border-color: rgb(17 17 17 / 0.18);
    background: rgb(17 17 17 / 0.06);
  }

  .graph-node--focus .graph-node-icon {
    background: rgb(255 255 255);
    box-shadow: 0 0 0 1px rgb(93 168 255 / 0.35);
  }

  .graph-node--warning .graph-node-icon {
    box-shadow: 0 0 0 1px rgb(255 102 102 / 0.35);
    color: rgb(255 102 102);
  }

  .confidence-panel {
    margin-top: 0.55rem;
  }

  .confidence-row {
    display: flex;
    align-items: center;
    justify-content: space-between;
    color: rgb(17 17 17 / 0.72);
    font-size: 0.58rem;
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
  }

  .confidence-bar {
    margin-top: 0.35rem;
    height: 0.32rem;
    overflow: hidden;
    border-radius: 999px;
    background: rgb(215 222 232 / 0.72);
  }

  .confidence-bar-fill {
    height: 100%;
    width: 94.2%;
    border-radius: 999px;
    background: linear-gradient(90deg, rgb(93 168 255) 0%, rgb(61 141 234) 100%);
  }

  .controller-card {
    padding: 0.7rem;
  }

  .controller-card--accent {
    background: linear-gradient(180deg, rgb(93 168 255 / 0.08) 0%, rgb(255 255 255 / 0.96) 100%);
    border-color: rgb(93 168 255 / 0.24);
  }

  .controller-kicker {
    color: rgb(17 17 17 / 0.62);
    font-size: 0.55rem;
    font-weight: 700;
    letter-spacing: 0.16em;
    text-transform: uppercase;
  }

