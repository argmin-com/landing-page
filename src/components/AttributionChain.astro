---
import { siteConfig } from "../content/site";
import ConfidenceBadge from "./ConfidenceBadge.astro";

const { attributionLayers } = siteConfig;
---

<div class="surface-panel p-6 md:p-8">
  <div class="border-b border-argmin-slate-300/80 pb-4">
    <p class="section-eyebrow">Attribution Record</p>
    <h3 class="mt-3 font-display text-[1.45rem] font-semibold tracking-[-0.03em] text-argmin-navy">
      Confidence stays visible at each hop.
    </h3>
    <p class="mt-3 max-w-[46ch] text-sm leading-7 text-argmin-slate-700">
      The system resolves each request through the operational chain that owns it instead of hiding
      uncertainty behind a single number.
    </p>
  </div>

  <ol class="mt-6 space-y-4">
    {attributionLayers.map((layer) => (
      <li class="grid gap-3 border-b border-argmin-slate-300/70 pb-4 last:border-none last:pb-0 md:grid-cols-[minmax(0,0.28fr)_minmax(0,1fr)_auto] md:items-center">
        <div>
          <p class="text-[0.72rem] font-semibold uppercase tracking-[0.18em] text-argmin-slate-500">
            {layer.label}
          </p>
        </div>
        <p class="text-sm leading-7 text-argmin-slate-700 md:text-base">{layer.value}</p>
        <ConfidenceBadge value={layer.confidence} tone={layer.tone} />
      </li>
    ))}
  </ol>
</div>
