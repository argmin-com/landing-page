---
import { siteConfig } from "../content/site";
import AttributionChain from "./AttributionChain.astro";

const { howItWorksTitle, howItWorksIntro, steps } = siteConfig;
---

<section id="how" class="border-b border-argmin-slate-300/70 bg-white px-6 py-16 md:py-24">
  <div class="section-shell grid gap-12 lg:grid-cols-[minmax(0,0.9fr)_minmax(0,1.1fr)] lg:gap-16">
    <div>
      <p class="section-eyebrow">How It Works</p>
      <h2 class="section-title max-w-none">{howItWorksTitle}</h2>
      <p class="section-copy max-w-3xl">{howItWorksIntro}</p>

      <div class="mt-10 space-y-6">
        {steps.map((step) => (
          <article class="border-t border-argmin-slate-300/80 pt-5">
            <p class="text-[0.72rem] font-semibold uppercase tracking-[0.18em] text-argmin-azure">
              {step.number}
            </p>
            <h3 class="mt-3 font-display text-[1.3rem] font-semibold tracking-[-0.02em] text-argmin-navy">
              {step.title}
            </h3>
            <p class="mt-3 text-base leading-7 text-argmin-slate-700">{step.description}</p>
          </article>
        ))}
      </div>
    </div>

    <AttributionChain />
  </div>
</section>
