---
const steps = [
  {
    number: "01",
    title: "Measure",
    description:
      "Connect your existing systems—cloud billing, API gateways, identity providers, CI/CD, and HR.  Argmin reads data directly, with no agents to install and no code changes required.",
  },
  {
    number: "02",
    title: "Attribute",
    description:
      "Every AI request is mapped end-to-end—linking the model, service, code owner, identity, team, and budget. Our engine reconstructs usage from fragmented data, with confidence scores and full auditability.",
  },
  {
    number: "03",
    title: "Intervene",
    description:
      "Act on requests in real time. Route to lower-cost equivalent models, apply team-level budgets, and simulate cost impact pre-deploy. Advisory by default. Enforcement is opt-in.",
  },
];
---

<section id="how" class="px-6 py-10 md:py-14">
  <div class="mx-auto max-w-6xl">
    <h2 class="text-center text-sm font-semibold uppercase tracking-[0.24em] text-argmin-dark">How It Works</h2>
    <div class="mt-8 grid grid-cols-1 gap-10 md:grid-cols-3 md:gap-12">
      {steps.map((step) => (
        <article class="p-6 md:p-8">
          <p class="text-sm font-semibold tracking-[0.2em] text-argmin-dark">{step.number}</p>
          <h3 class="mt-4 text-xl font-bold text-argmin-dark">{step.title}</h3>
          <p class="mt-3 text-base leading-relaxed text-argmin-dark">{step.description}</p>
        </article>
      ))}
    </div>
  </div>
</section>
