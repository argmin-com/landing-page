---
import { siteConfig } from "../content/site";

interface Props {
  formspreeUrl?: string;
}

const { contactEmail, contact } = siteConfig;
const { formspreeUrl = "" } = Astro.props;
const endpoint = formspreeUrl.trim();
const hasEndpoint = endpoint.length > 0;
---

<section id="contact" class="scroll-mt-8 border-t border-white/10 bg-argmin-navy px-6 py-16 md:py-24">
  <div class="section-shell grid gap-12 lg:grid-cols-[minmax(0,0.9fr)_minmax(0,1.1fr)] lg:gap-16">
    <div class="max-w-xl">
      <p class="section-eyebrow section-eyebrow-inverse">Contact</p>
      <h2 id="contact-heading" class="section-title max-w-none text-white">{contact.title}</h2>
      <p class="section-copy section-copy-inverse">
        {contact.intro}{" "}
        You can also reach us directly at
        <a
          class="font-medium text-white underline decoration-from-font underline-offset-4 hover:text-argmin-sky"
          href={`mailto:${contactEmail}`}
        >
          {contactEmail}
        </a>.
      </p>

      <dl class="mt-10 border-y border-white/12">
        {contact.details.map((detail, index) => (
          <div
            class:list={[
              "grid gap-3 py-5 md:grid-cols-[116px_1fr] md:gap-6",
              index > 0 && "border-t border-white/10",
            ]}
          >
            <dt class="text-[0.72rem] font-semibold uppercase tracking-[0.18em] text-white/50">
              {detail.label}
            </dt>
            <dd class="text-base leading-7 text-white/80">{detail.value}</dd>
          </div>
        ))}
      </dl>
    </div>

    <div class="surface-panel p-6 md:p-8 lg:p-10">
      <div class="border-b border-argmin-slate-300/80 pb-5">
        <p class="section-eyebrow">Start with the problem</p>
        <p class="mt-3 max-w-[42ch] text-sm leading-7 text-argmin-slate-700">
          A short note is enough. We respond directly when there is a real attribution, budget, or governance issue to untangle.
        </p>
      </div>

      <div data-form-container aria-live="polite">
        <form
          id="contact-form"
          class="space-y-4 pt-6"
          aria-labelledby="contact-heading"
          data-contact-form
          data-endpoint={endpoint}
          data-form-configured={String(hasEndpoint)}
          data-default-label={hasEndpoint ? contact.submitLabel : contact.unavailableLabel}
          data-sending-label={contact.sendingLabel}
          data-success-message={contact.successMessage}
        >
          <div>
            <label for="name" class="field-label">Name</label>
            <input
              id="name"
              name="name"
              type="text"
              required
              autocomplete="name"
              placeholder="Your name"
              class="field-input"
            />
          </div>

          <div>
            <label for="email" class="field-label">Email</label>
            <input
              id="email"
              name="email"
              type="email"
              required
              autocomplete="email"
              placeholder="work@company.com"
              class="field-input"
            />
          </div>

          <div>
            <label for="company" class="field-label">Company</label>
            <input
              id="company"
              name="company"
              type="text"
              required
              autocomplete="organization"
              placeholder="Company name"
              class="field-input"
            />
          </div>

          <div>
            <label for="message" class="field-label">Message</label>
            <textarea
              id="message"
              name="message"
              rows="5"
              placeholder="Tell us about your AI spend challenge"
              class="field-input min-h-[148px] resize-y"
            ></textarea>
          </div>

          <input type="text" id="gotcha" name="_gotcha" class="sr-only" tabindex="-1" autocomplete="off" />

          <button
            data-submit-button
            id="submit-btn"
            type="button"
            disabled={!hasEndpoint}
            aria-describedby={!hasEndpoint ? "form-config-error" : undefined}
            class="primary-button flex w-full items-center justify-center px-6 py-3.5 text-base disabled:cursor-not-allowed disabled:bg-argmin-slate-100 disabled:text-argmin-slate-500 sm:w-auto"
          >
            {hasEndpoint ? contact.submitLabel : contact.unavailableLabel}
          </button>

          <p id="form-config-error" hidden={hasEndpoint} class="text-sm leading-6 text-argmin-slate-500">
            {contact.unavailableMessage}{" "}
            <a class="font-medium text-argmin-azure underline decoration-from-font underline-offset-4" href={`mailto:${contactEmail}`}>
              {contactEmail}
            </a>.
          </p>

          <p data-form-error hidden role="alert" class="text-sm leading-6 text-argmin-error">
            {contact.errorMessage}{" "}
            <a class="font-medium text-argmin-azure underline decoration-from-font underline-offset-4" href={`mailto:${contactEmail}`}>
              {contactEmail}
            </a>.
          </p>
        </form>
      </div>

      <noscript>
        <p class="mt-6 text-sm leading-6 text-argmin-slate-500">
          JavaScript is required for the hosted form flow. Please email{" "}
          <a class="font-medium text-argmin-azure underline decoration-from-font underline-offset-4" href={`mailto:${contactEmail}`}>
            {contactEmail}
          </a>.
        </p>
      </noscript>
    </div>
  </div>
</section>
