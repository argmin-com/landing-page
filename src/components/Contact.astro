---
import ContactForm from "./ContactForm.astro";
import { CONTACT_EMAIL } from "../lib/contact";

interface Props {
  formspreeUrl?: string;
  title?: string;
  intro?: string;
}

const {
  formspreeUrl = "",
  title = "Talk to Us",
  intro = "We are working with a limited number of design partners. If your team is spending on AI inference and cannot track what it is spending, who is spending it, or whether it is money well spent, we should talk.",
} = Astro.props;
const contactEmailHref = `mailto:${CONTACT_EMAIL}`;
---

<section id="contact" class="scroll-mt-6 px-6 py-10 md:py-14">
  <div class="mx-auto max-w-2xl">
    <h2 id="contact-heading" class="text-sm font-semibold uppercase tracking-[0.24em] text-argmin-dark">{title}</h2>
    <p class="mt-4 text-lg leading-relaxed text-argmin-dark">
      {intro}{" "}
      You can also reach us directly at
      <a class="font-medium text-argmin-dark underline decoration-from-font underline-offset-4" href={contactEmailHref}>{CONTACT_EMAIL}</a>.
    </p>

    <ContactForm formspreeUrl={formspreeUrl} headingId="contact-heading" />
  </div>
</section>
