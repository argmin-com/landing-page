---
import { siteConfig } from "../content/site";

interface Props {
  formspreeUrl?: string;
  title?: string;
  intro?: string;
}

const { contactEmail, contact } = siteConfig;
const {
  formspreeUrl = "",
  title = contact.title,
  intro = contact.intro,
} = Astro.props;
const endpoint = formspreeUrl.trim();
const hasEndpoint = endpoint.length > 0;
---

<section id="contact" class="scroll-mt-24 bg-argmin-ice px-6 py-16 md:py-24">
  <div class="section-shell grid gap-12 lg:grid-cols-[minmax(0,0.9fr)_minmax(0,1.1fr)] lg:gap-16">
    <div class="max-w-xl js-reveal">
      <p class="section-eyebrow">Contact</p>
      <h2 id="contact-heading" class="section-title">{title}</h2>
      <p class="section-copy">
        {intro}{" "}
        You can also reach us directly at
        <a
          class="font-medium text-argmin-azure underline decoration-from-font underline-offset-4 hover:text-argmin-sky"
          href={`mailto:${contactEmail}`}
        >
          {contactEmail}
        </a>.
      </p>

      <div class="mt-10 border-y border-argmin-slate-300/80">
        <div class="grid gap-3 py-5 md:grid-cols-[112px_1fr] md:gap-6">
          <p class="font-mono text-sm text-argmin-slate-700">Scope</p>
          <p class="text-base leading-7 text-argmin-slate-700">
            Enterprise AI attribution, optimization, and intervention at request time.
          </p>
        </div>
        <div class="grid gap-3 border-t border-argmin-slate-300/70 py-5 md:grid-cols-[112px_1fr] md:gap-6">
          <p class="font-mono text-sm text-argmin-slate-700">Posture</p>
          <p class="text-base leading-7 text-argmin-slate-700">
            Deploys inside customer trust boundaries with read-only connectors and fail-open defaults.
          </p>
        </div>
        <div class="grid gap-3 border-t border-argmin-slate-300/70 py-5 md:grid-cols-[112px_1fr] md:gap-6">
          <p class="font-mono text-sm text-argmin-slate-700">Response</p>
          <p class="text-base leading-7 text-argmin-slate-700">
            We respond directly when there is a real inference attribution problem to solve.
          </p>
        </div>
      </div>
    </div>

    <div class="surface-panel p-6 md:p-8 js-reveal" data-reveal-delay="120">
      <div data-form-container aria-live="polite">
        <form
          id="contact-form"
          class="space-y-4"
          aria-labelledby="contact-heading"
          data-contact-form
          data-endpoint={endpoint}
          data-form-configured={String(hasEndpoint)}
          data-default-label={hasEndpoint ? contact.submitLabel : contact.unavailableLabel}
          data-sending-label={contact.sendingLabel}
          data-success-message={contact.successMessage}
          action={hasEndpoint ? endpoint : undefined}
          method="post"
        >
          <div>
            <label for="name" class="field-label">Name</label>
            <input
              id="name"
              name="name"
              type="text"
              required
              placeholder="Your name"
              class="field-input"
            />
          </div>

          <div>
            <label for="email" class="field-label">Email</label>
            <input
              id="email"
              name="email"
              type="email"
              required
              placeholder="work@company.com"
              class="field-input"
            />
          </div>

          <div>
            <label for="company" class="field-label">Company</label>
            <input
              id="company"
              name="company"
              type="text"
              required
              placeholder="Company name"
              class="field-input"
            />
          </div>

          <div>
            <label for="message" class="field-label">Message</label>
            <textarea
              id="message"
              name="message"
              rows="5"
              placeholder="Tell us about your AI spend challenge"
              class="field-input min-h-[148px] resize-y"
            ></textarea>
          </div>

          <input type="text" id="gotcha" name="_gotcha" class="hidden" tabindex="-1" autocomplete="off" />

          <button
            data-submit-button
            id="submit-btn"
            type="submit"
            disabled={!hasEndpoint}
            aria-describedby={!hasEndpoint ? "form-config-error" : undefined}
            class="primary-button flex w-full items-center justify-center px-6 py-3.5 text-base disabled:cursor-not-allowed disabled:bg-argmin-slate-100 disabled:text-argmin-slate-500"
          >
            {hasEndpoint ? contact.submitLabel : contact.unavailableLabel}
          </button>

          <p
            id="form-config-error"
            hidden={hasEndpoint}
            class="text-sm leading-6 text-argmin-slate-500"
          >
            {contact.unavailableMessage}{" "}
            <a class="font-medium text-argmin-azure underline decoration-from-font underline-offset-4" href={`mailto:${contactEmail}`}>
              {contactEmail}
            </a>.
          </p>

          <p
            data-form-error
            hidden
            role="alert"
            class="text-sm leading-6 text-argmin-error"
          >
            {contact.errorMessage}{" "}
            <a class="font-medium text-argmin-azure underline decoration-from-font underline-offset-4" href={`mailto:${contactEmail}`}>
              {contactEmail}
            </a>.
          </p>
        </form>
      </div>

      <noscript>
        {!hasEndpoint && (
          <p class="mt-6 text-sm leading-6 text-argmin-slate-500">
            {contact.unavailableMessage}{" "}
            <a class="font-medium text-argmin-azure underline decoration-from-font underline-offset-4" href={`mailto:${contactEmail}`}>
              {contactEmail}
            </a>.
          </p>
        )}
        {hasEndpoint && (
          <p class="mt-6 text-sm leading-6 text-argmin-slate-500">
            JavaScript is disabled. The form will still submit, but you will be taken to the hosted confirmation page.
          </p>
        )}
      </noscript>
    </div>
  </div>
</section>
