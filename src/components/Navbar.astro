---
import ThemeToggle from "./ThemeToggle.astro";
import { primaryNav } from "../content/site";

interface Props {
  hiddenUntilReveal?: boolean;
}

const { hiddenUntilReveal = false } = Astro.props;
const navClass = hiddenUntilReveal ? "home-nav-hidden" : "";
const pathname = Astro.url.pathname;

const normalizePath = (value: string) => {
  if (value === "/") return "/";

  const normalized = value.replace(/\/+$/, "");
  return normalized.length > 0 ? normalized : "/";
};

const currentPath = normalizePath(pathname);
const isActive = (href: string) => currentPath === normalizePath(href);
---

<header class:list={["px-6 pb-6 pt-8 md:px-8 md:pt-10", navClass]}>
  <div class="site-shell">
    <div class="flex items-center justify-between gap-3 rounded-[2rem] border border-argmin-border bg-argmin-surface/82 px-5 py-3 shadow-[var(--page-shadow-soft)] backdrop-blur md:gap-5 md:px-6">
      <a
        href="/"
        class="site-wordmark shrink-0 text-argmin-dark transition-opacity duration-200 hover:opacity-72"
      >
        Argmin
      </a>

      <div class="hidden min-[1080px]:flex min-[1080px]:items-center min-[1080px]:gap-6">
        <nav aria-label="Primary">
          <ul class="flex items-center gap-5">
            {primaryNav.map((item) => (
              <li>
                <a
                  href={item.href}
                  aria-current={isActive(item.href) ? "page" : undefined}
                  class:list={[
                    "text-sm font-semibold tracking-[0.02em] text-argmin-light transition-colors duration-200 hover:text-argmin-dark focus-visible:text-argmin-dark focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-argmin-accent focus-visible:ring-offset-2 rounded-sm",
                    isActive(item.href) && "nav-link-active",
                  ]}
                >
                  {item.label}
                </a>
              </li>
            ))}
          </ul>
        </nav>
        <ThemeToggle />
        <a href="/demo" class="button-primary text-sm">Request a Demo</a>
      </div>

      <div class="flex items-center gap-3 min-[1080px]:hidden">
        <ThemeToggle />
        <button
          type="button"
          class="inline-flex h-10 w-10 items-center justify-center rounded-full border border-argmin-border bg-argmin-surface text-argmin-dark"
          aria-label="Toggle navigation menu"
          aria-expanded="false"
          aria-controls="mobile-nav-panel"
          data-nav-toggle
        >
          <svg viewBox="0 0 24 24" class="h-4 w-4" aria-hidden="true">
            <path d="M5 7.5h14M5 12h14M5 16.5h14" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" />
          </svg>
        </button>
      </div>
    </div>

    <div
      id="mobile-nav-panel"
      hidden
      data-nav-panel
      class="mt-4 rounded-[1.75rem] border border-argmin-border bg-argmin-surface/92 p-5 shadow-[var(--page-shadow-strong)] backdrop-blur min-[1080px]:hidden"
    >
      <nav aria-label="Mobile">
        <ul class="grid gap-3">
          {primaryNav.map((item) => (
            <li>
              <a
                href={item.href}
                aria-current={isActive(item.href) ? "page" : undefined}
                class:list={[
                  "block rounded-2xl border border-transparent bg-argmin-surface-alt/50 px-4 py-3 text-base font-semibold text-argmin-dark transition-colors duration-200 hover:border-argmin-border",
                  isActive(item.href) && "border-argmin-border bg-argmin-surface",
                ]}
              >
                {item.label}
              </a>
            </li>
          ))}
        </ul>
      </nav>

      <div class="mt-5 border-t border-argmin-border pt-5">
        <p class="text-sm leading-7 text-argmin-mid">
          Browse the expanded product architecture, then bring a real spend spike or routing problem to the demo.
        </p>
        <a href="/demo" class="button-primary mt-4 w-full text-sm">Request a Demo</a>
      </div>
    </div>
  </div>
</header>

<script is:inline>
  const navToggles = document.querySelectorAll("[data-nav-toggle]");

  for (const toggle of navToggles) {
    const panelId = toggle.getAttribute("aria-controls");
    const panel = panelId ? document.getElementById(panelId) : null;
    if (!(panel instanceof HTMLElement)) continue;

    const closePanel = () => {
      panel.hidden = true;
      toggle.setAttribute("aria-expanded", "false");
    };

    toggle.addEventListener("click", () => {
      const nextState = panel.hidden;
      panel.hidden = !nextState;
      toggle.setAttribute("aria-expanded", nextState ? "true" : "false");
    });

    document.addEventListener("click", (event) => {
      if (panel.hidden) return;
      const target = event.target;
      if (!(target instanceof Node)) return;
      if (panel.contains(target) || toggle.contains(target)) return;
      closePanel();
    });

    document.addEventListener("keydown", (event) => {
      if (event.key === "Escape") {
        closePanel();
      }
    });

    panel.querySelectorAll("a").forEach((link) => {
      link.addEventListener("click", closePanel);
    });

    window.addEventListener("resize", () => {
      if (window.innerWidth >= 1080) {
        closePanel();
      }
    });
  }
</script>
