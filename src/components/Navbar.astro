---
import ThemeToggle from "./ThemeToggle.astro";
import { navGroups } from "../content/site";

interface Props {
  hiddenUntilReveal?: boolean;
  showMobileThemeToggle?: boolean;
}

const { hiddenUntilReveal = false, showMobileThemeToggle = true } = Astro.props;
const navClass = hiddenUntilReveal ? "home-nav-hidden" : "";
const pathname = Astro.url.pathname;

const normalizePath = (value: string) => {
  if (value === "/") return "/";

  const normalized = value.replace(/\/+$/, "");
  return normalized.length > 0 ? normalized : "/";
};

const currentPath = normalizePath(pathname);
const isActive = (href: string) => {
  const base = normalizePath(href.split("#")[0]);
  return currentPath === base;
};
const isGroupActive = (items: { href: string }[]) =>
  items.some((item) => isActive(item.href));
---

<header class:list={["relative z-[90] px-6 pb-6 pt-8 md:px-8 md:pt-10", navClass]}>
  <div class="site-shell">
    <div class="navbar-bar flex items-center justify-between gap-3 rounded-full border border-argmin-border px-5 py-3 shadow-[var(--page-shadow-soft)] md:gap-5 md:px-6">
      <a
        href="/"
        class="site-wordmark shrink-0 text-argmin-dark transition-opacity duration-200 hover:opacity-72"
      >
        Argmin
      </a>

      <div class="hidden min-[1080px]:flex min-[1080px]:items-center min-[1080px]:gap-6">
        <nav aria-label="Primary">
          <ul class="flex items-center gap-5">
            {navGroups.map((group) => (
              <li class="relative" data-nav-dropdown>
                <button
                  type="button"
                  class:list={[
                    "inline-flex items-center gap-1 text-sm font-semibold tracking-[0.02em] text-argmin-light transition-colors duration-200 hover:text-argmin-dark focus-visible:text-argmin-dark focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-argmin-accent focus-visible:ring-offset-2 rounded-full",
                    isGroupActive(group.items) && "nav-link-active",
                  ]}
                  aria-expanded="false"
                  data-dropdown-trigger
                >
                  {group.label}
                  <svg viewBox="0 0 12 12" class="h-3 w-3 opacity-50" aria-hidden="true">
                    <path d="M3 5l3 3 3-3" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" />
                  </svg>
                </button>
                <div
                  class="absolute left-1/2 top-full z-50 mt-3 hidden -translate-x-1/2 rounded-xl border border-argmin-border bg-argmin-surface p-2 shadow-[var(--page-shadow-strong)]"
                  data-dropdown-panel
                >
                  <ul class="grid gap-0.5" style="min-width:11rem">
                    {group.items.map((item) => (
                      <li>
                        <a
                          href={item.href}
                          aria-current={isActive(item.href) ? "page" : undefined}
                          class:list={[
                            "block rounded-xl px-3.5 py-2 text-sm font-medium text-argmin-mid transition-colors duration-150 hover:bg-argmin-surface-alt hover:text-argmin-dark",
                            isActive(item.href) && "bg-argmin-surface-alt text-argmin-dark",
                          ]}
                        >
                          {item.label}
                        </a>
                      </li>
                    ))}
                  </ul>
                </div>
              </li>
            ))}
          </ul>
        </nav>
        <ThemeToggle />
        <a href="/contact" class="button-primary text-sm">Request a Demo</a>
      </div>

      <div class="flex items-center gap-3 min-[1080px]:hidden">
        {showMobileThemeToggle && <ThemeToggle />}
        <button
          type="button"
          class="inline-flex h-10 w-10 items-center justify-center rounded-full border border-argmin-border bg-argmin-surface text-argmin-dark"
          aria-label="Toggle navigation menu"
          aria-expanded="false"
          aria-controls="mobile-nav-panel"
          data-nav-toggle
        >
          <svg viewBox="0 0 24 24" class="h-4 w-4" aria-hidden="true">
            <path d="M5 7.5h14M5 12h14M5 16.5h14" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" />
          </svg>
        </button>
      </div>
    </div>

    <div
      id="mobile-nav-panel"
      hidden
      data-nav-panel
      class="mt-4 rounded-[1.75rem] border border-argmin-border bg-argmin-surface/92 p-5 shadow-[var(--page-shadow-strong)] backdrop-blur min-[1080px]:hidden"
    >
      <nav aria-label="Mobile">
        <ul class="grid gap-5">
          {navGroups.map((group) => (
            <li>
              <p class="section-kicker mb-2 px-1 text-xs">{group.label}</p>
              <ul class="grid gap-2">
                {group.items.map((item) => (
                  <li>
                    <a
                      href={item.href}
                      aria-current={isActive(item.href) ? "page" : undefined}
                      class:list={[
                        "block rounded-xl border border-transparent bg-argmin-surface-alt/50 px-4 py-3 text-base font-semibold text-argmin-dark transition-colors duration-200 hover:border-argmin-border",
                        isActive(item.href) && "border-argmin-border bg-argmin-surface",
                      ]}
                    >
                      {item.label}
                    </a>
                  </li>
                ))}
              </ul>
            </li>
          ))}
        </ul>
      </nav>

      <div class="mt-5 border-t border-argmin-border pt-5">
        {!showMobileThemeToggle && (
          <div class="mb-5">
            <p class="section-kicker mb-3 px-1 text-xs">Theme</p>
            <ThemeToggle />
          </div>
        )}
        <a href="/contact" class="button-primary w-full text-sm">Request a Demo</a>
      </div>
    </div>
  </div>
</header>

<script is:inline>
  /* ── Mobile nav toggle ── */
  const navToggles = document.querySelectorAll("[data-nav-toggle]");

  for (const toggle of navToggles) {
    const panelId = toggle.getAttribute("aria-controls");
    const panel = panelId ? document.getElementById(panelId) : null;
    if (!(panel instanceof HTMLElement)) continue;

    const closePanel = () => {
      panel.hidden = true;
      toggle.setAttribute("aria-expanded", "false");
    };

    toggle.addEventListener("click", () => {
      const nextState = panel.hidden;
      panel.hidden = !nextState;
      toggle.setAttribute("aria-expanded", nextState ? "true" : "false");
    });

    document.addEventListener("click", (event) => {
      if (panel.hidden) return;
      const target = event.target;
      if (!(target instanceof Node)) return;
      if (panel.contains(target) || toggle.contains(target)) return;
      closePanel();
    });

    document.addEventListener("keydown", (event) => {
      if (event.key === "Escape") {
        closePanel();
      }
    });

    panel.querySelectorAll("a").forEach((link) => {
      link.addEventListener("click", closePanel);
    });

    window.addEventListener("resize", () => {
      if (window.innerWidth >= 1080) {
        closePanel();
      }
    });
  }

  /* ── Desktop dropdown menus ── */
  const dropdowns = document.querySelectorAll("[data-nav-dropdown]");

  for (const dropdown of dropdowns) {
    const trigger = dropdown.querySelector("[data-dropdown-trigger]");
    const panel = dropdown.querySelector("[data-dropdown-panel]");
    if (!(trigger instanceof HTMLElement) || !(panel instanceof HTMLElement)) continue;

    let closeTimer;

    const open = () => {
      clearTimeout(closeTimer);
      // close other open dropdowns
      for (const other of dropdowns) {
        if (other === dropdown) continue;
        const otherPanel = other.querySelector("[data-dropdown-panel]");
        const otherTrigger = other.querySelector("[data-dropdown-trigger]");
        if (otherPanel instanceof HTMLElement) otherPanel.classList.add("hidden");
        if (otherTrigger instanceof HTMLElement) otherTrigger.setAttribute("aria-expanded", "false");
      }
      panel.classList.remove("hidden");
      trigger.setAttribute("aria-expanded", "true");
    };

    const close = () => {
      closeTimer = setTimeout(() => {
        panel.classList.add("hidden");
        trigger.setAttribute("aria-expanded", "false");
      }, 150);
    };

    trigger.addEventListener("mouseenter", open);
    trigger.addEventListener("focus", open);
    trigger.addEventListener("click", (e) => {
      e.preventDefault();
      panel.classList.contains("hidden") ? open() : close();
    });

    dropdown.addEventListener("mouseleave", close);
    panel.addEventListener("mouseenter", () => clearTimeout(closeTimer));

    document.addEventListener("keydown", (event) => {
      if (event.key === "Escape" && !panel.classList.contains("hidden")) {
        panel.classList.add("hidden");
        trigger.setAttribute("aria-expanded", "false");
        trigger.focus();
      }
    });

    panel.querySelectorAll("a").forEach((link) => {
      link.addEventListener("click", () => {
        panel.classList.add("hidden");
        trigger.setAttribute("aria-expanded", "false");
      });
    });
  }
</script>

<style>
  /*
   * Move backdrop-filter off the navbar container onto a ::before pseudo-element
   * so it doesn't create a containing block that clips absolutely positioned
   * dropdown panels.
   */
  .navbar-bar {
    position: relative;
    overflow: visible;
    /* Establish a stacking context so the ::before pseudo-element with
       z-index: -1 is contained here instead of falling behind other
       page content. */
    isolation: isolate;
  }

  .navbar-bar::before {
    content: "";
    position: absolute;
    inset: 0;
    border-radius: 2rem;
    background: rgb(var(--color-argmin-surface) / 0.82);
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
    z-index: -1;
  }
</style>
