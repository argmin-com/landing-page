---
interface Props {
  hiddenUntilReveal?: boolean;
}

const { hiddenUntilReveal = false } = Astro.props;
const navClass = hiddenUntilReveal ? "initial-hidden" : "";
const navItems = [
  { href: "/#problem", label: "About" },
  { href: "/team", label: "Team" },
  { href: "/contact", label: "Contact Us" },
];
const cta = { href: "/demo", label: "Request a Demo" };
const linkClass =
  "text-base font-bold text-argmin-dark transition-colors duration-200 hover:text-argmin-accent focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-argmin-accent";
const mobileLinkClass =
  "block rounded-xl px-4 py-3 text-base font-semibold text-argmin-dark transition-colors duration-200 hover:bg-argmin-surface-alt focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-argmin-accent";
---

<header class:list={["px-6 pt-8 pb-6 md:px-8 md:pt-10", navClass]} data-mobile-nav>
  <div class="mx-auto flex w-full max-w-6xl items-center justify-between gap-4">
    <a
      href="/"
      class="text-xl font-bold tracking-[0.08em] text-argmin-dark transition-colors duration-200 hover:text-argmin-accent focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-argmin-accent"
    >
      Argmin
    </a>

    <nav aria-label="Primary" class="hidden md:block">
      <ul class="flex items-center gap-4 md:gap-6">
        {navItems.map((item) => (
          <li><a href={item.href} class={linkClass}>{item.label}</a></li>
        ))}
        <li>
          <a
            href={cta.href}
            class="inline-flex items-center justify-center rounded-lg bg-argmin-accent px-4 py-2 text-sm font-semibold text-argmin-dark transition-colors duration-200 hover:bg-argmin-accent-hover focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-argmin-accent"
          >
            {cta.label}
          </a>
        </li>
      </ul>
    </nav>

    <button
      type="button"
      class="inline-flex items-center justify-center rounded-lg border border-argmin-border bg-white/90 px-4 py-2 text-sm font-semibold text-argmin-dark transition-colors duration-200 hover:border-argmin-accent hover:bg-argmin-surface-alt focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-argmin-accent md:hidden"
      aria-expanded="false"
      aria-controls="mobile-nav-panel"
      data-mobile-nav-toggle
    >
      Menu
    </button>
  </div>

  <nav
    id="mobile-nav-panel"
    aria-label="Mobile Primary"
    class="mx-auto mt-4 hidden w-full max-w-6xl md:hidden"
    data-mobile-nav-panel
  >
    <div class="rounded-2xl border border-argmin-border bg-white/95 p-2 shadow-[0_24px_60px_rgba(15,23,42,0.08)] backdrop-blur">
      <ul class="flex flex-col gap-1">
        {navItems.map((item) => (
          <li>
            <a href={item.href} class={mobileLinkClass} data-mobile-nav-close>{item.label}</a>
          </li>
        ))}
        <li class="pt-1">
          <a
            href={cta.href}
            class="flex items-center justify-center rounded-xl bg-argmin-accent px-4 py-3 text-base font-semibold text-argmin-dark transition-colors duration-200 hover:bg-argmin-accent-hover focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-argmin-accent"
            data-mobile-nav-close
          >
            {cta.label}
          </a>
        </li>
      </ul>
    </div>
  </nav>
</header>

<script is:inline>
  const navRoot = document.querySelector("[data-mobile-nav]");
  const toggle = navRoot?.querySelector("[data-mobile-nav-toggle]");
  const panel = navRoot?.querySelector("[data-mobile-nav-panel]");
  const closeTargets = navRoot?.querySelectorAll("[data-mobile-nav-close]");

  if (navRoot instanceof HTMLElement && toggle instanceof HTMLButtonElement && panel instanceof HTMLElement) {
    const setOpen = (isOpen) => {
      toggle.setAttribute("aria-expanded", String(isOpen));
      panel.classList.toggle("hidden", !isOpen);
    };

    setOpen(false);

    toggle.addEventListener("click", () => {
      const isOpen = toggle.getAttribute("aria-expanded") === "true";
      setOpen(!isOpen);
    });

    for (const target of closeTargets ?? []) {
      target.addEventListener("click", () => setOpen(false));
    }

    document.addEventListener("click", (event) => {
      const target = event.target;
      if (!(target instanceof Node) || !navRoot.contains(target)) {
        setOpen(false);
      }
    });

    document.addEventListener("keydown", (event) => {
      if (event.key === "Escape") {
        const isOpen = toggle.getAttribute("aria-expanded") === "true";
        if (isOpen) {
          setOpen(false);
          toggle.focus();
        }
      }
    });
  }
</script>
