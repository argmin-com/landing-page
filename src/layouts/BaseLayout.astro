---
import Navbar from "../components/Navbar.astro";
import "../styles/global.css";

interface Props {
  title?: string;
  description?: string;
  canonicalUrl?: string;
  showNavbarImmediately?: boolean;
}

const {
  title = "Argmin | Application-Level AI Cost and Usage Attribution",
  description =
    "Argmin deploys inside your environment, attributes AI spend to teams and budgets, and intervenes at decision time. Enterprise AI cost attribution.",
  canonicalUrl = "https://argmin.co/",
  showNavbarImmediately = true,
} = Astro.props;
const ogImage = "https://argmin.co/og-image.png";
---

<!doctype html>
<html lang="en" class="motion-safe:scroll-smooth">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalUrl} />
    <meta name="robots" content="index, follow" />

    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:type" content="website" />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />

    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <script is:inline>
      const hostname = window.location.hostname;
      if (hostname === "argmin.co" || hostname.endsWith(".argmin.co")) {
        const script = document.createElement("script");
        script.defer = true;
        script.dataset.domain = "argmin.co";
        script.src = "https://plausible.io/js/script.js";
        document.head.appendChild(script);
      }
    </script>
  </head>
  <body class="font-sans text-argmin-dark antialiased">
    <Navbar hiddenUntilReveal={!showNavbarImmediately} />
    <slot />
  </body>
</html>
