---
import { siteConfig } from "../content/site";
import "../styles/global.css";

interface Props {
  title?: string;
  description?: string;
  canonicalUrl?: string;
}

const {
  title = siteConfig.title,
  description = siteConfig.description,
  canonicalUrl = siteConfig.siteUrl,
} = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="referrer" content="strict-origin-when-cross-origin" />
    <meta name="theme-color" content="#0F2B46" />
    <link rel="canonical" href={canonicalUrl} />
    <meta name="robots" content="index, follow" />

    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={siteConfig.ogImage} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content={siteConfig.name} />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={siteConfig.ogImage} />

    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <script defer data-domain="argmin.co" src="https://plausible.io/js/script.js"></script>
  </head>
  <body class="bg-argmin-white font-body text-argmin-slate-700 antialiased">
    <a href="#main-content" class="skip-link">Skip to content</a>
    <slot />
    <script type="module" src="/scripts/site.js"></script>
  </body>
</html>
