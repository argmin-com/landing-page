---
import "../styles/global.css";

const title = "Argmin | AI Cost Attribution and Optimization";
const description =
  "Argmin deploys inside your environment, attributes AI spend to teams and budgets, and intervenes at decision time. Enterprise AI cost intelligence.";
const canonicalUrl = "https://argmin.co/";
const ogImage = "https://argmin.co/og-image.png";
---

<!doctype html>
<html lang="en" class="motion-safe:scroll-smooth">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalUrl} />
    <meta name="robots" content="index, follow" />

    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:type" content="website" />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />

    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <script is:inline defer data-domain="argmin.co" src="https://plausible.io/js/script.js"></script>
  </head>
  <body class="bg-white font-sans text-argmin-dark antialiased">
    <slot />
  </body>
</html>
