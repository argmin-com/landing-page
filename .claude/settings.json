{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "allow": [
      "Bash(npm run check)",
      "Bash(npm run build)",
      "Bash(npm run validate:*)",
      "Bash(npm run audit:site)",
      "Bash(npm run preview)",
      "Bash(npx astro check)",
      "Bash(npx playwright *)",
      "Bash(git status*)",
      "Bash(git log*)",
      "Bash(git diff*)",
      "Bash(git branch*)",
      "Bash(git fetch*)",
      "Bash(ls *)",
      "Bash(cat package.json)",
      "Bash(node scripts/*)"
    ]
  }
}
