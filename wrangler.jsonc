{
  "$schema": "./node_modules/wrangler/config-schema.json",
  "name": "landing-page",
  "compatibility_date": "2026-04-12",
  "compatibility_flags": ["nodejs_compat", "global_fetch_strictly_public"],
  "assets": {
    "directory": "./dist",
    "not_found_handling": "404-page"
  },
  "observability": {
    "logs": {},
    "traces": {
      "enabled": true
    }
  }
}
